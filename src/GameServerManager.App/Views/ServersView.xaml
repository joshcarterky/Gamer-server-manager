<UserControl x:Class="GameServerManager.App.Views.ServersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="#B30D1724"/>
            <Setter Property="BorderBrush" Value="#26394A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Foreground" Value="#EAF2FA"/>
            <Setter Property="Background" Value="#142234"/>
            <Setter Property="BorderBrush" Value="#2B4057"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="13,8"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Background" Value="#1E62E8"/>
            <Setter Property="BorderBrush" Value="#2F7BFF"/>
        </Style>

        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="MinWidth" Value="36"/>
        </Style>

        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Background" Value="#0E1824"/>
            <Setter Property="Foreground" Value="#E8F0F8"/>
            <Setter Property="BorderBrush" Value="#2A4057"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CaretBrush" Value="#E8F0F8"/>
        </Style>

        <Style x:Key="ComboInput" TargetType="ComboBox">
            <Setter Property="Background" Value="#0E1824"/>
            <Setter Property="Foreground" Value="#E8F0F8"/>
            <Setter Property="TextElement.Foreground" Value="#E8F0F8"/>
            <Setter Property="BorderBrush" Value="#2A4057"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,7"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#0E1824"/>
                        <Setter Property="Foreground" Value="#E8F0F8"/>
                        <Setter Property="Padding" Value="10,7"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBorder"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter TextElement.Foreground="#E8F0F8"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#183A5B"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#1E62E8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Chrome"
                                                Background="#0E1824"
                                                BorderBrush="#2A4057"
                                                BorderThickness="1"
                                                CornerRadius="2">
                                            <Grid>
                                                <ContentPresenter Margin="10,0,30,0"
                                                                  TextElement.Foreground="#E8F0F8"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                                <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="#9BAABC"
                                                      Width="8"
                                                      Height="4"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#397BFF"/>
                                                <Setter TargetName="Chrome" Property="Background" Value="#122236"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Background="#0E1824"
                                        BorderBrush="#2A4057"
                                        BorderThickness="1"
                                        CornerRadius="2"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="260">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AFC0D0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="BodyText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DDE7F2"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="5"/>
            <Setter Property="Width" Value="90"/>
            <Setter Property="Background" Value="#203040"/>
            <Setter Property="Foreground" Value="#397BFF"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="78"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="46"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource Panel}" Padding="18,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Text="Servers" Foreground="White" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text="Manage all of your game servers from one place."
                               Foreground="#9BAABC"
                               FontSize="12"
                               Margin="12,6,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="+ Add Server"
                            Command="{Binding ToggleAddServerCommand, Mode=OneWay}"
                            Style="{StaticResource PrimaryButton}"/>
                    <Button Content="Import"
                            Command="{Binding ImportServerCommand, Mode=OneWay}"
                            Style="{StaticResource ToolbarButton}"/>
                    <Button Content="..." Style="{StaticResource IconButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#A009121C" BorderBrush="#1E3144" BorderThickness="1,0,1,1" Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource Input}"
                         ToolTip="Search servers"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding StatusFilters, Mode=OneWay}"
                          SelectedItem="{Binding FilterStatus, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          Style="{StaticResource ComboInput}"
                          Margin="12,0,0,0"/>
                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding ProviderFilters, Mode=OneWay}"
                          SelectedItem="{Binding FilterProvider, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          Style="{StaticResource ComboInput}"
                          Margin="12,0,0,0"/>
                <Button Grid.Column="3" Content="Tags" Style="{StaticResource ToolbarButton}" Margin="12,0,0,0"/>
                <Button Grid.Column="5"
                        Content="Refresh"
                        Command="{Binding RefreshCommand, Mode=OneWay}"
                        Style="{StaticResource ToolbarButton}"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Panel}" Padding="0" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="56"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="#142231">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock Text="SERVER OPERATIONS" Style="{StaticResource HeaderText}" VerticalAlignment="Center"/>
                        <TextBlock Text="Live status, resource usage, maintenance, and profile health" Foreground="#7F91A4" FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="ACTIONS" Style="{StaticResource HeaderText}" VerticalAlignment="Center" Margin="0,0,18,0"/>
                </Grid>

                <Grid Grid.Row="1">
                    <Border Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="No servers added yet" Foreground="White" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Add a profile to start managing real JSON-backed game servers."
                                       Foreground="#A8B7C8"
                                       FontSize="14"
                                       Margin="0,8,0,18"
                                       HorizontalAlignment="Center"/>
                            <Button Content="+ Add Server"
                                    Command="{Binding ToggleAddServerCommand, Mode=OneWay}"
                                    Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding FilteredServers, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#111D2B" BorderBrush="#2A4057" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,10">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="2.2*"/>
                                                    <ColumnDefinition Width="1.05*"/>
                                                    <ColumnDefinition Width="1.05*"/>
                                                    <ColumnDefinition Width="1.1*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                                                    <Button Content="{Binding FavoriteIcon, Mode=OneWay}" Foreground="{Binding FavoriteColor, Mode=OneWay}" Background="Transparent" BorderBrush="Transparent" FontSize="18" Width="30" Height="30" Cursor="Hand" Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                    <Border Width="46" Height="46" CornerRadius="6" Background="#183349" Margin="8,0,14,0">
                                                        <TextBlock Text="{Binding IconText, Mode=OneWay}" Foreground="#68C7FF" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Margin="0,0,18,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding ServerName, Mode=OneWay}" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                                                        <Border Background="#162C3D" BorderBrush="#31506B" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="10,0,0,0">
                                                            <TextBlock Text="{Binding StatusText, Mode=OneWay}" Foreground="{Binding StatusColor, Mode=OneWay}" FontSize="12" FontWeight="SemiBold"/>
                                                        </Border>
                                                        <Border Background="#152F3D" BorderBrush="#36627A" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="8,0,0,0" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <TextBlock Text="{Binding BusyText, Mode=OneWay}" Foreground="#68C7FF" FontSize="12" FontWeight="SemiBold"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding GameName, Mode=OneWay}" Foreground="#A8B7C8" FontSize="12" Margin="0,6,0,0"/>
                                                    <TextBlock Text="{Binding Endpoint, Mode=OneWay}" Foreground="#7F91A4" FontSize="12" Margin="0,4,0,0"/>
                                                    <TextBlock Text="{Binding MapName, Mode=OneWay, StringFormat=Map: {0}}" Foreground="#7F91A4" FontSize="12" Margin="0,4,0,0"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" Margin="0,0,18,0">
                                                    <TextBlock Text="Players" Foreground="#7F91A4" FontSize="11"/>
                                                    <TextBlock Text="{Binding PlayersText, Mode=OneWay}" Foreground="#EAF2FA" FontSize="15" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                                    <ProgressBar Value="{Binding PlayerCount, Mode=OneWay}" Maximum="{Binding MaxPlayers, Mode=OneWay}" Foreground="#43D17A" Margin="0,9,0,0" Height="5"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="3" Margin="0,0,18,0">
                                                    <TextBlock Text="CPU" Foreground="#7F91A4" FontSize="11"/>
                                                    <TextBlock Text="{Binding CpuPercent, Mode=OneWay, StringFormat={}{0}%}" Foreground="#EAF2FA" FontSize="15" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                                    <ProgressBar Value="{Binding CpuPercent, Mode=OneWay}" Maximum="100" Foreground="#397BFF" Margin="0,9,0,0" Height="5"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="4" Margin="0,0,18,0">
                                                    <TextBlock Text="Memory" Foreground="#7F91A4" FontSize="11"/>
                                                    <TextBlock Text="{Binding RamText, Mode=OneWay}" Foreground="#EAF2FA" FontSize="15" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                                    <ProgressBar Value="{Binding RamPercent, Mode=OneWay}" Maximum="100" Foreground="#8D55FF" Margin="0,9,0,0" Height="5"/>
                                                </StackPanel>

                                                <WrapPanel Grid.Column="5" HorizontalAlignment="Right" VerticalAlignment="Top" MaxWidth="430">
                                                    <Button Content="Start" Command="{Binding DataContext.StartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" IsEnabled="{Binding CanStart, Mode=OneWay}" Style="{StaticResource IconButton}" Margin="4,0,0,6"/>
                                                    <Button Content="Stop" Command="{Binding DataContext.StopCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" IsEnabled="{Binding CanStop, Mode=OneWay}" Style="{StaticResource IconButton}" Margin="4,0,0,6"/>
                                                    <Button Content="Restart" Command="{Binding DataContext.RestartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource IconButton}" Margin="4,0,0,6"/>
                                                    <Button Content="Install/Update" Command="{Binding DataContext.UpdateServerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource IconButton}" Margin="4,0,0,6"/>
                                                    <Button Content="Console" Command="{Binding DataContext.ViewConsoleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource IconButton}" Margin="4,0,0,6"/>
                                                    <Button Content="Files" Command="{Binding DataContext.OpenFilesCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource IconButton}" Margin="4,0,0,6"/>
                                                    <Button Content="Settings" Command="{Binding DataContext.OpenSettingsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource IconButton}" Margin="4,0,0,6"/>
                                                    <Button Content="Backup" Command="{Binding DataContext.BackupNowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource IconButton}" Margin="4,0,0,6"/>
                                                    <Button Content="{Binding ExpandText, Mode=OneWay}" Command="{Binding DataContext.ToggleCardCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource IconButton}" Margin="4,0,0,6"/>
                                                    <Button Content="More" Command="{Binding DataContext.MoreOptionsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource IconButton}" Margin="4,0,0,6"/>
                                                    <Button Content="Delete" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource IconButton}" Margin="4,0,0,6" Foreground="#FF8D8D" BorderBrush="#6F3440"/>
                                                </WrapPanel>
                                            </Grid>

                                            <Border Background="#0D1825" BorderBrush="#203447" BorderThickness="1" CornerRadius="5" Padding="12" Margin="0,14,0,0" Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.2*"/>
                                                        <ColumnDefinition Width="1.2*"/>
                                                        <ColumnDefinition Width="1.2*"/>
                                                        <ColumnDefinition Width="1.6*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                                        <TextBlock Text="Ports" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding GamePortText, Mode=OneWay, StringFormat=Game: {0}}" Foreground="#A8B7C8" FontSize="12" Margin="0,8,0,0"/>
                                                        <TextBlock Text="{Binding QueryPortText, Mode=OneWay, StringFormat=Query: {0}}" Foreground="#A8B7C8" FontSize="12" Margin="0,5,0,0"/>
                                                        <TextBlock Text="{Binding RconPortText, Mode=OneWay, StringFormat=RCON: {0}}" Foreground="#A8B7C8" FontSize="12" Margin="0,5,0,0"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Margin="0,0,18,0">
                                                        <TextBlock Text="Runtime" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Uptime, Mode=OneWay, StringFormat=Uptime: {0}}" Foreground="#A8B7C8" FontSize="12" Margin="0,8,0,0"/>
                                                        <TextBlock Text="{Binding LastStarted, Mode=OneWay, StringFormat=Started: {0}}" Foreground="#A8B7C8" FontSize="12" Margin="0,5,0,0"/>
                                                        <TextBlock Text="{Binding LastStopped, Mode=OneWay, StringFormat=Stopped: {0}}" Foreground="#A8B7C8" FontSize="12" Margin="0,5,0,0"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Margin="0,0,18,0">
                                                        <TextBlock Text="Maintenance" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding BackupStatus, Mode=OneWay, StringFormat=Backup: {0}}" Foreground="#A8B7C8" FontSize="12" Margin="0,8,0,0"/>
                                                        <TextBlock Text="{Binding UpdateStatus, Mode=OneWay, StringFormat=Update: {0}}" Foreground="#A8B7C8" FontSize="12" Margin="0,5,0,0"/>
                                                        <TextBlock Text="{Binding DiskUsageText, Mode=OneWay, StringFormat=Disk: {0}}" Foreground="#A8B7C8" FontSize="12" Margin="0,5,0,0"/>
                                                        <TextBlock Text="{Binding NetworkActivityText, Mode=OneWay, StringFormat=Network: {0}}" Foreground="#A8B7C8" FontSize="12" Margin="0,5,0,0"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="3">
                                                        <TextBlock Text="Paths and Warnings" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding InstallPath, Mode=OneWay, StringFormat=Install: {0}}" Foreground="#A8B7C8" FontSize="12" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                                        <ItemsControl ItemsSource="{Binding WarningBadges, Mode=OneWay}" Margin="0,10,0,0">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="#2D1D1D" BorderBrush="#7A3C3C" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,0,6,6">
                                                                        <TextBlock Text="{Binding}" Foreground="#FFB46B" FontSize="11"/>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                            <Button Content="Edit" Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource IconButton}"/>
                                                            <Button Content="Delete" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource IconButton}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>


                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Message, Mode=OneWay}" Foreground="#A8B7C8" FontSize="12" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBlock Text="{Binding FilteredServers.Count, Mode=OneWay, StringFormat=Showing {0} server(s)}" Foreground="#A8B7C8" FontSize="12" VerticalAlignment="Center" Margin="0,0,18,0"/>
                <Button Content="1" Style="{StaticResource PrimaryButton}"/>
                <Button Content="20 / page" Style="{StaticResource ToolbarButton}"/>
            </StackPanel>
        </Grid>

        <Border Grid.RowSpan="4"
                Panel.ZIndex="50"
                Background="#CC050A11"
                Visibility="{Binding IsAddServerOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Style="{StaticResource Panel}"
                    Width="920"
                    MaxWidth="980"
                    Margin="26"
                    Padding="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding AddServer.DialogTitle, Mode=OneWay}" Foreground="White" FontSize="22" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding AddServer.StepTitle, Mode=OneWay}" Foreground="#A8B7C8" FontSize="13" Margin="0,5,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Close" Command="{Binding ToggleAddServerCommand, Mode=OneWay}" Style="{StaticResource ToolbarButton}"/>
                    </Grid>

                    <Grid MinHeight="340">
                        <StackPanel Visibility="{Binding AddServer.IsStep1, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Game Type" Foreground="#A8B7C8" FontSize="12" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding AddServer.Providers, Mode=OneWay}"
                                      SelectedItem="{Binding AddServer.SelectedProvider, Mode=TwoWay}"
                                      DisplayMemberPath="GameName"
                                      Style="{StaticResource ComboInput}"
                                      Width="420"
                                      HorizontalAlignment="Left"/>
                        </StackPanel>

                        <Grid Visibility="{Binding AddServer.IsStep2, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Margin="0,0,8,10">
                                <TextBlock Text="Server Name" Foreground="#A8B7C8" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding AddServer.ServerName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,10">
                                <TextBlock Text="Tags" Foreground="#A8B7C8" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding AddServer.Tags, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,10">
                                <TextBlock Text="Description" Foreground="#A8B7C8" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding AddServer.Description, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}" Height="70" TextWrapping="Wrap" AcceptsReturn="True"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Margin="0,0,8,10">
                                <TextBlock Text="Server Path" Foreground="#A8B7C8" FontSize="12" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding AddServer.ServerPath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                    <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseServerPathCommand, Mode=OneWay}" Style="{StaticResource ToolbarButton}" Margin="8,0,0,0"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,10">
                                <TextBlock Text="Install Directory" Foreground="#A8B7C8" FontSize="12" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding AddServer.InstallPath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                    <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseInstallPathCommand, Mode=OneWay}" Style="{StaticResource ToolbarButton}" Margin="8,0,0,0"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Margin="0,0,8,0">
                                <TextBlock Text="Executable Path" Foreground="#A8B7C8" FontSize="12" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding AddServer.ExecutablePath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                    <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseExecutablePathCommand, Mode=OneWay}" Style="{StaticResource ToolbarButton}" Margin="8,0,0,0"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Save Directory" Foreground="#A8B7C8" FontSize="12" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding AddServer.SaveDirectory, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                    <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseSaveDirectoryCommand, Mode=OneWay}" Style="{StaticResource ToolbarButton}" Margin="8,0,0,0"/>
                                </Grid>
                                <TextBlock Text="Backup Directory" Foreground="#A8B7C8" FontSize="12" Margin="0,10,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding AddServer.BackupDirectory, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                    <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseBackupDirectoryCommand, Mode=OneWay}" Style="{StaticResource ToolbarButton}" Margin="8,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <Grid Visibility="{Binding AddServer.IsStep3, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Margin="0,0,8,10">
                                <TextBlock Text="IP Address" Foreground="#A8B7C8" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding AddServer.IpAddress, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,10">
                                <TextBlock Text="Game Port" Foreground="#A8B7C8" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding AddServer.GamePort, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="0,0,8,10">
                                <TextBlock Text="Query Port" Foreground="#A8B7C8" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding AddServer.QueryPort, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,10">
                                <TextBlock Text="RCON Port" Foreground="#A8B7C8" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding AddServer.RconPort, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.ColumnSpan="2">
                                <TextBlock Text="RCON Password" Foreground="#A8B7C8" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding AddServer.RconPassword, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Visibility="{Binding AddServer.IsStep4, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Margin="0,0,8,10">
                                <TextBlock Text="Max Players" Foreground="#A8B7C8" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding AddServer.MaxPlayers, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,10">
                                <TextBlock Text="CPU Limit (%)" Foreground="#A8B7C8" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding AddServer.CpuLimit, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,10">
                                <CheckBox Content="Auto Restart" IsChecked="{Binding AddServer.AutoRestart, Mode=TwoWay}" Foreground="#EAF2FA" Margin="0,0,0,10"/>
                                <CheckBox Content="Auto Backup" IsChecked="{Binding AddServer.AutoBackup, Mode=TwoWay}" Foreground="#EAF2FA"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Visibility="{Binding AddServer.IsStep5, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Review" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding AddServer.ReviewText, Mode=OneWay}"
                                     Style="{StaticResource Input}"
                                     Height="320"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="Cancel" Command="{Binding ToggleAddServerCommand, Mode=OneWay}" Style="{StaticResource ToolbarButton}"/>
                        <Button Content="Back" Command="{Binding PreviousAddServerStepCommand, Mode=OneWay}" IsEnabled="{Binding AddServer.CanGoBack, Mode=OneWay}" Style="{StaticResource ToolbarButton}"/>
                        <Button Content="Next" Command="{Binding NextAddServerStepCommand, Mode=OneWay}" IsEnabled="{Binding AddServer.CanGoNext, Mode=OneWay}" Style="{StaticResource ToolbarButton}"/>
                        <Button Content="{Binding AddServer.SaveButtonText, Mode=OneWay}" Command="{Binding SaveNewServerCommand, Mode=OneWay}" IsEnabled="{Binding AddServer.IsReviewStep, Mode=OneWay}" Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.RowSpan="4"
                Panel.ZIndex="60"
                Background="#AA000814"
                Visibility="{Binding IsImportConfirmationOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Style="{StaticResource Panel}"
                    Width="820"
                    MaxWidth="960"
                    Padding="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Import Server" Foreground="White" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ImportModeText, Mode=OneWay}" Foreground="#A8B7C8" FontSize="13" Margin="0,5,0,16"/>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Source folder" Style="{StaticResource HeaderText}" Margin="0,0,12,10"/>
                        <TextBlock Grid.Column="1" Text="{Binding ImportSourceFolder, Mode=OneWay}" Style="{StaticResource BodyText}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="1" Text="Destination" Style="{StaticResource HeaderText}" Margin="0,0,12,10"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ImportDestinationDisplay, Mode=OneWay}" Style="{StaticResource BodyText}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="2" Text="Server name" Style="{StaticResource HeaderText}" Margin="0,0,12,10"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ImportServerName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="3" Text="Game type" Style="{StaticResource HeaderText}" Margin="0,0,12,10"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ImportGameName, Mode=OneWay}" Style="{StaticResource BodyText}" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="4" Text="Folder size" Style="{StaticResource HeaderText}" Margin="0,0,12,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ImportEstimatedSize, Mode=OneWay}" Style="{StaticResource BodyText}"/>
                    </Grid>

                    <Border Background="#101C2A" BorderBrush="#2A4057" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,14">
                        <StackPanel>
                            <CheckBox Content="Link existing folder instead of copying"
                                      IsChecked="{Binding LinkExistingFolder, Mode=TwoWay}"
                                      Foreground="#EAF2FA"/>
                            <TextBlock Text="Advanced option. Linked servers stay in their original location, so moving or deleting that folder can break the server."
                                       Foreground="#FFCF8A"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="24,7,0,0"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Visibility="{Binding IsImportRunning, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,14">
                        <TextBlock Text="{Binding ImportStatus, Mode=OneWay}" Foreground="#EAF2FA" FontSize="13" FontWeight="SemiBold"/>
                        <ProgressBar Value="{Binding ImportProgress, Mode=OneWay}" Maximum="100" Height="8" Width="Auto" Margin="0,8,0,8"/>
                        <TextBlock Text="{Binding ImportCurrentFile, Mode=OneWay}" Foreground="#A8B7C8" FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel"
                                Command="{Binding CancelImportCommand, Mode=OneWay}"
                                Style="{StaticResource ToolbarButton}"/>
                        <Button Content="Stop Copy"
                                Command="{Binding CancelImportCopyCommand, Mode=OneWay}"
                                Visibility="{Binding IsImportRunning, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Style="{StaticResource ToolbarButton}"/>
                        <Button Content="Import"
                                Command="{Binding ConfirmImportCommand, Mode=OneWay}"
                                IsEnabled="{Binding CanConfirmImport, Mode=OneWay}"
                                Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.RowSpan="4"
                Panel.ZIndex="70"
                Background="#AA000814"
                Visibility="{Binding IsConsoleOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Style="{StaticResource Panel}"
                    Width="920"
                    MaxWidth="1100"
                    MaxHeight="650"
                    Padding="18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding ConsoleTitle, Mode=OneWay}" Foreground="White" FontSize="22" FontWeight="SemiBold"/>
                        <TextBlock Text="Latest server log output" Foreground="#A8B7C8" FontSize="13" Margin="0,4,0,12"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Refresh" Command="{Binding RefreshConsoleCommand, Mode=OneWay}" Style="{StaticResource ToolbarButton}"/>
                        <Button Content="Close" Command="{Binding CloseConsoleCommand, Mode=OneWay}" Style="{StaticResource ToolbarButton}"/>
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             Grid.ColumnSpan="2"
                             Text="{Binding ConsoleText, Mode=OneWay}"
                             Style="{StaticResource Input}"
                             FontFamily="Consolas"
                             FontSize="12"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
