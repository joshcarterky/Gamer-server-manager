<UserControl x:Class="GameServerManager.App.Views.ServersView"
             x:Name="ServersViewRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>

        <!-- ═══ Converters ══════════════════════════════════════════════════ -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ═══ Color palette ═══════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="Surface0" Color="#070E17"/>
        <SolidColorBrush x:Key="Surface1" Color="#0C1726"/>
        <SolidColorBrush x:Key="Surface2" Color="#111D2B"/>
        <SolidColorBrush x:Key="Surface3" Color="#162433"/>
        <SolidColorBrush x:Key="BorderMuted" Color="#1C3045"/>
        <SolidColorBrush x:Key="BorderSubtle" Color="#243A50"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E8F2FA"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8BA3B8"/>
        <SolidColorBrush x:Key="TextMuted" Color="#526070"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#2268E0"/>
        <SolidColorBrush x:Key="AccentBlueDark" Color="#1252B8"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#1D8049"/>

        <!-- ═══ Base button template ════════════════════════════════════════ -->
        <ControlTemplate x:Key="FlatButtonTemplate" TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- ═══ Shared button styles ════════════════════════════════════════ -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Foreground" Value="#D8EAF8"/>
            <Setter Property="Background" Value="#152436"/>
            <Setter Property="BorderBrush" Value="#253E56"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="13,8"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template" Value="{StaticResource FlatButtonTemplate}"/>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#1E62E8"/>
            <Setter Property="BorderBrush" Value="#2D78FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#145C38"/>
            <Setter Property="BorderBrush" Value="#1D7A4A"/>
            <Setter Property="Foreground" Value="#3DDA85"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="BtnConsole" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#0E2236"/>
            <Setter Property="BorderBrush" Value="#1A3E5C"/>
            <Setter Property="Foreground" Value="#5BB8FF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="BtnIcon" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="BtnPower" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="#111E2C"/>
            <Setter Property="BorderBrush" Value="#1E3347"/>
        </Style>

        <!-- ═══ Input styles ════════════════════════════════════════════════ -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background" Value="#0C1726"/>
            <Setter Property="Foreground" Value="#D8EAF8"/>
            <Setter Property="BorderBrush" Value="#1E3347"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="CaretBrush" Value="#D8EAF8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FilterCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#0C1726"/>
            <Setter Property="Foreground" Value="#D8EAF8"/>
            <Setter Property="TextElement.Foreground" Value="#D8EAF8"/>
            <Setter Property="BorderBrush" Value="#1E3347"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#0C1726"/>
                        <Setter Property="Foreground" Value="#D8EAF8"/>
                        <Setter Property="Padding" Value="10,7"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="B" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter TextElement.Foreground="#D8EAF8"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="B" Property="Background" Value="#162C42"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="B" Property="Background" Value="#1E62E8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="C" Background="#0C1726" BorderBrush="#1E3347" BorderThickness="1" CornerRadius="6">
                                            <Grid>
                                                <ContentPresenter Margin="10,0,28,0"
                                                                  TextElement.Foreground="#D8EAF8"
                                                                  VerticalAlignment="Center"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                                <Path Data="M 0 0 L 4 4 L 8 0 Z" Fill="#6A85A0"
                                                      Width="8" Height="4"
                                                      HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="C" Property="BorderBrush" Value="#2D78FF"/>
                                                <Setter TargetName="C" Property="Background" Value="#0E1E30"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup AllowsTransparency="True" Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" PopupAnimation="Fade">
                                <Border Background="#0C1726" BorderBrush="#1E3347" BorderThickness="1" CornerRadius="6"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="280">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ ContextMenu style ════════════════════════════════════════════ -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#0E1A28"/>
            <Setter Property="BorderBrush" Value="#1E3347"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0,4"/>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#D0E4F4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="MB" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="MB" Property="Background" Value="#142233"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#3E5568"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Progress bar style ══════════════════════════════════════════ -->
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="3"/>
            <Setter Property="Background" Value="#182A3A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#2268E0"/>
        </Style>

        <!-- ═══ Separator ═══════════════════════════════════════════════════ -->
        <Style x:Key="MenuSep" TargetType="Separator">
            <Setter Property="Background" Value="#1C3045"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <!-- ═══ Text styles ═════════════════════════════════════════════════ -->
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5C7A90"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D8EAF8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- ═══ Summary card style ══════════════════════════════════════════ -->
        <Style x:Key="SummaryCard" TargetType="Border">
            <Setter Property="Background" Value="#0C1726"/>
            <Setter Property="BorderBrush" Value="#1C3045"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,14"/>
        </Style>

        <!-- ═══ Server card surface ═════════════════════════════════════════ -->
        <Style x:Key="ServerCard" TargetType="Border">
            <Setter Property="Background" Value="#0D1A27"/>
            <Setter Property="BorderBrush" Value="#1B3048"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- ═══ Expanded drawer ══════════════════════════════════════════════ -->
        <Style x:Key="DrawerPanel" TargetType="Border">
            <Setter Property="Background" Value="#091422"/>
            <Setter Property="BorderBrush" Value="#1A2E42"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="Padding" Value="16,14"/>
        </Style>

        <!-- ═══ Input for wizard/overlay ════════════════════════════════════ -->
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Background" Value="#0C1726"/>
            <Setter Property="Foreground" Value="#D8EAF8"/>
            <Setter Property="BorderBrush" Value="#1E3347"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CaretBrush" Value="#D8EAF8"/>
        </Style>

        <Style x:Key="ComboInput" TargetType="ComboBox" BasedOn="{StaticResource FilterCombo}"/>

        <!-- ═══ Overlay panel ════════════════════════════════════════════════ -->
        <Style x:Key="OverlayPanel" TargetType="Border">
            <Setter Property="Background" Value="#0D1A27"/>
            <Setter Property="BorderBrush" Value="#1B3048"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>

    </UserControl.Resources>

    <!-- ═══════════════════════════════════════════════════════════════════════
         ROOT LAYOUT
    ═══════════════════════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: Summary cards -->
            <RowDefinition Height="Auto"/>  <!-- 1: Toolbar -->
            <RowDefinition Height="*"/>     <!-- 2: Server list -->
            <RowDefinition Height="Auto"/>  <!-- 3: Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ ROW 0 — Summary cards ══════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="18,14,18,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Total Servers -->
            <Border Grid.Column="0" Style="{StaticResource SummaryCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding TotalCount, Mode=OneWay}"
                                   Foreground="White" FontSize="26" FontWeight="Bold"/>
                        <TextBlock Text="TOTAL SERVERS" Style="{StaticResource LabelText}" Margin="0,5,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Width="36" Height="36" CornerRadius="8"
                            Background="#112236" VerticalAlignment="Center">
                        <TextBlock Text="⊞" Foreground="#4A8FB8" FontSize="16"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Online -->
            <Border Grid.Column="2" Style="{StaticResource SummaryCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding OnlineCount, Mode=OneWay}"
                                   Foreground="#3DDA85" FontSize="26" FontWeight="Bold"/>
                        <TextBlock Text="ONLINE" Style="{StaticResource LabelText}" Margin="0,5,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Width="36" Height="36" CornerRadius="8"
                            Background="#0A2018" VerticalAlignment="Center">
                        <TextBlock Text="●" Foreground="#3DDA85" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Players -->
            <Border Grid.Column="4" Style="{StaticResource SummaryCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding TotalPlayerDisplay, Mode=OneWay}"
                                   Foreground="White" FontSize="26" FontWeight="Bold"/>
                        <TextBlock Text="ACTIVE PLAYERS" Style="{StaticResource LabelText}" Margin="0,5,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Width="36" Height="36" CornerRadius="8"
                            Background="#0C1830" VerticalAlignment="Center">
                        <TextBlock Text="♟" Foreground="#5BB8FF" FontSize="16"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Needs Attention -->
            <Border Grid.Column="6" Style="{StaticResource SummaryCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding AttentionCount, Mode=OneWay}"
                                   Foreground="#F7C34A" FontSize="26" FontWeight="Bold"/>
                        <TextBlock Text="NEEDS ATTENTION" Style="{StaticResource LabelText}" Margin="0,5,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Width="36" Height="36" CornerRadius="8"
                            Background="#22180A" VerticalAlignment="Center">
                        <TextBlock Text="⚠" Foreground="#F7C34A" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Servers count badge -->
            <Border Grid.Column="8" Style="{StaticResource SummaryCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding FilteredServers.Count, Mode=OneWay}"
                                   Foreground="White" FontSize="26" FontWeight="Bold"/>
                        <TextBlock Text="SHOWING" Style="{StaticResource LabelText}" Margin="0,5,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Width="36" Height="36" CornerRadius="8"
                            Background="#0E1E2C" VerticalAlignment="Center">
                        <TextBlock Text="▤" Foreground="#6A8FAA" FontSize="16"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Page action buttons (right side, same row) -->
            <Button Grid.Column="10"
                    Content="+ Add Server"
                    Command="{Binding ToggleAddServerCommand, Mode=OneWay}"
                    Style="{StaticResource BtnPrimary}"
                    Padding="16,0" Height="36" VerticalAlignment="Center"/>
            <Button Grid.Column="12"
                    Content="Import"
                    Command="{Binding ImportServerCommand, Mode=OneWay}"
                    Style="{StaticResource BtnBase}"
                    Padding="14,0" Height="36" VerticalAlignment="Center"/>
            <Button Grid.Column="14"
                    Content="⋯"
                    Style="{StaticResource BtnBase}"
                    Width="36" Height="36" VerticalAlignment="Center" FontSize="16"/>
        </Grid>

        <!-- ═══ ROW 1 — Toolbar ═════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#0A1520" BorderBrush="#162638"
                BorderThickness="0,1,0,1" Padding="18,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="180"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#0C1726" BorderBrush="#1E3347" BorderThickness="1,1,0,1"
                            CornerRadius="6,0,0,6" Padding="10,0" Width="34">
                        <TextBlock Text="⌕" Foreground="#4A6A80" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBox Grid.Column="1"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchBox}"
                             BorderThickness="0,1,1,1"
                             Padding="6,0,10,0">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="0,6,6,0"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </Grid>

                <!-- Status filter -->
                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding StatusFilters, Mode=OneWay}"
                          SelectedItem="{Binding FilterStatus, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          Style="{StaticResource FilterCombo}"/>

                <!-- Game filter -->
                <ComboBox Grid.Column="4"
                          ItemsSource="{Binding ProviderFilters, Mode=OneWay}"
                          SelectedItem="{Binding FilterProvider, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          Style="{StaticResource FilterCombo}"/>

                <!-- Refresh -->
                <Button Grid.Column="6"
                        Content="↺  Refresh"
                        Command="{Binding RefreshCommand, Mode=OneWay}"
                        Style="{StaticResource BtnBase}"
                        Padding="14,0" Height="36"/>
            </Grid>
        </Border>

        <!-- ═══ ROW 2 — Server list ═════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <!-- Empty state (no servers at all) -->
            <Border Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <Border Width="72" Height="72" CornerRadius="16" Background="#0E1E2E"
                            BorderBrush="#1E3A52" BorderThickness="1" HorizontalAlignment="Center">
                        <TextBlock Text="⊞" Foreground="#2B6090" FontSize="36"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="No servers configured"
                               Foreground="White" FontSize="20" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,20,0,0"/>
                    <TextBlock Text="Add a server profile to start managing your dedicated game servers."
                               Foreground="#607A90" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,8,0,24"/>
                    <Button Content="+ Add Server"
                            Command="{Binding ToggleAddServerCommand, Mode=OneWay}"
                            Style="{StaticResource BtnPrimary}"
                            HorizontalAlignment="Center" Padding="20,0" Height="38"/>
                </StackPanel>
            </Border>

            <!-- Server list -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding HasServers, Converter={StaticResource BoolToVis}}">
                <StackPanel Margin="18,12,18,18">
                    <ItemsControl ItemsSource="{Binding FilteredServers, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ServerCard}">
                                    <StackPanel>

                                        <!-- ── Card main row ──────────────────────── -->
                                        <Grid Margin="14,12,12,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>   <!-- 0: fav + tile -->
                                                <ColumnDefinition Width="*"/>      <!-- 1: identity -->
                                                <ColumnDefinition Width="104"/>    <!-- 2: players -->
                                                <ColumnDefinition Width="96"/>     <!-- 3: cpu -->
                                                <ColumnDefinition Width="110"/>    <!-- 4: ram -->
                                                <ColumnDefinition Width="Auto"/>   <!-- 5: actions -->
                                            </Grid.ColumnDefinitions>

                                            <!-- Col 0: Favorite + Game tile -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,12,0">
                                                <Button Content="{Binding FavoriteIcon, Mode=OneWay}"
                                                        Foreground="{Binding FavoriteColor, Mode=OneWay}"
                                                        Background="Transparent"
                                                        BorderBrush="Transparent"
                                                        BorderThickness="0"
                                                        Width="22" Height="22"
                                                        Padding="0"
                                                        FontSize="14"
                                                        Cursor="Hand"
                                                        VerticalAlignment="Top"
                                                        Margin="0,2,6,0"
                                                        ToolTip="Toggle favorite"
                                                        Command="{Binding DataContext.ToggleFavoriteCommand, ElementName=ServersViewRoot}"
                                                        CommandParameter="{Binding}"/>
                                                <!-- Game tile -->
                                                <Border Width="48" Height="48" CornerRadius="8"
                                                        Background="{Binding GameTileBackground}"
                                                        BorderBrush="{Binding GameAccentColor}"
                                                        BorderThickness="1">
                                                    <TextBlock Text="{Binding GameInitials, Mode=OneWay}"
                                                               Foreground="{Binding GameAccentColor}"
                                                               FontSize="16" FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </StackPanel>

                                            <!-- Col 1: Identity -->
                                            <StackPanel Grid.Column="1" Margin="0,0,12,0" VerticalAlignment="Center">

                                                <!-- Name + Status badge + Busy -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding ServerName, Mode=OneWay}"
                                                               Foreground="White" FontSize="15" FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>
                                                    <!-- Status badge -->
                                                    <Border Background="{Binding StatusBadgeBackground}"
                                                            BorderBrush="{Binding StatusBadgeBorder}"
                                                            BorderThickness="1" CornerRadius="4"
                                                            Padding="7,3" Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding StatusIcon, Mode=OneWay}"
                                                                       Foreground="{Binding StatusBadgeForeground}"
                                                                       FontSize="9" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                            <TextBlock Text="{Binding StatusText, Mode=OneWay}"
                                                                       Foreground="{Binding StatusBadgeForeground}"
                                                                       FontSize="11" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <!-- Busy badge -->
                                                    <Border Background="#0C1E30" BorderBrush="#1A3A58"
                                                            BorderThickness="1" CornerRadius="4"
                                                            Padding="7,3" Margin="6,0,0,0" VerticalAlignment="Center"
                                                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="{Binding BusyText, Mode=OneWay}"
                                                                   Foreground="#5BB8FF" FontSize="11" FontWeight="SemiBold"/>
                                                    </Border>
                                                </StackPanel>

                                                <!-- Game + Endpoint -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                    <TextBlock Text="{Binding GameName, Mode=OneWay}"
                                                               Foreground="#6A8BA4" FontSize="12"/>
                                                    <TextBlock Text="  ·  " Foreground="#3A5468" FontSize="12"/>
                                                    <TextBlock Text="{Binding Endpoint, Mode=OneWay}"
                                                               Foreground="#4A6A80" FontSize="12"/>
                                                    <TextBlock Text="  ·  " Foreground="#3A5468" FontSize="12"/>
                                                    <TextBlock Text="{Binding MapName, Mode=OneWay}"
                                                               Foreground="#4A6A80" FontSize="12"/>
                                                </StackPanel>

                                                <!-- Tags row -->
                                                <StackPanel Orientation="Horizontal">
                                                    <!-- Cluster badge (ARK only) -->
                                                    <Border Background="#0C1C30" BorderBrush="#1A3A5C"
                                                            BorderThickness="1" CornerRadius="4"
                                                            Padding="6,2" Margin="0,0,5,0"
                                                            Visibility="{Binding HasCluster, Converter={StaticResource BoolToVis}}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="⧓ " Foreground="#4A90D8" FontSize="10"/>
                                                            <TextBlock Text="{Binding ClusterBadge, Mode=OneWay}"
                                                                       Foreground="#6AACF0" FontSize="10" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <!-- Warning badge -->
                                                    <Border Background="#261A08" BorderBrush="#4A3010"
                                                            BorderThickness="1" CornerRadius="4"
                                                            Padding="6,2" Margin="0,0,5,0"
                                                            Visibility="{Binding HasWarnings, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="⚠  Issues" Foreground="#F7A840" FontSize="10" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <!-- User tags -->
                                                    <Border Background="#0E1E2E" BorderBrush="#1E3448"
                                                            BorderThickness="1" CornerRadius="4"
                                                            Padding="6,2"
                                                            Visibility="{Binding HasTags, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="{Binding Tags, Mode=OneWay}" Foreground="#5C8AAA" FontSize="10"/>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Col 2: Players -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,10,0">
                                                <TextBlock Text="PLAYERS" Style="{StaticResource LabelText}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding PlayersDisplayText, Mode=OneWay}"
                                                           Style="{StaticResource ValueText}"/>
                                                <ProgressBar Value="{Binding PlayerCount, Mode=OneWay}"
                                                             Maximum="{Binding MaxPlayers, Mode=OneWay}"
                                                             Foreground="#3DDA85"
                                                             Margin="0,6,0,0" Width="80" HorizontalAlignment="Left"/>
                                            </StackPanel>

                                            <!-- Col 3: CPU -->
                                            <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="0,0,10,0">
                                                <TextBlock Text="CPU" Style="{StaticResource LabelText}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding CpuDisplayText, Mode=OneWay}"
                                                           Style="{StaticResource ValueText}"/>
                                                <ProgressBar Value="{Binding CpuPercent, Mode=OneWay}" Maximum="100"
                                                             Foreground="#2268E0"
                                                             Margin="0,6,0,0" Width="72" HorizontalAlignment="Left"/>
                                            </StackPanel>

                                            <!-- Col 4: RAM -->
                                            <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="0,0,10,0">
                                                <TextBlock Text="MEMORY" Style="{StaticResource LabelText}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding RamDisplayText, Mode=OneWay}"
                                                           Style="{StaticResource ValueText}"/>
                                                <ProgressBar Value="{Binding RamPercent, Mode=OneWay}" Maximum="100"
                                                             Foreground="#8A55FF"
                                                             Margin="0,6,0,0" Width="80" HorizontalAlignment="Left"
                                                             Visibility="{Binding HasRamLimit, Converter={StaticResource BoolToVis}}"/>
                                            </StackPanel>

                                            <!-- Col 5: Actions -->
                                            <StackPanel Grid.Column="5" VerticalAlignment="Center">
                                                <!-- Row 1: Primary + Power dropdown -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <!-- Start (when stopped) -->
                                                    <Button Content="▶  Start"
                                                            Command="{Binding DataContext.StartCommand, ElementName=ServersViewRoot}"
                                                            CommandParameter="{Binding}"
                                                            IsEnabled="{Binding CanStart, Mode=OneWay}"
                                                            Style="{StaticResource BtnSuccess}"
                                                            Padding="14,0" Height="30" MinWidth="90"
                                                            Visibility="{Binding IsPrimaryStart, Converter={StaticResource BoolToVis}}"
                                                            ToolTip="Start this server"/>
                                                    <!-- Console (when running) -->
                                                    <Button Content=">_  Console"
                                                            Command="{Binding DataContext.ViewConsoleCommand, ElementName=ServersViewRoot}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource BtnConsole}"
                                                            Padding="14,0" Height="30" MinWidth="90"
                                                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"
                                                            ToolTip="Open console log"/>
                                                    <!-- Power dropdown arrow -->
                                                    <Button Content="▾"
                                                            Style="{StaticResource BtnPower}"
                                                            Height="30" Width="26" Margin="3,0,0,0"
                                                            Click="OnPowerMenuClick"
                                                            Tag="{Binding DataContext, ElementName=ServersViewRoot}"
                                                            ContextMenuService.Placement="Bottom"
                                                            ToolTip="Server power options">
                                                        <Button.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="▶  Start"
                                                                          Command="{Binding PlacementTarget.Tag.StartCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                                <MenuItem Header="■  Stop"
                                                                          Command="{Binding PlacementTarget.Tag.StopCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                                <MenuItem Header="↺  Restart"
                                                                          Command="{Binding PlacementTarget.Tag.RestartCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                            </ContextMenu>
                                                        </Button.ContextMenu>
                                                    </Button>
                                                </StackPanel>
                                                <!-- Row 2: Quick icon buttons + More menu -->
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="⚙"
                                                            Style="{StaticResource BtnIcon}"
                                                            Height="28" Width="28" FontSize="13"
                                                            Margin="0,0,4,0"
                                                            ToolTip="Server settings"
                                                            Command="{Binding DataContext.OpenSettingsCommand, ElementName=ServersViewRoot}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="📁"
                                                            Style="{StaticResource BtnIcon}"
                                                            Height="28" Width="28" FontSize="13"
                                                            Margin="0,0,4,0"
                                                            ToolTip="Open server files"
                                                            Command="{Binding DataContext.OpenFilesCommand, ElementName=ServersViewRoot}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="{Binding ExpandText, Mode=OneWay}"
                                                            Style="{StaticResource BtnBase}"
                                                            Height="28" Padding="8,0" FontSize="11"
                                                            Margin="0,0,4,0"
                                                            ToolTip="Expand server details"
                                                            Command="{Binding DataContext.ToggleCardCommand, ElementName=ServersViewRoot}"
                                                            CommandParameter="{Binding}"/>
                                                    <!-- More menu -->
                                                    <Button Content="⋯"
                                                            Style="{StaticResource BtnIcon}"
                                                            Height="28" Width="28" FontSize="16"
                                                            Click="OnMoreMenuClick"
                                                            Tag="{Binding DataContext, ElementName=ServersViewRoot}"
                                                            ContextMenuService.Placement="Bottom"
                                                            ToolTip="More options">
                                                        <Button.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="Edit profile"
                                                                          Command="{Binding PlacementTarget.Tag.EditCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                                <MenuItem Header="Console log"
                                                                          Command="{Binding PlacementTarget.Tag.ViewConsoleCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                                <MenuItem Header="Backup now"
                                                                          Command="{Binding PlacementTarget.Tag.BackupNowCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                                <MenuItem Header="Install / Update"
                                                                          Command="{Binding PlacementTarget.Tag.UpdateServerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                                <MenuItem Header="Open folder"
                                                                          Command="{Binding PlacementTarget.Tag.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                                <Separator Style="{StaticResource MenuSep}"/>
                                                                <MenuItem Header="More options"
                                                                          Command="{Binding PlacementTarget.Tag.MoreOptionsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                                <Separator Style="{StaticResource MenuSep}"/>
                                                                <MenuItem Header="Delete server" Foreground="#E05050"
                                                                          Command="{Binding PlacementTarget.Tag.DeleteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                            </ContextMenu>
                                                        </Button.ContextMenu>
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>

                                        <!-- ── Expandable details drawer ──────────── -->
                                        <Border Style="{StaticResource DrawerPanel}"
                                                Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="1.4*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Ports -->
                                                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                                    <TextBlock Text="PORTS" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <TextBlock Text="Game  " Foreground="#3A5468" FontSize="12"/>
                                                        <TextBlock Text="{Binding GamePortText, Mode=OneWay}" Foreground="#8AA8C0" FontSize="12"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <TextBlock Text="Query  " Foreground="#3A5468" FontSize="12"/>
                                                        <TextBlock Text="{Binding QueryPortText, Mode=OneWay}" Foreground="#8AA8C0" FontSize="12"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="RCON  " Foreground="#3A5468" FontSize="12"/>
                                                        <TextBlock Text="{Binding RconPortText, Mode=OneWay}" Foreground="#8AA8C0" FontSize="12"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- Runtime -->
                                                <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                                    <TextBlock Text="RUNTIME" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <TextBlock Text="Uptime  " Foreground="#3A5468" FontSize="12"/>
                                                        <TextBlock Text="{Binding Uptime, Mode=OneWay}" Foreground="#8AA8C0" FontSize="12"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <TextBlock Text="Started  " Foreground="#3A5468" FontSize="12"/>
                                                        <TextBlock Text="{Binding LastStarted, Mode=OneWay}" Foreground="#8AA8C0" FontSize="12"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Stopped  " Foreground="#3A5468" FontSize="12"/>
                                                        <TextBlock Text="{Binding LastStopped, Mode=OneWay}" Foreground="#8AA8C0" FontSize="12"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- Maintenance -->
                                                <StackPanel Grid.Column="2" Margin="0,0,16,0">
                                                    <TextBlock Text="MAINTENANCE" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <TextBlock Text="Backup  " Foreground="#3A5468" FontSize="12"/>
                                                        <TextBlock Text="{Binding LastBackup, Mode=OneWay}" Foreground="#8AA8C0" FontSize="12"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <TextBlock Text="Update  " Foreground="#3A5468" FontSize="12"/>
                                                        <TextBlock Text="{Binding UpdateStatus, Mode=OneWay}" Foreground="#8AA8C0" FontSize="12"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Disk  " Foreground="#3A5468" FontSize="12"/>
                                                        <TextBlock Text="{Binding DiskUsageText, Mode=OneWay}" Foreground="#8AA8C0" FontSize="12"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- Path + Warnings + quick actions -->
                                                <StackPanel Grid.Column="3">
                                                    <TextBlock Text="INSTALL PATH" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
                                                    <TextBlock Text="{Binding InstallPath, Mode=OneWay}"
                                                               Foreground="#5A7A90" FontSize="11"
                                                               TextWrapping="Wrap" Margin="0,0,0,8"/>
                                                    <ItemsControl ItemsSource="{Binding WarningBadges, Mode=OneWay}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="#1E0C0C" BorderBrush="#5A2020"
                                                                        BorderThickness="1" CornerRadius="4"
                                                                        Padding="7,3" Margin="0,0,5,5">
                                                                    <TextBlock Text="{Binding}" Foreground="#F08080" FontSize="11"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- No results state -->
                    <Border HorizontalAlignment="Center" Margin="0,40,0,0"
                            Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="No servers match your filters"
                                       Foreground="#607A90" FontSize="15" HorizontalAlignment="Center"/>
                            <Button Content="Clear filters"
                                    Command="{Binding RefreshCommand, Mode=OneWay}"
                                    Style="{StaticResource BtnBase}"
                                    HorizontalAlignment="Center" Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ═══ ROW 3 — Status bar ══════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#070E17" BorderBrush="#0E1E2E"
                BorderThickness="0,1,0,0" Padding="18,7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Message, Mode=OneWay}"
                           Foreground="#3A5468" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding FilteredServers.Count, Mode=OneWay, StringFormat={}{0} server(s) shown}"
                           Foreground="#3A5468" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>


        <!-- ═══ OVERLAY — Add Server wizard ═════════════════════════════════ -->
        <Border Grid.RowSpan="4"
                Panel.ZIndex="50"
                Background="#CC040A14"
                Visibility="{Binding IsAddServerOpen, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource OverlayPanel}"
                    Width="920" MaxWidth="980"
                    Margin="26" Padding="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding AddServer.DialogTitle, Mode=OneWay}"
                                       Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding AddServer.StepTitle, Mode=OneWay}"
                                       Foreground="#6A8BA4" FontSize="13" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="✕  Close"
                                Command="{Binding ToggleAddServerCommand, Mode=OneWay}"
                                Style="{StaticResource BtnBase}"/>
                    </Grid>

                    <Grid MinHeight="320">
                        <!-- Step 1: Game type -->
                        <StackPanel Visibility="{Binding AddServer.IsStep1, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Select Game Type" Foreground="#8AA8C0" FontSize="12" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding AddServer.Providers, Mode=OneWay}"
                                      SelectedItem="{Binding AddServer.SelectedProvider, Mode=TwoWay}"
                                      DisplayMemberPath="GameName"
                                      Style="{StaticResource FilterCombo}"
                                      Width="420" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <!-- Step 2: Profile details -->
                        <Grid Visibility="{Binding AddServer.IsStep2, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Margin="0,0,8,10">
                                <TextBlock Text="Server Name" Foreground="#6A8BA4" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding AddServer.ServerName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,10">
                                <TextBlock Text="Tags (comma-separated)" Foreground="#6A8BA4" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding AddServer.Tags, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,10">
                                <TextBlock Text="Description" Foreground="#6A8BA4" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding AddServer.Description, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Input}" Height="70"
                                         TextWrapping="Wrap" AcceptsReturn="True"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Margin="0,0,8,10">
                                <TextBlock Text="Server Path" Foreground="#6A8BA4" FontSize="12" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding AddServer.ServerPath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                    <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseServerPathCommand, Mode=OneWay}"
                                            Style="{StaticResource BtnBase}" Margin="6,0,0,0"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,10">
                                <TextBlock Text="Install Directory" Foreground="#6A8BA4" FontSize="12" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding AddServer.InstallPath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                    <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseInstallPathCommand, Mode=OneWay}"
                                            Style="{StaticResource BtnBase}" Margin="6,0,0,0"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Margin="0,0,8,0">
                                <TextBlock Text="Executable Path" Foreground="#6A8BA4" FontSize="12" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding AddServer.ExecutablePath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                    <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseExecutablePathCommand, Mode=OneWay}"
                                            Style="{StaticResource BtnBase}" Margin="6,0,0,0"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Save Directory" Foreground="#6A8BA4" FontSize="12" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding AddServer.SaveDirectory, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                    <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseSaveDirectoryCommand, Mode=OneWay}"
                                            Style="{StaticResource BtnBase}" Margin="6,0,0,0"/>
                                </Grid>
                                <TextBlock Text="Backup Directory" Foreground="#6A8BA4" FontSize="12" Margin="0,10,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding AddServer.BackupDirectory, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                    <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseBackupDirectoryCommand, Mode=OneWay}"
                                            Style="{StaticResource BtnBase}" Margin="6,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <!-- Step 3: Network -->
                        <Grid Visibility="{Binding AddServer.IsStep3, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Margin="0,0,8,10">
                                <TextBlock Text="IP Address" Foreground="#6A8BA4" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding AddServer.IpAddress, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,10">
                                <TextBlock Text="Game Port" Foreground="#6A8BA4" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding AddServer.GamePort, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="0,0,8,10">
                                <TextBlock Text="Query Port" Foreground="#6A8BA4" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding AddServer.QueryPort, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,10">
                                <TextBlock Text="RCON Port" Foreground="#6A8BA4" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding AddServer.RconPort, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.ColumnSpan="2">
                                <TextBlock Text="RCON Password" Foreground="#6A8BA4" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding AddServer.RconPassword, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Step 4: Options -->
                        <Grid Visibility="{Binding AddServer.IsStep4, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Margin="0,0,8,10">
                                <TextBlock Text="Max Players" Foreground="#6A8BA4" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding AddServer.MaxPlayers, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,10">
                                <TextBlock Text="CPU Limit (%)" Foreground="#6A8BA4" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding AddServer.CpuLimit, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,10">
                                <CheckBox Content="Auto Restart" IsChecked="{Binding AddServer.AutoRestart, Mode=TwoWay}"
                                          Foreground="#D0E4F4" Margin="0,0,0,10"/>
                                <CheckBox Content="Auto Backup" IsChecked="{Binding AddServer.AutoBackup, Mode=TwoWay}"
                                          Foreground="#D0E4F4"/>
                            </StackPanel>
                        </Grid>

                        <!-- Step 5: Review -->
                        <StackPanel Visibility="{Binding AddServer.IsStep5, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Review Configuration" Foreground="White" FontSize="14"
                                       FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <TextBox Text="{Binding AddServer.ReviewText, Mode=OneWay}"
                                     Style="{StaticResource Input}"
                                     Height="300" IsReadOnly="True"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" FontSize="12"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Content="Cancel" Command="{Binding ToggleAddServerCommand, Mode=OneWay}" Style="{StaticResource BtnBase}"/>
                        <Button Content="← Back" Command="{Binding PreviousAddServerStepCommand, Mode=OneWay}"
                                IsEnabled="{Binding AddServer.CanGoBack, Mode=OneWay}" Style="{StaticResource BtnBase}" Margin="6,0,0,0"/>
                        <Button Content="Next →" Command="{Binding NextAddServerStepCommand, Mode=OneWay}"
                                IsEnabled="{Binding AddServer.CanGoNext, Mode=OneWay}" Style="{StaticResource BtnBase}" Margin="6,0,0,0"/>
                        <Button Content="{Binding AddServer.SaveButtonText, Mode=OneWay}"
                                Command="{Binding SaveNewServerCommand, Mode=OneWay}"
                                IsEnabled="{Binding AddServer.IsReviewStep, Mode=OneWay}"
                                Style="{StaticResource BtnPrimary}" Margin="6,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- ═══ OVERLAY — Import confirmation ══════════════════════════════ -->
        <Border Grid.RowSpan="4"
                Panel.ZIndex="60"
                Background="#C4040A14"
                Visibility="{Binding IsImportConfirmationOpen, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource OverlayPanel}"
                    Width="820" MaxWidth="960"
                    Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Import Server" Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ImportModeText, Mode=OneWay}"
                               Foreground="#6A8BA4" FontSize="13" Margin="0,4,0,18"/>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Source folder" Foreground="#3A5468" FontSize="11" FontWeight="SemiBold" Margin="0,0,12,10"/>
                        <TextBlock Grid.Column="1" Text="{Binding ImportSourceFolder, Mode=OneWay}"
                                   Foreground="#8AA8C0" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="1" Text="Destination" Foreground="#3A5468" FontSize="11" FontWeight="SemiBold" Margin="0,0,12,10"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ImportDestinationDisplay, Mode=OneWay}"
                                   Foreground="#8AA8C0" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="2" Text="Server name" Foreground="#3A5468" FontSize="11" FontWeight="SemiBold" Margin="0,0,12,10"/>
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding ImportServerName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Input}" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="3" Text="Game type" Foreground="#3A5468" FontSize="11" FontWeight="SemiBold" Margin="0,0,12,10"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ImportGameName, Mode=OneWay}"
                                   Foreground="#8AA8C0" FontSize="13" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="4" Text="Folder size" Foreground="#3A5468" FontSize="11" FontWeight="SemiBold" Margin="0,0,12,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ImportEstimatedSize, Mode=OneWay}"
                                   Foreground="#8AA8C0" FontSize="13"/>
                    </Grid>

                    <Border Background="#0C1A28" BorderBrush="#1A3448" BorderThickness="1"
                            CornerRadius="6" Padding="14" Margin="0,0,0,14">
                        <StackPanel>
                            <CheckBox Content="Link existing folder instead of copying"
                                      IsChecked="{Binding LinkExistingFolder, Mode=TwoWay}"
                                      Foreground="#D0E4F4"/>
                            <TextBlock Text="Advanced option. The original folder must remain intact — moving or deleting it will break the server."
                                       Foreground="#C89048" FontSize="12" TextWrapping="Wrap" Margin="24,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Visibility="{Binding IsImportRunning, Converter={StaticResource BoolToVis}}" Margin="0,0,0,14">
                        <TextBlock Text="{Binding ImportStatus, Mode=OneWay}" Foreground="#D0E4F4"
                                   FontSize="13" FontWeight="SemiBold"/>
                        <ProgressBar Value="{Binding ImportProgress, Mode=OneWay}" Maximum="100"
                                     Height="6" Margin="0,8,0,8"/>
                        <TextBlock Text="{Binding ImportCurrentFile, Mode=OneWay}"
                                   Foreground="#6A8BA4" FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Command="{Binding CancelImportCommand, Mode=OneWay}" Style="{StaticResource BtnBase}"/>
                        <Button Content="Stop Copy"
                                Command="{Binding CancelImportCopyCommand, Mode=OneWay}"
                                Visibility="{Binding IsImportRunning, Converter={StaticResource BoolToVis}}"
                                Style="{StaticResource BtnBase}" Margin="6,0,0,0"/>
                        <Button Content="Import"
                                Command="{Binding ConfirmImportCommand, Mode=OneWay}"
                                IsEnabled="{Binding CanConfirmImport, Mode=OneWay}"
                                Style="{StaticResource BtnPrimary}" Margin="6,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- ═══ OVERLAY — Install / Update ════════════════════════════════════ -->
        <Border Grid.RowSpan="4"
                Panel.ZIndex="80"
                Background="#C4040A14"
                Visibility="{Binding IsInstallOpen, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource OverlayPanel}"
                    Width="820" MaxWidth="960"
                    Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>

                    <!-- Header -->
                    <TextBlock Text="Install / Update Server"
                               Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Foreground="#6A8BA4" FontSize="13" Margin="0,4,0,18">
                        <Run Text="{Binding InstallModeLabel, Mode=OneWay}"/>
                        <Run Text=" via SteamCMD  ·  "/>
                        <Run Text="{Binding InstallTargetGame, Mode=OneWay}"/>
                    </TextBlock>

                    <!-- Server info row -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Server" Foreground="#3A5468" FontSize="11" FontWeight="SemiBold" Margin="0,0,12,8"/>
                        <TextBlock Grid.Column="1" Text="{Binding InstallTargetName, Mode=OneWay}"
                                   Foreground="#E0EEFA" FontSize="13" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="1" Text="Install path" Foreground="#3A5468" FontSize="11" FontWeight="SemiBold" Margin="0,0,12,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding InstallTargetPath, Mode=OneWay}"
                                   Foreground="#8AA8C0" FontSize="12" TextWrapping="Wrap"/>
                    </Grid>

                    <!-- ── Confirm section ─────────────────────────────────── -->
                    <StackPanel Visibility="{Binding IsInstallConfirm, Converter={StaticResource BoolToVis}}">
                        <Border Background="#0C1A28" BorderBrush="#1A3448" BorderThickness="1"
                                CornerRadius="6" Padding="14" Margin="0,0,0,14">
                            <StackPanel>
                                <CheckBox Content="Validate files (repairs corrupt or incomplete installation)"
                                          IsChecked="{Binding InstallValidateFiles, Mode=TwoWay}"
                                          Foreground="#D0E4F4" Margin="0,0,0,10"/>
                                <CheckBox Content="Restart server automatically after a successful update"
                                          IsChecked="{Binding InstallRestartAfter, Mode=TwoWay}"
                                          Foreground="#D0E4F4"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#0B1822" BorderBrush="#1A2E3E" BorderThickness="1"
                                CornerRadius="6" Padding="12" Margin="0,0,0,18">
                            <TextBlock Foreground="#C89048" FontSize="12" TextWrapping="Wrap">
                                <Run Text="This will download "/>
                                <Run Text="{Binding InstallModeLabel, Mode=OneWay}"/>
                                <Run Text=" files from Steam. The server must not be running during this operation."/>
                            </TextBlock>
                        </Border>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel" Command="{Binding CloseInstallCommand, Mode=OneWay}" Style="{StaticResource BtnBase}"/>
                            <Button Command="{Binding StartInstallCommand, Mode=OneWay}"
                                    Style="{StaticResource BtnPrimary}" Margin="6,0,0,0">
                                <Button.Content>
                                    <TextBlock>
                                        <Run Text="⬇  "/>
                                        <Run Text="{Binding InstallModeLabel, Mode=OneWay}"/>
                                    </TextBlock>
                                </Button.Content>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- ── Progress section ────────────────────────────────── -->
                    <StackPanel Visibility="{Binding IsInstallRunning, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding InstallStage, Mode=OneWay}"
                                   Foreground="#D0E4F4" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <ProgressBar IsIndeterminate="True" Height="6" Margin="0,0,0,12"/>
                        <Border Background="#060E18" BorderBrush="#1A2E42" BorderThickness="1"
                                CornerRadius="6" Padding="12" Margin="0,0,0,16" MinHeight="48" MaxHeight="140">
                            <ScrollViewer VerticalScrollBarVisibility="Hidden">
                                <TextBlock Text="{Binding InstallCurrentLine, Mode=OneWay}"
                                           Foreground="#6A9AB8" FontFamily="Consolas" FontSize="12"
                                           TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </Border>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="⛔  Cancel" Command="{Binding CancelInstallCommand, Mode=OneWay}" Style="{StaticResource BtnBase}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- ── Result section ──────────────────────────────────── -->
                    <StackPanel Visibility="{Binding IsInstallComplete, Converter={StaticResource BoolToVis}}">
                        <Border CornerRadius="6" Padding="14" Margin="0,0,0,16">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#0B2010"/>
                                    <Setter Property="BorderBrush" Value="#1A4A28"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsInstallSuccess}" Value="False">
                                            <Setter Property="Background" Value="#200C0C"/>
                                            <Setter Property="BorderBrush" Value="#4A1A1A"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding InstallResultMessage, Mode=OneWay}"
                                       FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#3DDA85"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInstallSuccess}" Value="False">
                                                <Setter Property="Foreground" Value="#E87070"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="✕  Close" Command="{Binding CloseInstallCommand, Mode=OneWay}" Style="{StaticResource BtnBase}"/>
                            <Button Content="📋  Open Log" Command="{Binding OpenInstallLogCommand, Mode=OneWay}"
                                    Style="{StaticResource BtnBase}" Margin="6,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Border>

        <!-- ═══ OVERLAY — Console log ════════════════════════════════════════ -->
        <Border Grid.RowSpan="4"
                Panel.ZIndex="70"
                Background="#C4040A14"
                Visibility="{Binding IsConsoleOpen, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource OverlayPanel}"
                    Width="920" MaxWidth="1100" MaxHeight="660"
                    Padding="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding ConsoleTitle, Mode=OneWay}"
                                   Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="Latest server log output"
                                   Foreground="#4A6A80" FontSize="12" Margin="0,4,0,14"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button Content="↺  Refresh" Command="{Binding RefreshConsoleCommand, Mode=OneWay}"
                                Style="{StaticResource BtnBase}"/>
                        <Button Content="✕  Close" Command="{Binding CloseConsoleCommand, Mode=OneWay}"
                                Style="{StaticResource BtnBase}" Margin="6,0,0,0"/>
                    </StackPanel>

                    <TextBox Grid.Row="1" Grid.ColumnSpan="2"
                             Text="{Binding ConsoleText, Mode=OneWay}"
                             Background="#060E18" Foreground="#A8C8E8"
                             BorderBrush="#1A2E42" BorderThickness="1"
                             FontFamily="Consolas" FontSize="12"
                             IsReadOnly="True" AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"
                             Padding="10"/>
                </Grid>
            </Border>
        </Border>

    </Grid>
</UserControl>
