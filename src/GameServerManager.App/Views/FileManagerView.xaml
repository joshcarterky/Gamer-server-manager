<UserControl x:Class="GameServerManager.App.Views.FileManagerView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GameServerManager.App.ViewModels"
             Background="Transparent">

    <UserControl.Resources>

        <!-- ═══ Converters ════════════════════════════════════════════════════ -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ═══ Color palette ════════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="Surface0"      Color="#060D16"/>
        <SolidColorBrush x:Key="Surface1"      Color="#0B1726"/>
        <SolidColorBrush x:Key="Surface2"      Color="#0F1E2E"/>
        <SolidColorBrush x:Key="Surface3"      Color="#142436"/>
        <SolidColorBrush x:Key="BorderMuted"   Color="#192E42"/>
        <SolidColorBrush x:Key="BorderSubtle"  Color="#243A50"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#E0EEF8"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8BA3B8"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#4E6070"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#2268E0"/>
        <SolidColorBrush x:Key="AccentGreen"   Color="#38D983"/>
        <SolidColorBrush x:Key="AccentRed"     Color="#FF5050"/>
        <SolidColorBrush x:Key="AccentYellow"  Color="#FFB800"/>

        <!-- ═══ Flat button template ══════════════════════════════════════════ -->
        <ControlTemplate x:Key="FlatBtn" TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.32"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- ═══ Shared button styles ═════════════════════════════════════════ -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Foreground"        Value="#D0E4F4"/>
            <Setter Property="Background"        Value="#0E1E2E"/>
            <Setter Property="BorderBrush"       Value="#1C3248"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Padding"           Value="10,0"/>
            <Setter Property="Height"            Value="32"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="Template"          Value="{StaticResource FlatBtn}"/>
        </Style>

        <Style x:Key="BtnNav" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Width"             Value="32"/>
            <Setter Property="Padding"           Value="0"/>
            <Setter Property="FontSize"          Value="14"/>
            <Setter Property="FontFamily"        Value="Segoe UI Symbol"/>
        </Style>

        <Style x:Key="BtnAction" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Padding"           Value="11,0"/>
            <Setter Property="Height"            Value="32"/>
            <Setter Property="FontSize"          Value="12"/>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"        Value="#1E62E8"/>
            <Setter Property="BorderBrush"       Value="#2878FF"/>
            <Setter Property="Foreground"        Value="White"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"        Value="#2C0A0A"/>
            <Setter Property="BorderBrush"       Value="#6A1C1C"/>
            <Setter Property="Foreground"        Value="#FF7070"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
        </Style>

        <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"        Value="#0D3D20"/>
            <Setter Property="BorderBrush"       Value="#1A6038"/>
            <Setter Property="Foreground"        Value="#3DDA85"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
        </Style>

        <Style x:Key="BtnIconSm" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Width"             Value="28"/>
            <Setter Property="Height"            Value="28"/>
            <Setter Property="Padding"           Value="0"/>
            <Setter Property="FontSize"          Value="12"/>
        </Style>

        <!-- ═══ Search / Input styles ════════════════════════════════════════ -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background"             Value="#0A1624"/>
            <Setter Property="Foreground"             Value="#D0E4F4"/>
            <Setter Property="BorderBrush"            Value="#1C3248"/>
            <Setter Property="BorderThickness"        Value="1"/>
            <Setter Property="Padding"                Value="9,0,9,0"/>
            <Setter Property="Height"                 Value="32"/>
            <Setter Property="CaretBrush"             Value="#D0E4F4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="EditorBox" TargetType="TextBox">
            <Setter Property="Background"             Value="#050E1A"/>
            <Setter Property="Foreground"             Value="#C8DCF0"/>
            <Setter Property="BorderThickness"        Value="0"/>
            <Setter Property="FontFamily"             Value="Consolas, Courier New"/>
            <Setter Property="FontSize"               Value="13"/>
            <Setter Property="AcceptsReturn"          Value="True"/>
            <Setter Property="AcceptsTab"             Value="True"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalScrollBarVisibility"   Value="Auto"/>
            <Setter Property="CaretBrush"             Value="#7AA8D0"/>
            <Setter Property="Padding"                Value="12"/>
            <Setter Property="TextWrapping"           Value="NoWrap"/>
        </Style>

        <!-- ═══ ComboBox style ════════════════════════════════════════════════ -->
        <Style x:Key="ServerCombo" TargetType="ComboBox">
            <Setter Property="Background"        Value="#0A1624"/>
            <Setter Property="Foreground"        Value="#D0E4F4"/>
            <Setter Property="BorderBrush"       Value="#1C3248"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Padding"           Value="10,0"/>
            <Setter Property="Height"            Value="34"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background"  Value="#0A1624"/>
                        <Setter Property="Foreground"  Value="#D0E4F4"/>
                        <Setter Property="Padding"     Value="10,7"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="B" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter TextElement.Foreground="#D0E4F4"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="B" Property="Background" Value="#14304A"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="B" Property="Background" Value="#1E62E8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="C" Background="#0A1624" BorderBrush="#1C3248" BorderThickness="1" CornerRadius="6">
                                            <Grid>
                                                <ContentPresenter Margin="10,0,28,0"
                                                                  TextElement.Foreground="#D0E4F4"
                                                                  VerticalAlignment="Center"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                                <Path Data="M 0 0 L 4 4 L 8 0 Z" Fill="#6A85A0"
                                                      Width="8" Height="4"
                                                      HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="C" Property="BorderBrush" Value="#2D78FF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup AllowsTransparency="True" Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" PopupAnimation="Fade">
                                <Border Background="#0A1624" BorderBrush="#1C3248" BorderThickness="1" CornerRadius="6"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="300">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ ContextMenu / MenuItem styles ════════════════════════════════ -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background"    Value="#0C1828"/>
            <Setter Property="BorderBrush"   Value="#1C3248"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"       Value="0,4"/>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground"    Value="#C8DCF0"/>
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="Padding"       Value="14,7"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="MB" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="MB" Property="Background" Value="#122438"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#344C60"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuSep" TargetType="Separator">
            <Setter Property="Background"    Value="#1A2E42"/>
            <Setter Property="Height"        Value="1"/>
            <Setter Property="Margin"        Value="0,3"/>
        </Style>

        <!-- ═══ TreeView styles ═══════════════════════════════════════════════ -->
        <Style TargetType="TreeView">
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Padding"           Value="0"/>
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground"        Value="#9BB6CC"/>
            <Setter Property="Padding"           Value="4,3"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="IsExpanded"        Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected"        Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="Bd" Background="Transparent" Padding="0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Indentation -->
                                    <Rectangle Width="{Binding Level, RelativeSource={RelativeSource AncestorType=TreeViewItem}, Converter={x:Static SystemParameters.HorizontalScrollBarHeightKey}}"
                                               Grid.Column="0"/>
                                    <!-- Expander toggle -->
                                    <ToggleButton x:Name="Expander"
                                                  Grid.Column="1"
                                                  Width="16" Height="16"
                                                  Margin="2,0,2,0"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Focusable="False"
                                                  ClickMode="Press">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Grid Width="16" Height="16">
                                                    <Path x:Name="Arrow"
                                                          Data="M 4 3 L 11 8 L 4 13 Z"
                                                          Fill="#4E6A80"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Arrow" Property="Data" Value="M 3 5 L 13 5 L 8 12 Z"/>
                                                        <Setter TargetName="Arrow" Property="Fill" Value="#6A90B0"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Arrow" Property="Fill" Value="#8AAFCF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <!-- Item header -->
                                    <ContentPresenter x:Name="PART_Header"
                                                      Grid.Column="2"
                                                      ContentSource="Header"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <!-- Children -->
                            <ItemsPresenter x:Name="ItemsHost" Margin="14,0,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#122438"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0D1E30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ ScrollBar style ═══════════════════════════════════════════════ -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width"      Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#243A50" CornerRadius="4" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ ListView / GridView header ═══════════════════════════════════ -->
        <Style TargetType="ListView">
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="SelectionMode"     Value="Extended"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground"        Value="#C0D8EE"/>
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="Padding"           Value="6,5"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="#0F2030" BorderThickness="0,0,0,1">
                            <GridViewRowPresenter
                                Columns="{Binding Path=View.Columns, RelativeSource={RelativeSource AncestorType=ListView}}"
                                Content="{TemplateBinding Content}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0E2236"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#122A40"/>
                                <Setter TargetName="Bd" Property="BorderBrush"  Value="#1E4060"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColHeader" TargetType="GridViewColumnHeader">
            <Setter Property="Background"        Value="#0C1C2E"/>
            <Setter Property="Foreground"        Value="#7A98B0"/>
            <Setter Property="BorderBrush"       Value="#162638"/>
            <Setter Property="BorderThickness"   Value="0,0,1,1"/>
            <Setter Property="Padding"           Value="8,6"/>
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Breadcrumb item data template ════════════════════════════════ -->
        <DataTemplate x:Key="BreadcrumbTemplate" DataType="{x:Type vm:BreadcrumbItem}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="Sep" Text=" › " Foreground="#3A5060" FontSize="13" VerticalAlignment="Center"/>
                <Button Content="{Binding Label}"
                        Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding FullPath}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource BtnBase}">
                            <Setter Property="Foreground"       Value="#6A90B0"/>
                            <Setter Property="Background"       Value="Transparent"/>
                            <Setter Property="BorderThickness"  Value="0"/>
                            <Setter Property="Height"           Value="Auto"/>
                            <Setter Property="Padding"          Value="4,2"/>
                            <Setter Property="FontSize"         Value="12"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLast}" Value="True">
                                    <Setter Property="Foreground" Value="#C0D8EE"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Cursor"     Value="Arrow"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsLast}" Value="False">
                    <!-- separator shown for all items -->
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- ═══ Folder icon selector (simple text emoji) ══════════════════════ -->
        <!-- Used inside tree node headers and file rows -->

    </UserControl.Resources>

    <!-- ═══════════════════════════════════════════════════════════════════════
         ROOT GRID
    ════════════════════════════════════════════════════════════════════════════ -->
    <Grid Margin="14,10,14,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 0: Server selector + toolbar -->
            <RowDefinition Height="Auto"/>   <!-- 1: Breadcrumb bar -->
            <RowDefinition Height="*"/>      <!-- 2: Main content (tree + list or editor) -->
            <RowDefinition Height="Auto"/>   <!-- 3: Progress bar -->
            <RowDefinition Height="Auto"/>   <!-- 4: Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ ROW 0: Server selector + toolbar ════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#080F1A"
                BorderBrush="#162638"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10,8"
                Margin="0,0,0,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Server label + combo -->
                <TextBlock Grid.Column="0" Text="Server:" Foreground="#607A90" FontSize="12"
                           VerticalAlignment="Center" Margin="4,0,8,0"/>
                <ComboBox Grid.Column="1"
                          Style="{StaticResource ServerCombo}"
                          ItemsSource="{Binding Servers}"
                          SelectedItem="{Binding SelectedServer}"
                          DisplayMemberPath="ServerName"/>

                <!-- Nav buttons -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Style="{StaticResource BtnNav}" Content="←"
                            Command="{Binding NavigateBackCommand}" ToolTip="Back" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource BtnNav}" Content="→"
                            Command="{Binding NavigateForwardCommand}" ToolTip="Forward" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource BtnNav}" Content="↑"
                            Command="{Binding NavigateUpCommand}" ToolTip="Up one level" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource BtnNav}" Content="⌂"
                            Command="{Binding NavigateHomeCommand}" ToolTip="Home (server root)" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource BtnNav}" Content="⟳"
                            Command="{Binding RefreshCommand}" ToolTip="Refresh"/>
                </StackPanel>

                <!-- Action toolbar -->
                <StackPanel Grid.Column="5" Orientation="Horizontal">
                    <Button Style="{StaticResource BtnAction}" Content="+ Folder"
                            Command="{Binding CreateFolderCommand}" ToolTip="Create folder" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource BtnAction}" Content="+ File"
                            Command="{Binding CreateFileCommand}" ToolTip="Create text file" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource BtnAction}" Content="Upload"
                            Command="{Binding UploadCommand}" ToolTip="Upload files" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource BtnAction}" Content="↓ Download"
                            Command="{Binding DownloadCommand}" ToolTip="Download selected files" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource BtnAction}" Content="Copy"
                            Command="{Binding CopyCommand}" ToolTip="Copy selected" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource BtnAction}" Content="Cut"
                            Command="{Binding CutCommand}" ToolTip="Cut selected" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource BtnAction}" Content="Paste"
                            Command="{Binding PasteCommand}" ToolTip="Paste" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource BtnAction}" Content="Rename"
                            Command="{Binding RenameCommand}" ToolTip="Rename selected" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource BtnDanger}" Content="Delete"
                            Command="{Binding DeleteCommand}" ToolTip="Delete selected"/>
                </StackPanel>

                <!-- Editor actions (visible when editor open) -->
                <StackPanel Grid.Column="7" Orientation="Horizontal"
                            Visibility="{Binding EditorVisible, Converter={StaticResource BoolToVis}}">
                    <Button Style="{StaticResource BtnSuccess}" Content="Save"
                            Command="{Binding SaveFileCommand}" Margin="6,0,4,0"/>
                    <Button Style="{StaticResource BtnAction}" Content="Save As"
                            Command="{Binding SaveFileAsCommand}" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource BtnAction}" Content="Reload"
                            Command="{Binding ReloadFileCommand}" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource BtnDanger}" Content="✕ Close"
                            Command="{Binding CloseEditorCommand}"/>
                </StackPanel>

                <!-- Search -->
                <TextBox Grid.Column="9"
                         Style="{StaticResource SearchBox}"
                         Width="180"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <!-- Open in Explorer -->
                <Button Grid.Column="11" Style="{StaticResource BtnAction}" Content="📂 Explorer"
                        Command="{Binding OpenInExplorerCommand}" ToolTip="Open current folder in Windows Explorer"/>

            </Grid>
        </Border>

        <!-- ═══ ROW 1: Breadcrumb bar ════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="#060D18"
                BorderBrush="#142030"
                BorderThickness="1"
                CornerRadius="6"
                Padding="8,4"
                Margin="0,0,0,6"
                Visibility="{Binding HasServer, Converter={StaticResource BoolToVis}}">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                          Height="26">
                <ItemsControl ItemsSource="{Binding Breadcrumbs}"
                              ItemTemplate="{StaticResource BreadcrumbTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ═══ ROW 2: Main content ══════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <!-- Left: folder tree -->
                <ColumnDefinition Width="200" MinWidth="140" MaxWidth="340"/>
                <!-- Splitter -->
                <ColumnDefinition Width="5"/>
                <!-- Right: file list OR editor -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: Folder tree ─────────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="#070E1A"
                    BorderBrush="#142030"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="4"
                    Visibility="{Binding HasServer, Converter={StaticResource BoolToVis}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <TreeView x:Name="FolderTree"
                              ItemsSource="{Binding TreeNodes}"
                              SelectedItemChanged="OnTreeSelectionChanged"
                              TreeViewItem.Expanded="OnTreeItemExpanded">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type vm:FolderTreeNode}"
                                                      ItemsSource="{Binding Children}">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="#8AAAC0"
                                           FontSize="12"
                                           Padding="2,1"
                                           ToolTip="{Binding FullPath}"/>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </ScrollViewer>
            </Border>

            <!-- ── SPLITTER ─────────────────────────────────────────────── -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          Cursor="SizeWE"/>

            <!-- ── RIGHT: file list + optional editor ──────────────────── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{Binding EditorPanelHeight}"/>
                </Grid.RowDefinitions>

                <!-- File list panel -->
                <Border Grid.Row="0"
                        Background="#070E1A"
                        BorderBrush="#142030"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <!-- Loading overlay -->
                        <Border Background="#0A121C"
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                                CornerRadius="8"
                                Panel.ZIndex="10">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ProgressBar IsIndeterminate="True" Width="160" Height="4"
                                             Foreground="#2268E0" Background="#182840" BorderThickness="0"/>
                                <TextBlock Text="Loading…" Foreground="#607A90" FontSize="12"
                                           HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- No-server placeholder -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding IsNoServerSelected, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="📁" FontSize="48" HorizontalAlignment="Center" Opacity="0.25"/>
                            <TextBlock Text="Select a server above to browse its files."
                                       Foreground="#4E6070" FontSize="13"
                                       HorizontalAlignment="Center" Margin="0,12,0,0"/>
                        </StackPanel>

                        <!-- Empty folder -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="📂" FontSize="40" HorizontalAlignment="Center" Opacity="0.2"/>
                            <TextBlock Text="This folder is empty."
                                       Foreground="#4E6070" FontSize="13"
                                       HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        </StackPanel>

                        <!-- Rename bar -->
                        <Border Background="#0A1624"
                                BorderBrush="#1E62E8"
                                BorderThickness="0,0,0,2"
                                Padding="10,8"
                                VerticalAlignment="Bottom"
                                Panel.ZIndex="5"
                                Visibility="{Binding IsRenaming, Converter={StaticResource BoolToVis}}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="Rename: " Foreground="#607A90"
                                           VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                                <Button DockPanel.Dock="Right" Content="Cancel"
                                        Style="{StaticResource BtnAction}"
                                        Command="{Binding CancelRenameCommand}"
                                        Height="28" Padding="8,0" Margin="6,0,0,0"/>
                                <Button DockPanel.Dock="Right" Content="OK"
                                        Style="{StaticResource BtnPrimary}"
                                        Command="{Binding CommitRenameCommand}"
                                        Height="28" Padding="8,0"/>
                                <TextBox x:Name="RenameBox"
                                         Style="{StaticResource SearchBox}"
                                         Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}"
                                         Height="28"
                                         KeyDown="OnRenameKeyDown"
                                         GotFocus="OnRenameBoxFocused"/>
                            </DockPanel>
                        </Border>

                        <!-- File list -->
                        <ListView x:Name="FileList"
                                  ItemsSource="{Binding Entries}"
                                  SelectionChanged="OnFileListSelectionChanged"
                                  MouseDoubleClick="OnFileListDoubleClick"
                                  KeyDown="OnFileListKeyDown"
                                  PreviewKeyDown="OnFileListPreviewKeyDown"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  Margin="0"
                                  Visibility="{Binding HasServer, Converter={StaticResource BoolToVis}}">
                            <ListView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Open" Command="{Binding OpenEditorCommand}"/>
                                    <Separator Style="{StaticResource MenuSep}"/>
                                    <MenuItem Header="Copy"   Command="{Binding CopyCommand}"/>
                                    <MenuItem Header="Cut"    Command="{Binding CutCommand}"/>
                                    <MenuItem Header="Paste"  Command="{Binding PasteCommand}"/>
                                    <Separator Style="{StaticResource MenuSep}"/>
                                    <MenuItem Header="Rename" Command="{Binding RenameCommand}"/>
                                    <MenuItem Header="Delete" Command="{Binding DeleteCommand}"/>
                                    <Separator Style="{StaticResource MenuSep}"/>
                                    <MenuItem Header="+ New Folder"    Command="{Binding CreateFolderCommand}"/>
                                    <MenuItem Header="+ New Text File" Command="{Binding CreateFileCommand}"/>
                                    <Separator Style="{StaticResource MenuSep}"/>
                                    <MenuItem Header="Upload Files…"  Command="{Binding UploadCommand}"/>
                                    <MenuItem Header="Download…"      Command="{Binding DownloadCommand}"/>
                                    <Separator Style="{StaticResource MenuSep}"/>
                                    <MenuItem Header="Open in Explorer" Command="{Binding OpenInExplorerCommand}"/>
                                </ContextMenu>
                            </ListView.ContextMenu>
                            <ListView.View>
                                <GridView AllowsColumnReorder="False" ColumnHeaderContainerStyle="{StaticResource ColHeader}">
                                    <GridViewColumn Width="300">
                                        <GridViewColumn.Header>
                                            <Button Style="{StaticResource BtnBase}"
                                                    Content="Name ↕" Background="Transparent" BorderThickness="0"
                                                    Command="{Binding SortByNameCommand}"
                                                    Padding="0" Height="Auto" FontSize="11" Foreground="#7A98B0"/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock x:Name="Icon"
                                                               Text="📁"
                                                               FontSize="13"
                                                               Margin="0,0,6,0"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Name}"
                                                               VerticalAlignment="Center"
                                                               Foreground="#C0D8EE"/>
                                                </StackPanel>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsDirectory}" Value="False">
                                                        <Setter TargetName="Icon" Property="Text" Value="📄"/>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="90">
                                        <GridViewColumn.Header>
                                            <Button Style="{StaticResource BtnBase}"
                                                    Content="Type ↕" Background="Transparent" BorderThickness="0"
                                                    Command="{Binding SortByTypeCommand}"
                                                    Padding="0" Height="Auto" FontSize="11" Foreground="#7A98B0"/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding TypeDisplay}" Foreground="#7A98B0" FontSize="11"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="90">
                                        <GridViewColumn.Header>
                                            <Button Style="{StaticResource BtnBase}"
                                                    Content="Size ↕" Background="Transparent" BorderThickness="0"
                                                    Command="{Binding SortBySizeCommand}"
                                                    Padding="0" Height="Auto" FontSize="11" Foreground="#7A98B0"/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SizeDisplay}" Foreground="#8AAAC0" FontSize="11"
                                                           HorizontalAlignment="Right"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="145">
                                        <GridViewColumn.Header>
                                            <Button Style="{StaticResource BtnBase}"
                                                    Content="Modified ↕" Background="Transparent" BorderThickness="0"
                                                    Command="{Binding SortByModifiedCommand}"
                                                    Padding="0" Height="Auto" FontSize="11" Foreground="#7A98B0"/>
                                        </GridViewColumn.Header>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ModifiedDisplay}" Foreground="#607A90" FontSize="11"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>

                <!-- GridSplitter between file list and editor -->
                <GridSplitter Grid.Row="1"
                              Height="5"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              Background="Transparent"
                              Cursor="SizeNS"
                              Visibility="{Binding EditorVisible, Converter={StaticResource BoolToVis}}"/>

                <!-- ── Editor panel ──────────────────────────────────────── -->
                <Border Grid.Row="2"
                        Background="#050C18"
                        BorderBrush="#142030"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="{Binding EditorVisible, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Editor header bar -->
                        <Border Grid.Row="0"
                                Background="#0A1624"
                                BorderBrush="#142030"
                                BorderThickness="0,0,0,1"
                                Padding="12,6">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <TextBlock Foreground="#FFB800" Text="● Modified"
                                               FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"
                                               Visibility="{Binding IsEditorModified, Converter={StaticResource BoolToVis}}"/>
                                    <Button Style="{StaticResource BtnSuccess}" Content="Save"
                                            Command="{Binding SaveFileCommand}" Height="26" Padding="10,0" Margin="0,0,4,0"/>
                                    <Button Style="{StaticResource BtnAction}" Content="Save As"
                                            Command="{Binding SaveFileAsCommand}" Height="26" Padding="8,0" Margin="0,0,4,0"/>
                                    <Button Style="{StaticResource BtnAction}" Content="↺ Reload"
                                            Command="{Binding ReloadFileCommand}" Height="26" Padding="8,0" Margin="0,0,4,0"/>
                                    <Button Style="{StaticResource BtnBase}" Content="✕"
                                            Command="{Binding CloseEditorCommand}" Height="26" Width="28" Padding="0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="📝 " FontSize="13"/>
                                    <TextBlock Text="{Binding EditorFilePath}"
                                               Foreground="#7A9AB0"
                                               FontSize="11"
                                               FontFamily="Consolas"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- Text editor -->
                        <TextBox Grid.Row="1"
                                 x:Name="EditorTextBox"
                                 Style="{StaticResource EditorBox}"
                                 Text="{Binding EditorContent, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ═══ ROW 3: Progress bar ══════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="#070E1A"
                BorderBrush="#142030"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,6"
                Margin="0,4,0,0"
                Visibility="{Binding ProgressVisible, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding ProgressLabel}"
                           Foreground="#7A98B0" FontSize="11" Margin="0,0,0,4"/>
                <ProgressBar Grid.Row="1"
                             Value="{Binding ProgressValue}"
                             Maximum="100"
                             Height="4"
                             Background="#182840"
                             Foreground="#2268E0"
                             BorderThickness="0"/>
            </Grid>
        </Border>

        <!-- ═══ ROW 4: Status bar ════════════════════════════════════════════ -->
        <Border Grid.Row="4"
                Padding="10,5"
                Margin="0,4,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="11"
                       VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#607A90"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StatusIsError}" Value="True">
                                <Setter Property="Foreground" Value="#FF7070"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>

    </Grid>
</UserControl>
