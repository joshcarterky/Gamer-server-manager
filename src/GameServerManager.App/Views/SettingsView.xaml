<UserControl x:Class="GameServerManager.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="#B30D1724"/>
            <Setter Property="BorderBrush" Value="#26394A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

        <Style x:Key="PanelTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F4F8FC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="Body" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DCE7F3"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#91A4B7"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Background" Value="#0E1824"/>
            <Setter Property="Foreground" Value="#E8F0F8"/>
            <Setter Property="BorderBrush" Value="#2A4057"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CaretBrush" Value="#E8F0F8"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>

        <Style x:Key="ComboInput" TargetType="ComboBox">
            <Setter Property="Background" Value="#0E1824"/>
            <Setter Property="Foreground" Value="#E8F0F8"/>
            <Setter Property="TextElement.Foreground" Value="#E8F0F8"/>
            <Setter Property="BorderBrush" Value="#2A4057"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#0E1824"/>
                        <Setter Property="Foreground" Value="#E8F0F8"/>
                        <Setter Property="Padding" Value="10,7"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBorder"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter TextElement.Foreground="#E8F0F8"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#183A5B"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#1E62E8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Chrome"
                                                Background="#0E1824"
                                                BorderBrush="#2A4057"
                                                BorderThickness="1">
                                            <Grid>
                                                <ContentPresenter Margin="10,0,32,0"
                                                                  TextElement.Foreground="#E8F0F8"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentStringFormat="{TemplateBinding ContentStringFormat}"/>
                                                <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="#9BAABC"
                                                      Width="8"
                                                      Height="4"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#397BFF"/>
                                                <Setter TargetName="Chrome" Property="Background" Value="#122236"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#397BFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#0E1824"
                                            BorderBrush="#397BFF"
                                            BorderThickness="1"/>
                                    <ScrollViewer Margin="1" CanContentScroll="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Check" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E8F0F8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Foreground" Value="#EAF2FA"/>
            <Setter Property="Background" Value="#142234"/>
            <Setter Property="BorderBrush" Value="#2B4057"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="13,8"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Background" Value="#1E62E8"/>
            <Setter Property="BorderBrush" Value="#2F7BFF"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Background" Value="#421C22"/>
            <Setter Property="BorderBrush" Value="#A33A48"/>
        </Style>

        <Style x:Key="InnerCard" TargetType="Border">
            <Setter Property="Background" Value="#8A101C2A"/>
            <Setter Property="BorderBrush" Value="#2A4057"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="CategoryButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#10263D"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#1E3854"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#7BB7FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#1E62E8"/>
                    <Setter Property="BorderBrush" Value="#287DFF"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource Input}"
                     Margin="0,0,12,0"
                     VerticalContentAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="Save Changes" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}"/>
                <Button Content="Reset to Defaults" Command="{Binding ResetCommand}" Style="{StaticResource ToolbarButton}"/>
                <Button Content="Import Configuration" Command="{Binding ImportCommand}" Style="{StaticResource ToolbarButton}"/>
                <Button Content="Export Configuration" Command="{Binding ExportCommand}" Style="{StaticResource ToolbarButton}" Background="#241B45" BorderBrush="#513B83"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="205"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="315"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Panel}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="SETTINGS" Style="{StaticResource PanelTitle}"/>
                    <ItemsControl ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Name}"
                                        Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource CategoryButton}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="0,0,8,0">
                <StackPanel>
                    <Border Style="{StaticResource Panel}" Visibility="{Binding IsGeneralSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="GENERAL" Style="{StaticResource PanelTitle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="44"/>
                                    <RowDefinition Height="44"/>
                                    <RowDefinition Height="44"/>
                                    <RowDefinition Height="44"/>
                                    <RowDefinition Height="44"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Application Name" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding Settings.ApplicationName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}" Margin="0,0,14,8"/>
                                <TextBlock Grid.Column="2" Text="Time Zone" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="3" ItemsSource="{Binding TimeZoneOptions}" SelectedItem="{Binding Settings.TimeZone, Mode=TwoWay}" Style="{StaticResource ComboInput}" Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="1" Text="Language" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding LanguageOptions}" SelectedItem="{Binding Settings.Language, Mode=TwoWay}" Style="{StaticResource ComboInput}" Margin="0,0,14,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Date Format" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="1" Grid.Column="3" ItemsSource="{Binding DateFormatOptions}" SelectedItem="{Binding Settings.DateFormat, Mode=TwoWay}" Style="{StaticResource ComboInput}" Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="2" Text="Theme" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding Settings.Theme, Mode=TwoWay}" Style="{StaticResource ComboInput}" Margin="0,0,14,8"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="Startup" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="2" Grid.Column="3" ItemsSource="{Binding StartupBehaviorOptions}" SelectedItem="{Binding Settings.StartupBehavior, Mode=TwoWay}" Style="{StaticResource ComboInput}" Margin="0,0,0,8"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Panel}" Visibility="{Binding IsAppearanceSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="APPEARANCE" Style="{StaticResource PanelTitle}"/>
                            <UniformGrid Columns="2" Rows="5">
                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Theme" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding Settings.Theme, Mode=TwoWay}" Style="{StaticResource ComboInput}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Accent Color" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding AccentColorOptions}" SelectedItem="{Binding Settings.AccentColor, Mode=TwoWay}" Style="{StaticResource ComboInput}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Density" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding DensityOptions}" SelectedItem="{Binding Settings.Density, Mode=TwoWay}" Style="{StaticResource ComboInput}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Sidebar Width" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding Settings.SidebarWidth, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Corner Radius" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding Settings.CornerRadius, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Background Intensity" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding Settings.BackgroundIntensity, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                </StackPanel>
                                <StackPanel Margin="0,22,10,10">
                                    <CheckBox Content="Glass Panels" IsChecked="{Binding Settings.GlassPanels}" Style="{StaticResource Check}"/>
                                </StackPanel>
                                <StackPanel Margin="0,22,0,10">
                                    <CheckBox Content="Compact Header" IsChecked="{Binding Settings.CompactHeader}" Style="{StaticResource Check}"/>
                                </StackPanel>
                            </UniformGrid>
                            <TextBlock Text="These settings apply immediately where supported and are saved with the rest of the app configuration."
                                       Style="{StaticResource Muted}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Panel}" Visibility="{Binding IsApplicationSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="APPLICATION" Style="{StaticResource PanelTitle}"/>
                            <CheckBox Content="Auto Save Settings" IsChecked="{Binding Settings.AutoSaveSettings}" Style="{StaticResource Check}"/>
                            <TextBlock Text="Automatically save settings when changes are made." Style="{StaticResource Muted}" Margin="22,0,0,8"/>
                            <CheckBox Content="Minimize to Tray" IsChecked="{Binding Settings.MinimizeToTray}" Style="{StaticResource Check}"/>
                            <TextBlock Text="Minimize the application to the system tray instead of closing." Style="{StaticResource Muted}" Margin="22,0,0,8"/>
                            <CheckBox Content="Hardware Acceleration" IsChecked="{Binding Settings.HardwareAcceleration}" Style="{StaticResource Check}"/>
                            <TextBlock Text="Use GPU acceleration for improved rendering performance." Style="{StaticResource Muted}" Margin="22,0,0,8"/>
                            <CheckBox Content="Performance Mode" IsChecked="{Binding Settings.PerformanceMode}" Style="{StaticResource Check}"/>
                            <TextBlock Text="Optimize for performance over visual quality." Style="{StaticResource Muted}" Margin="22,0,0,14"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="260"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Logging Level" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" ItemsSource="{Binding LoggingLevelOptions}" SelectedItem="{Binding Settings.LoggingLevel, Mode=TwoWay}" Style="{StaticResource ComboInput}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Panel}" Visibility="{Binding IsServerDefaultsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="SERVER DEFAULTS" Style="{StaticResource PanelTitle}"/>
                            <UniformGrid Columns="2" Rows="3">
                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Default CPU Allocation (%)" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding Settings.DefaultCpuAllocationPercent, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Memory Mode" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                                    <TextBlock Text="Game Default / Auto" Style="{StaticResource Muted}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Default Disk Limit (GB)" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding Settings.DefaultDiskGb, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Default Backup Schedule" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding BackupScheduleOptions}" SelectedItem="{Binding Settings.DefaultBackupSchedule, Mode=TwoWay}" Style="{StaticResource ComboInput}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Default Restart Policy" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding RestartPolicyOptions}" SelectedItem="{Binding Settings.DefaultRestartPolicy, Mode=TwoWay}" Style="{StaticResource ComboInput}"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Panel}" Visibility="{Binding IsNetworkSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="NETWORK" Style="{StaticResource PanelTitle}"/>
                            <UniformGrid Columns="2" Rows="4">
                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Default IP Binding" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding Settings.DefaultIpBinding, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Port Range Start" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding Settings.PortRangeStart, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Port Range End" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding Settings.PortRangeEnd, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="SSL/TLS" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding SslTlsOptions}" SelectedItem="{Binding Settings.SslTlsMode, Mode=TwoWay}" Style="{StaticResource ComboInput}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Connection Limit" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding Settings.ConnectionLimit, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                </StackPanel>
                                <StackPanel Margin="0,23,0,10">
                                    <CheckBox Content="Reverse Proxy Enabled" IsChecked="{Binding Settings.ReverseProxyEnabled}" Style="{StaticResource Check}"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Panel}" Visibility="{Binding IsSecuritySelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="SECURITY" Style="{StaticResource PanelTitle}"/>
                            <CheckBox Content="Require Two-Factor Authentication" IsChecked="{Binding Settings.TwoFactorRequired}" Style="{StaticResource Check}"/>
                            <CheckBox Content="Audit Logging Enabled" IsChecked="{Binding Settings.AuditLoggingEnabled}" Style="{StaticResource Check}" Margin="0,5,0,14"/>
                            <UniformGrid Columns="2" Rows="3">
                                <StackPanel Margin="0,0,10,10">
                                    <TextBlock Text="Session Timeout (hours)" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding Settings.SessionTimeoutHours, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Login Protection Attempts" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding Settings.LoginProtectionAttempts, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="API Access Control" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding ApiAccessOptions}" SelectedItem="{Binding Settings.ApiAccessControl, Mode=TwoWay}" Style="{StaticResource ComboInput}"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Encryption Mode" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding EncryptionOptions}" SelectedItem="{Binding Settings.EncryptionMode, Mode=TwoWay}" Style="{StaticResource ComboInput}"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Panel}" Visibility="{Binding IsUpdatesSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Client Updates" Foreground="#F4F8FC" FontSize="20" FontWeight="SemiBold"/>
                                    <TextBlock Text="Manage application updates, release channels, downloads, and installation behavior." Style="{StaticResource Muted}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                    <Button Content="{Binding CheckForUpdatesButtonText}" Command="{Binding CheckForUpdatesCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,0,0"/>
                                    <Button Content="Open Update Logs" Command="{Binding OpenUpdateLogsCommand}" Style="{StaticResource ToolbarButton}"/>
                                    <Button Content="Open Downloads Folder" Command="{Binding OpenDownloadsFolderCommand}" Style="{StaticResource ToolbarButton}"/>
                                </StackPanel>
                            </Grid>

                            <Border Style="{StaticResource InnerCard}">
                                <StackPanel>
                                    <TextBlock Text="Update Overview" Style="{StaticResource PanelTitle}"/>
                                    <UniformGrid Columns="2">
                                        <DockPanel Margin="0,0,18,10"><TextBlock Text="Current Version" Style="{StaticResource Muted}"/><TextBlock Text="{Binding CurrentVersion}" Style="{StaticResource Body}" FontWeight="SemiBold" HorizontalAlignment="Right"/></DockPanel>
                                        <DockPanel Margin="0,0,0,10"><TextBlock Text="Latest Version" Style="{StaticResource Muted}"/><TextBlock Text="{Binding LatestVersion}" Style="{StaticResource Body}" FontWeight="SemiBold" HorizontalAlignment="Right"/></DockPanel>
                                        <DockPanel Margin="0,0,18,10"><TextBlock Text="Update Status" Style="{StaticResource Muted}"/><TextBlock Text="{Binding UpdateStateText}" Foreground="#62D4F1" FontWeight="SemiBold" HorizontalAlignment="Right"/></DockPanel>
                                        <DockPanel Margin="0,0,0,10"><TextBlock Text="Last Checked" Style="{StaticResource Muted}"/><TextBlock Text="{Binding LastCheckedText}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                                        <DockPanel Margin="0,0,18,10"><TextBlock Text="Release Date" Style="{StaticResource Muted}"/><TextBlock Text="{Binding ReleaseDateText}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                                        <DockPanel Margin="0,0,0,10"><TextBlock Text="Update Type" Style="{StaticResource Muted}"/><TextBlock Text="{Binding UpdateType}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                                        <DockPanel Margin="0,0,18,0"><TextBlock Text="Download Size" Style="{StaticResource Muted}"/><TextBlock Text="{Binding DownloadSizeText}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                                        <DockPanel><TextBlock Text="Install Mode" Style="{StaticResource Muted}"/><TextBlock Text="{Binding InstallMode}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                                    </UniformGrid>
                                    <DockPanel Margin="0,12,0,0"><TextBlock Text="Selected Release Channel" Style="{StaticResource Muted}"/><TextBlock Text="{Binding UpdateChannelText}" Style="{StaticResource Body}" FontWeight="SemiBold" HorizontalAlignment="Right"/></DockPanel>
                                    <StackPanel Visibility="{Binding ShowDownloadProgress, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,14,0,0">
                                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding DownloadProgress, Mode=OneWay}" IsIndeterminate="{Binding IsCheckingForUpdates}" Height="8" Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding DownloadDetail}" Style="{StaticResource Muted}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource InnerCard}">
                                <StackPanel>
                                    <TextBlock Text="Update Actions" Style="{StaticResource PanelTitle}"/>
                                    <TextBlock Text="{Binding UpdateStatus}" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="{Binding CheckForUpdatesButtonText}" Command="{Binding CheckForUpdatesCommand}" Style="{StaticResource PrimaryButton}" Margin="0"
                                                Visibility="{Binding ShowCheckForUpdatesAction, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <Button Content="Download Update" Command="{Binding DownloadUpdateCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                                                Visibility="{Binding ShowDownloadButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <Button Content="Cancel" Command="{Binding CancelDownloadCommand}" Style="{StaticResource ToolbarButton}" Margin="0,0,8,0"
                                                Visibility="{Binding ShowCancelButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <Button Content="Install Update" Command="{Binding InstallUpdateCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                                                Visibility="{Binding ShowInstallButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <Button Content="View Release" Command="{Binding ViewReleaseCommand}" Style="{StaticResource ToolbarButton}"
                                                Visibility="{Binding ShowReleaseAction, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <Button Content="Open Download Folder" Command="{Binding OpenDownloadsFolderCommand}" Style="{StaticResource ToolbarButton}"
                                                Visibility="{Binding ShowInstallButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </StackPanel>
                                    <Border Background="#0F2A1A" BorderBrush="#2ECC71" BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,12,0,0"
                                            Visibility="{Binding ShowReadyToInstall, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="Update package downloaded and ready. Installation will ask before closing or restarting the application." Foreground="#62F19F" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap"/>
                                    </Border>
                                    <Border Background="#2A0F0F" BorderBrush="#CC3333" BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,12,0,0"
                                            Visibility="{Binding ShowNoInstallerMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="Update found, but no compatible Windows installer or portable package is attached. Open the GitHub release to download manually." Foreground="#F16262" FontSize="12" TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource InnerCard}">
                                <StackPanel>
                                    <TextBlock Text="Automatic Update Settings" Style="{StaticResource PanelTitle}"/>
                                    <UniformGrid Columns="2">
                                        <CheckBox Content="Automatically check for updates" IsChecked="{Binding Settings.AutomaticallyCheckForUpdates}" Style="{StaticResource Check}"/>
                                        <CheckBox Content="Ask before downloading" IsChecked="{Binding Settings.AskBeforeDownloadingUpdates}" Style="{StaticResource Check}"/>
                                        <CheckBox Content="Automatically download updates" IsChecked="{Binding Settings.AutomaticallyDownloadUpdates}" Style="{StaticResource Check}"/>
                                        <CheckBox Content="Ask before installing" IsChecked="{Binding Settings.AskBeforeInstallingUpdates}" Style="{StaticResource Check}"/>
                                        <CheckBox Content="Include prerelease versions" IsChecked="{Binding Settings.IncludeBetaUpdates}" Style="{StaticResource Check}"/>
                                        <CheckBox Content="Notify when an update is available" IsChecked="{Binding Settings.NotifyWhenUpdateAvailable}" Style="{StaticResource Check}"/>
                                        <CheckBox Content="Download updates in the background" IsChecked="{Binding Settings.DownloadUpdatesInBackground}" IsEnabled="{Binding CanUseBackgroundDownload}" Style="{StaticResource Check}"/>
                                        <CheckBox Content="Open release notes after updating" IsChecked="{Binding Settings.OpenReleaseNotesAfterUpdate}" Style="{StaticResource Check}"/>
                                    </UniformGrid>
                                    <DockPanel Margin="0,12,0,0">
                                        <TextBlock Text="Check Frequency" Style="{StaticResource Body}" Width="160" VerticalAlignment="Center"/>
                                        <ComboBox ItemsSource="{Binding UpdateFrequencyOptions}" SelectedItem="{Binding Settings.UpdateCheckFrequency, Mode=TwoWay}" IsEnabled="{Binding CanUseUpdateFrequency}" Style="{StaticResource ComboInput}"/>
                                    </DockPanel>
                                    <TextBlock Text="Prerelease updates can be less stable and may contain unfinished changes." Foreground="#F3B45D" FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"
                                               Visibility="{Binding ShowPrereleaseWarning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource InnerCard}">
                                <StackPanel>
                                    <TextBlock Text="Release Channel" Style="{StaticResource PanelTitle}"/>
                                    <ComboBox ItemsSource="{Binding UpdateChannelOptions}" SelectedItem="{Binding Settings.UpdateChannel, Mode=TwoWay}" Style="{StaticResource ComboInput}" Width="220" HorizontalAlignment="Left"/>
                                    <TextBlock Text="Stable is recommended for normal use. Beta includes prerelease GitHub releases when available." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource InnerCard}">
                                <StackPanel>
                                    <TextBlock Text="Release Information" Style="{StaticResource PanelTitle}"/>
                                    <UniformGrid Columns="2">
                                        <DockPanel Margin="0,0,18,8"><TextBlock Text="Release Version" Style="{StaticResource Muted}"/><TextBlock Text="{Binding LatestVersion}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                                        <DockPanel Margin="0,0,0,8"><TextBlock Text="Release Title" Style="{StaticResource Muted}"/><TextBlock Text="{Binding ReleaseTitle}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                                        <DockPanel Margin="0,0,18,8"><TextBlock Text="Release Type" Style="{StaticResource Muted}"/><TextBlock Text="{Binding UpdateChannelText}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                                        <DockPanel Margin="0,0,0,8"><TextBlock Text="Published By" Style="{StaticResource Muted}"/><TextBlock Text="{Binding ReleasePublisher}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                                    </UniformGrid>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,10">
                                        <Button Content="View Release" Command="{Binding ViewReleaseCommand}" Style="{StaticResource ToolbarButton}" Margin="0"/>
                                        <Button Content="Copy Release Link" Command="{Binding CopyReleaseLinkCommand}" Style="{StaticResource ToolbarButton}"/>
                                    </StackPanel>
                                    <TextBox Text="{Binding ReleaseNotes, Mode=OneWay}" Style="{StaticResource Input}" MinHeight="170" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource InnerCard}">
                                <StackPanel>
                                    <TextBlock Text="Update History" Style="{StaticResource PanelTitle}"/>
                                    <TextBox Text="{Binding UpdateHistoryText, Mode=OneWay}" Style="{StaticResource Input}" MinHeight="95" MaxHeight="150" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Button Content="Open Logs" Command="{Binding OpenUpdateLogsCommand}" Style="{StaticResource ToolbarButton}" Margin="0"/>
                                        <Button Content="Clear History" Command="{Binding ClearUpdateHistoryCommand}" Style="{StaticResource DangerButton}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource InnerCard}">
                                <StackPanel>
                                    <TextBlock Text="Advanced Update Source" Style="{StaticResource PanelTitle}"/>
                                    <UniformGrid Columns="2">
                                        <StackPanel Margin="0,0,12,10"><TextBlock Text="GitHub Owner" Style="{StaticResource Body}" Margin="0,0,0,6"/><TextBox Text="{Binding Settings.GitHubOwner, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/></StackPanel>
                                        <StackPanel Margin="0,0,0,10"><TextBlock Text="GitHub Repository" Style="{StaticResource Body}" Margin="0,0,0,6"/><TextBox Text="{Binding Settings.GitHubRepository, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/></StackPanel>
                                        <DockPanel Margin="0,0,12,8"><TextBlock Text="Repository URL" Style="{StaticResource Muted}"/><TextBlock Text="{Binding RepositoryUrl}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                                        <DockPanel Margin="0,0,0,8"><TextBlock Text="Asset Pattern" Style="{StaticResource Muted}"/><TextBlock Text="{Binding ReleaseAssetPattern}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                                        <DockPanel Margin="0,0,12,8"><TextBlock Text="Package Type" Style="{StaticResource Muted}"/><TextBlock Text="{Binding InstallerPackageType}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                                        <DockPanel Margin="0,0,0,8"><TextBlock Text="Architecture" Style="{StaticResource Muted}"/><TextBlock Text="{Binding ArchitectureText}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                                    </UniformGrid>
                                    <DockPanel Margin="0,0,0,10"><TextBlock Text="Download Folder" Style="{StaticResource Muted}"/><TextBlock Text="{Binding DownloadsFolder}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                                    <TextBlock Text="{Binding RepositoryValidationText}" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Validate Repository" Command="{Binding ValidateRepositoryCommand}" Style="{StaticResource ToolbarButton}" Margin="0"/>
                                        <Button Content="Open Repository" Command="{Binding OpenRepositoryCommand}" Style="{StaticResource ToolbarButton}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Panel}" Visibility="{Binding IsIntegrationsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="INTEGRATIONS" Style="{StaticResource PanelTitle}"/>

                            <TextBlock Text="CurseForge" Style="{StaticResource Body}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <CheckBox Content="Enable CurseForge mod lookup" IsChecked="{Binding Settings.CurseForgeEnabled}" Style="{StaticResource Check}"/>
                            <TextBlock Text="When enabled, pasting a CurseForge URL into the mod manager triggers an automatic mod lookup (API key required for numeric ID resolution)."
                                       Style="{StaticResource Muted}" Margin="22,2,0,12" TextWrapping="Wrap"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="API Key" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Settings.CurseForgeApiKey, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Input}" Margin="0,0,8,0"/>
                                <Button Grid.Row="0" Grid.Column="2" Content="Test" Command="{Binding TestCurseForgeCommand}"
                                        Style="{StaticResource ToolbarButton}" Margin="0" VerticalAlignment="Bottom"/>

                                <TextBlock Grid.Row="1" Grid.ColumnSpan="3" Text="Get a free API key at console.curseforge.com — required for auto-resolving mod IDs from URLs."
                                           Style="{StaticResource Muted}" Margin="160,4,0,0" TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="3" Text="ARK ASA Game ID" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Settings.CurseForgeGameId, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Input}" Margin="0"/>

                                <TextBlock Grid.Row="4" Grid.ColumnSpan="3" Text="CurseForge's internal numeric game ID for ARK: Survival Ascended. Query GET /v1/games with your API key to find it."
                                           Style="{StaticResource Muted}" Margin="160,4,0,0" TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="6" Text="Timeout (seconds)" Style="{StaticResource Body}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Settings.CurseForgeTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Input}" Margin="0"/>
                            </Grid>

                            <TextBlock Text="{Binding IntegrationsStatus}" Style="{StaticResource Muted}" Margin="0,10,0,0" TextWrapping="Wrap"
                                       Visibility="{Binding HasIntegrationsStatus, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Panel}" Visibility="{Binding IsAdvancedSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Advanced" Foreground="#F4F8FC" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="Diagnostics, logging, maintenance, and troubleshooting tools for the application." Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,14"/>

                            <Border Style="{StaticResource InnerCard}">
                                <StackPanel>
                                    <TextBlock Text="Diagnostics" Style="{StaticResource PanelTitle}"/>
                                    <TextBlock Text="Diagnostic reports automatically mask passwords, API keys, RCON credentials, tokens, and other secrets before export."
                                               Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                    <WrapPanel>
                                        <Button Content="Export Diagnostic Report" Command="{Binding ExportDiagnosticsCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,6,8"/>
                                        <Button Content="Copy GitHub Issue Template" Command="{Binding CopyIssueTemplateCommand}" Style="{StaticResource ToolbarButton}" Margin="0,0,6,8"/>
                                        <Button Content="Open Application Logs" Command="{Binding OpenApplicationLogsCommand}" Style="{StaticResource ToolbarButton}" Margin="0,0,6,8"/>
                                        <Button Content="Open Crash Reports Folder" Command="{Binding OpenCrashReportsCommand}" Style="{StaticResource ToolbarButton}" Margin="0,0,6,8"/>
                                        <Button Content="Open Configuration Folder" Command="{Binding OpenConfigurationFolderCommand}" Style="{StaticResource ToolbarButton}" Margin="0,0,6,8"/>
                                        <Button Content="Open Application Data Folder" Command="{Binding OpenApplicationDataCommand}" Style="{StaticResource ToolbarButton}" Margin="0,0,6,8"/>
                                    </WrapPanel>
                                    <TextBlock Text="{Binding DiagnosticsStatus}" Style="{StaticResource Muted}" TextWrapping="Wrap"
                                               Visibility="{Binding HasDiagnosticsStatus, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource InnerCard}">
                                <StackPanel>
                                    <TextBlock Text="Logging" Style="{StaticResource PanelTitle}"/>
                                    <UniformGrid Columns="2">
                                        <StackPanel Margin="0,0,12,10">
                                            <TextBlock Text="Log Level" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                                            <ComboBox ItemsSource="{Binding LoggingLevelOptions}" SelectedItem="{Binding Settings.LoggingLevel, Mode=TwoWay}" Style="{StaticResource ComboInput}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="Maximum Log Retention" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                                            <TextBox Text="{Binding Settings.MaximumLogRetentionDays, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                        </StackPanel>
                                        <CheckBox Content="Enable verbose startup logging" IsChecked="{Binding Settings.VerboseStartupLogging}" Style="{StaticResource Check}"/>
                                        <CheckBox Content="Enable service diagnostics" IsChecked="{Binding Settings.ServiceDiagnosticsEnabled}" Style="{StaticResource Check}"/>
                                        <StackPanel Margin="0,0,12,10">
                                            <TextBlock Text="Maximum Log File Size (MB)" Style="{StaticResource Body}" Margin="0,0,0,6"/>
                                            <TextBox Text="{Binding Settings.MaximumLogFileSizeMb, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                        </StackPanel>
                                        <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,10">
                                            <Button Content="Clear Old Logs" Command="{Binding ClearOldLogsCommand}" Style="{StaticResource DangerButton}" HorizontalAlignment="Left" Margin="0"/>
                                        </StackPanel>
                                    </UniformGrid>
                                    <TextBlock Text="Debug and Trace logging may create large log files." Foreground="#F3B45D" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource InnerCard}">
                                <StackPanel>
                                    <TextBlock Text="Troubleshooting" Style="{StaticResource PanelTitle}"/>
                                    <WrapPanel>
                                        <Button Content="Clear Temporary Files" Command="{Binding ClearTemporaryFilesCommand}" Style="{StaticResource DangerButton}" Margin="0,0,6,8"/>
                                        <Button Content="Clear UI Cache" Command="{Binding ClearUiCacheCommand}" Style="{StaticResource DangerButton}" Margin="0,0,6,8"/>
                                        <Button Content="Rebuild Local Indexes" Command="{Binding RebuildIndexesCommand}" Style="{StaticResource ToolbarButton}" Margin="0,0,6,8"/>
                                        <Button Content="Validate Configuration" Command="{Binding ValidateConfigurationCommand}" Style="{StaticResource ToolbarButton}" Margin="0,0,6,8"/>
                                        <Button Content="Repair Settings File" Command="{Binding RepairSettingsFileCommand}" Style="{StaticResource ToolbarButton}" Margin="0,0,6,8"/>
                                        <Button Content="Reset Window Layout" Command="{Binding ResetWindowLayoutCommand}" Style="{StaticResource DangerButton}" Margin="0,0,6,8"/>
                                        <Button Content="Restart Application" Command="{Binding RestartApplicationCommand}" Style="{StaticResource ToolbarButton}" Margin="0,0,6,8"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource InnerCard}">
                                <StackPanel>
                                    <TextBlock Text="About" Style="{StaticResource PanelTitle}"/>
                                    <UniformGrid Columns="2">
                                        <DockPanel Margin="0,0,18,8"><TextBlock Text="Application Version" Style="{StaticResource Muted}"/><TextBlock Text="{Binding CurrentVersion}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                                        <DockPanel Margin="0,0,0,8"><TextBlock Text="Build Number" Style="{StaticResource Muted}"/><TextBlock Text="{Binding BuildNumber}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                                        <DockPanel Margin="0,0,18,8"><TextBlock Text="Build Date" Style="{StaticResource Muted}"/><TextBlock Text="{Binding BuildDateText}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                                        <DockPanel Margin="0,0,0,8"><TextBlock Text="Installation Type" Style="{StaticResource Muted}"/><TextBlock Text="{Binding InstallMode}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                                        <DockPanel Margin="0,0,18,8"><TextBlock Text="Application Data Location" Style="{StaticResource Muted}"/><TextBlock Text="{Binding ApplicationDataLocation}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                                        <DockPanel Margin="0,0,0,8"><TextBlock Text="GitHub Repository" Style="{StaticResource Muted}"/><TextBlock Text="{Binding RepositoryUrl}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                                        <DockPanel Margin="0,0,18,0"><TextBlock Text="License" Style="{StaticResource Muted}"/><TextBlock Text="See LICENSE" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                                    </UniformGrid>
                                    <Button Content="Copy Version Information" Command="{Binding CopyVersionInformationCommand}" Style="{StaticResource ToolbarButton}" HorizontalAlignment="Left" Margin="0,12,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Panel}" Visibility="{Binding IsComingSoonSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedCategory.Name}" Style="{StaticResource PanelTitle}"/>
                            <TextBlock Text="This category is wired into navigation and ready for real settings." Style="{StaticResource Body}"/>
                            <TextBlock Text="Specific controls can be added here without changing the settings storage system." Style="{StaticResource Muted}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource Panel}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="CONFIGURATION SUMMARY" Style="{StaticResource PanelTitle}"/>
                            <DockPanel Margin="0,4"><TextBlock Text="Total Categories" Style="{StaticResource Body}"/><TextBlock Text="{Binding TotalCategories}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                            <DockPanel Margin="0,4"><TextBlock Text="Total Settings" Style="{StaticResource Body}"/><TextBlock Text="{Binding TotalSettings}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                            <DockPanel Margin="0,4"><TextBlock Text="Last Modified" Style="{StaticResource Body}"/><TextBlock Text="{Binding LastModifiedText}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                            <DockPanel Margin="0,4"><TextBlock Text="Configuration Version" Style="{StaticResource Body}"/><TextBlock Text="{Binding VersionText}" Style="{StaticResource Body}" HorizontalAlignment="Right"/></DockPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Panel}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="VALIDATION STATUS" Style="{StaticResource PanelTitle}"/>
                            <TextBlock Text="Configuration is valid" Foreground="#62F19F" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Text="Current settings can be saved and exported." Style="{StaticResource Muted}" Margin="0,3,0,10"/>
                            <TextBlock Text="Syntax Check                                      Passed" Foreground="#62F19F" FontSize="12" Margin="0,4"/>
                            <TextBlock Text="Settings Folder                                  Ready" Foreground="#62F19F" FontSize="12" Margin="0,4"/>
                            <TextBlock Text="JSON Persistence                                 Enabled" Foreground="#62F19F" FontSize="12" Margin="0,4"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Panel}">
                        <StackPanel>
                            <TextBlock Text="STATUS" Style="{StaticResource PanelTitle}"/>
                            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource Muted}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
