<UserControl x:Class="GameServerManager.App.Views.SchedulerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="SchedBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#243A50"/>
            <Setter Property="BorderBrush" Value="#4B6F8A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D89B7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A8B7C8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1A2C3E"/>
            <Setter Property="BorderBrush" Value="#3A5468"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="FormCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1A2C3E"/>
            <Setter Property="BorderBrush" Value="#3A5468"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7A95AA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CellText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD9E8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="18">

            <!-- ═══ PAGE HEADER ═══ -->
            <TextBlock Text="Scheduler" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>

            <!-- ═══ ADD TASK FORM ═══ -->
            <Border Background="#96203147" BorderBrush="#48647D" BorderThickness="1"
                    CornerRadius="8" Padding="18" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Add Scheduled Task" Foreground="White" FontSize="14"
                               FontWeight="SemiBold" Margin="0,0,0,14"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Server -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Server" Style="{StaticResource FormLabel}"/>
                            <ComboBox Style="{StaticResource FormCombo}"
                                      ItemsSource="{Binding ServerNames}"
                                      SelectedItem="{Binding SelectedServerName, Mode=TwoWay}"/>
                        </StackPanel>

                        <!-- Task Type -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Task Type" Style="{StaticResource FormLabel}"/>
                            <ComboBox Style="{StaticResource FormCombo}"
                                      ItemsSource="{Binding TaskTypes}"
                                      SelectedIndex="{Binding SelectedTaskTypeIndex, Mode=TwoWay}"/>
                        </StackPanel>

                        <!-- Schedule Type -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Schedule" Style="{StaticResource FormLabel}"/>
                            <ComboBox Style="{StaticResource FormCombo}"
                                      ItemsSource="{Binding ScheduleTypes}"
                                      SelectedIndex="{Binding SelectedScheduleTypeIndex, Mode=TwoWay}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Daily time or interval -->
                        <StackPanel Grid.Column="0" Visibility="{Binding ShowDailyTime, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Time (HH:mm)" Style="{StaticResource FormLabel}"/>
                            <TextBox Style="{StaticResource FormInput}" Text="{Binding DailyTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="0" Visibility="{Binding ShowInterval, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Interval (minutes)" Style="{StaticResource FormLabel}"/>
                            <TextBox Style="{StaticResource FormInput}" Text="{Binding IntervalMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Parameter (broadcast/RCON) -->
                        <StackPanel Grid.Column="2" Visibility="{Binding ShowParameter, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding ParameterLabel}" Style="{StaticResource FormLabel}"/>
                            <TextBox Style="{StaticResource FormInput}" Text="{Binding Parameter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Warn minutes (restart only) -->
                        <StackPanel Grid.Column="4" Visibility="{Binding ShowWarnMinutes, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Pre-warn (minutes, 0=none)" Style="{StaticResource FormLabel}"/>
                            <TextBox Style="{StaticResource FormInput}" Text="{Binding WarnMinutesBefore, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                        <Button Content="Add Task" Style="{StaticResource SchedBtn}"
                                Command="{Binding AddTaskCommand}"
                                Background="#1B5D9A" BorderBrush="#2F84D8"/>
                    </StackPanel>

                    <!-- Status message -->
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#4AA8FF" FontSize="12"
                               Margin="0,10,0,0"
                               Visibility="{Binding HasStatusMessage, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </Border>

            <!-- ═══ TASKS TABLE ═══ -->
            <Border Background="#96203147" BorderBrush="#48647D" BorderThickness="1" CornerRadius="8" Padding="18">
                <StackPanel>
                    <TextBlock Text="Scheduled Tasks" Foreground="White" FontSize="14"
                               FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <!-- Table header -->
                    <Border Background="#40162030" BorderBrush="#2A3F52" BorderThickness="0,0,0,1" Padding="0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource ColHeader}" Text="SERVER"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource ColHeader}" Text="TYPE"/>
                            <TextBlock Grid.Column="2" Style="{StaticResource ColHeader}" Text="SCHEDULE"/>
                            <TextBlock Grid.Column="3" Style="{StaticResource ColHeader}" Text="PARAMETER"/>
                            <TextBlock Grid.Column="4" Style="{StaticResource ColHeader}" Text="NEXT RUN"/>
                            <TextBlock Grid.Column="5" Style="{StaticResource ColHeader}" Text="STATUS"/>
                            <TextBlock Grid.Column="6" Style="{StaticResource ColHeader}" Text="ACTIONS"/>
                        </Grid>
                    </Border>

                    <!-- Empty state -->
                    <Border Padding="16" Visibility="{Binding HasNoTasks, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="No scheduled tasks. Use the form above to add one."
                                   Foreground="#556070" FontSize="13"/>
                    </Border>

                    <!-- Task rows -->
                    <ItemsControl ItemsSource="{Binding Tasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#1E3040" BorderThickness="0,0,0,1" Padding="0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding ServerName}" Style="{StaticResource CellText}" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TypeText}" Style="{StaticResource CellText}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ScheduleText}" Style="{StaticResource CellText}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding ParameterText}" Style="{StaticResource CellText}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="4" Text="{Binding NextRunText}" Style="{StaticResource CellText}"/>
                                        <TextBlock Grid.Column="5" Text="{Binding EnabledText}"
                                                   Foreground="{Binding EnabledColor}" FontSize="12" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="6" Orientation="Horizontal">
                                            <Button Content="Toggle" Style="{StaticResource SchedBtn}"
                                                    Padding="8,4" Margin="0,0,4,0"
                                                    Command="{Binding DataContext.ToggleEnabledCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Delete" Style="{StaticResource SchedBtn}"
                                                    Padding="8,4" Background="#3D1A1A" BorderBrush="#6E3232"
                                                    Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
