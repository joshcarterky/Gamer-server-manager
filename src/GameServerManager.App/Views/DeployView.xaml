<UserControl x:Class="GameServerManager.App.Views.DeployView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GameServerManager.App.ViewModels"
             Background="Transparent">

    <UserControl.Resources>

        <!-- ═══ Converters ════════════════════════════════════════════════════ -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ═══ Color palette ════════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="BorderMuted"   Color="#192E42"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8BA3B8"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#4E6070"/>

        <!-- ═══ Flat button template ══════════════════════════════════════════ -->
        <ControlTemplate x:Key="FlatBtn" TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.32"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- ═══ Button styles ════════════════════════════════════════════════ -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Foreground"      Value="#D0E4F4"/>
            <Setter Property="Background"      Value="#0E1E2E"/>
            <Setter Property="BorderBrush"     Value="#1C3248"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Template"        Value="{StaticResource FlatBtn}"/>
        </Style>

        <Style x:Key="BtnNav" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Width"    Value="32"/>
            <Setter Property="Padding"  Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI Symbol"/>
        </Style>

        <Style x:Key="BtnAction" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Padding" Value="11,0"/>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="#1E62E8"/>
            <Setter Property="BorderBrush" Value="#2878FF"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="#2C0A0A"/>
            <Setter Property="BorderBrush" Value="#6A1C1C"/>
            <Setter Property="Foreground"  Value="#FF7070"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
        </Style>

        <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="#0D3D20"/>
            <Setter Property="BorderBrush" Value="#1A6038"/>
            <Setter Property="Foreground"  Value="#3DDA85"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
        </Style>

        <!-- ═══ Input / ComboBox styles ══════════════════════════════════════ -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background"               Value="#0A1624"/>
            <Setter Property="Foreground"               Value="#D0E4F4"/>
            <Setter Property="BorderBrush"              Value="#1C3248"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Padding"                  Value="9,0"/>
            <Setter Property="Height"                   Value="30"/>
            <Setter Property="CaretBrush"               Value="#D0E4F4"/>
            <Setter Property="VerticalContentAlignment"  Value="Center"/>
            <Setter Property="FontSize"                 Value="12"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7090A8"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,10,0,3"/>
        </Style>

        <Style x:Key="ProviderCombo" TargetType="ComboBox">
            <Setter Property="Background"      Value="#0A1624"/>
            <Setter Property="Foreground"      Value="#D0E4F4"/>
            <Setter Property="BorderBrush"     Value="#1C3248"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="9,0"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#0A1624"/>
                        <Setter Property="Foreground" Value="#D0E4F4"/>
                        <Setter Property="Padding"    Value="9,6"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="B" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter TextElement.Foreground="#D0E4F4"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="B" Property="Background" Value="#14304A"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="B" Property="Background" Value="#1E62E8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"/>
                            <DockPanel Margin="9,0,6,0">
                                <TextBlock DockPanel.Dock="Right" Text="⌄"
                                           Foreground="#7090A8" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  VerticalAlignment="Center"
                                                  TextElement.Foreground="#D0E4F4"/>
                            </DockPanel>
                            <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Placement="Bottom"
                                   MinWidth="{TemplateBinding ActualWidth}">
                                <Border Background="#0A1624" BorderBrush="#243A50"
                                        BorderThickness="1" CornerRadius="5" MaxHeight="260">
                                    <ScrollViewer><ItemsPresenter/></ScrollViewer>
                                </Border>
                            </Popup>
                            <ToggleButton IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="Transparent" BorderThickness="0" Opacity="0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Server list item template ════════════════════════════════════ -->
        <DataTemplate x:Key="ServerListItem" DataType="{x:Type vm:DeployServerItem}">
            <Border Padding="10,8" Background="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding DisplayName}"
                                   Foreground="#D0E4F4" FontSize="12" FontWeight="Medium"/>
                        <TextBlock Text="{Binding GameName}"
                                   Foreground="#5A7890" FontSize="11" Margin="0,1,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" CornerRadius="3" Padding="5,2"
                            VerticalAlignment="Center">
                        <Border.Background>
                            <SolidColorBrush Color="{Binding StatusColor}"/>
                        </Border.Background>
                        <Border.Opacity>0.18</Border.Opacity>
                    </Border>
                    <TextBlock Grid.Column="1" Text="{Binding StatusLabel}"
                               Foreground="{Binding StatusColor}"
                               FontSize="10" VerticalAlignment="Center"
                               Padding="5,2"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ═══ Install log line template ════════════════════════════════════ -->
        <DataTemplate x:Key="LogLineTemplate">
            <TextBlock Text="{Binding}"
                       Foreground="#7DAAC4"
                       FontFamily="Consolas, Courier New"
                       FontSize="11"
                       Padding="12,1"
                       TextWrapping="Wrap"/>
        </DataTemplate>

    </UserControl.Resources>

    <!-- ═══ Root ══════════════════════════════════════════════════════════════ -->
    <Grid Margin="14,10,14,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Main content -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ Row 0 — Header ══════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Style="{StaticResource BtnPrimary}"
                    Content="＋ New Profile" Command="{Binding AddNewCommand}"
                    Height="32" Padding="12,0"/>

            <Button Grid.Column="2" Style="{StaticResource BtnNav}" Content="⟳"
                    ToolTip="Refresh server list" Command="{Binding RefreshCommand}"/>
        </Grid>

        <!-- ═══ Row 1 — Main content (list | panel) ═════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="264" MinWidth="180"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left: server list ───────────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="#0A1624" BorderBrush="{StaticResource BorderMuted}"
                    BorderThickness="1" CornerRadius="6">
                <Grid>
                    <!-- Empty list placeholder -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="16">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Servers.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="No server profiles yet."
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                        <TextBlock Text="Click '＋ New Profile' to get started."
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                    </StackPanel>

                    <ListBox x:Name="ServerList"
                             ItemsSource="{Binding Servers}"
                             SelectedItem="{Binding SelectedServer, Mode=TwoWay}"
                             ItemTemplate="{StaticResource ServerListItem}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="Transparent">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#0D2438"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#0F2D48"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"/>

            <!-- ── Right: context panel ────────────────────────────────────── -->
            <Grid Grid.Column="2">

                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding ShowEmpty, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="⊡" FontSize="40" Foreground="#1A3248"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Select a server profile to install or update it,"
                               Foreground="{StaticResource TextMuted}" FontSize="13"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="or click '＋ New Profile' to set up a new server."
                               Foreground="{StaticResource TextMuted}" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- ── Server info panel ──────────────────────────────────── -->
                <ScrollViewer Visibility="{Binding ShowServerInfo, Converter={StaticResource BoolToVis}}"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="2,0,2,0">

                        <!-- Info card -->
                        <Border Background="#0B1828" BorderBrush="{StaticResource BorderMuted}"
                                BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Name + status badge -->
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{Binding SelectedServer.Profile.ProfileName}"
                                           Foreground="#E0EEF8" FontSize="16" FontWeight="SemiBold"/>
                                <Border Grid.Row="0" Grid.Column="1"
                                        CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding SelectedServer.StatusColor}"/>
                                    </Border.Background>
                                    <Border.Opacity>0.15</Border.Opacity>
                                </Border>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding SelectedServer.StatusLabel}"
                                           Foreground="{Binding SelectedServer.StatusColor}"
                                           FontSize="11" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Padding="8,3"/>

                                <!-- Game -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="{Binding SelectedServer.GameName}"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="12" Margin="0,2,0,12"/>

                                <!-- Install path -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                           Style="{StaticResource FieldLabel}" Text="INSTALL PATH" Margin="0,0,0,3"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="{Binding SelectedServer.Profile.InstallPath}"
                                           Foreground="#8BA3B8" FontSize="11"
                                           FontFamily="Consolas, Courier New"
                                           TextWrapping="Wrap"/>

                                <!-- Ports -->
                                <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                                           Foreground="{StaticResource TextMuted}" FontSize="11"
                                           Margin="0,8,0,0">
                                    <Run Text="Ports: "/>
                                    <Run Text="{Binding SelectedServer.Profile.Ports.Count, StringFormat='{}{0} configured'}"
                                         Foreground="#8BA3B8"/>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- Action buttons -->
                        <TextBlock Text="DEPLOYMENT" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                        <WrapPanel Margin="0,0,0,4">
                            <Button Style="{StaticResource BtnSuccess}" Content="⬇ Install / Update"
                                    Command="{Binding InstallCommand}"
                                    Height="36" Padding="14,0" Margin="0,0,6,6"
                                    ToolTip="Download and install via SteamCMD"/>
                            <Button Style="{StaticResource BtnAction}" Content="✔ Validate &amp; Repair"
                                    Command="{Binding ValidateCommand}"
                                    Height="36" Padding="14,0" Margin="0,0,6,6"
                                    ToolTip="Re-download any corrupt or missing files"/>
                            <Button Style="{StaticResource BtnAction}" Content="📁 Open Folder"
                                    Command="{Binding OpenInstallFolderCommand}"
                                    Height="36" Padding="14,0" Margin="0,0,6,6"
                                    ToolTip="Open the server install directory in Explorer"/>
                        </WrapPanel>

                        <!-- No SteamCMD warning -->
                        <Border CornerRadius="6" Padding="12,8" Margin="0,4,0,0"
                                Background="#1A1200" BorderBrush="#4A3800" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedServer.SupportsSteamCmd}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Foreground="#FFB800" FontSize="12" TextWrapping="Wrap">
                                <Run FontWeight="SemiBold">SteamCMD not supported.</Run>
                                <Run>This game must be installed manually. Point the profile's install path at your existing server files.</Run>
                            </TextBlock>
                        </Border>

                        <!-- Danger zone -->
                        <TextBlock Text="DANGER ZONE" Style="{StaticResource FieldLabel}" Margin="0,20,0,8"/>
                        <Button Style="{StaticResource BtnDanger}" Content="Delete Profile"
                                Command="{Binding DeleteProfileCommand}"
                                HorizontalAlignment="Left" Height="32" Padding="12,0"
                                ToolTip="Remove this profile from the app (server files are not deleted)"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- ── New server form ─────────────────────────────────────── -->
                <ScrollViewer Visibility="{Binding ShowNewServer, Converter={StaticResource BoolToVis}}"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="2,0,2,0">
                        <TextBlock Text="New Server Profile" Foreground="#E0EEF8"
                                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Foreground="{StaticResource TextMuted}" FontSize="12"
                                   Text="Configure the server profile. Paths are auto-generated from the server name."
                                   TextWrapping="Wrap" Margin="0,0,0,16"/>

                        <!-- Game -->
                        <TextBlock Style="{StaticResource FieldLabel}" Text="GAME"/>
                        <ComboBox Style="{StaticResource ProviderCombo}"
                                  ItemsSource="{Binding AllProviders}"
                                  SelectedItem="{Binding NewProvider, Mode=TwoWay}"
                                  DisplayMemberPath="GameName"/>

                        <!-- Server name -->
                        <TextBlock Style="{StaticResource FieldLabel}" Text="SERVER NAME"/>
                        <TextBox Style="{StaticResource InputBox}"
                                 Text="{Binding NewServerName, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="e.g. My Rust Server"/>

                        <!-- Profile name -->
                        <TextBlock Style="{StaticResource FieldLabel}" Text="PROFILE NAME  (display label in the app)"/>
                        <TextBox Style="{StaticResource InputBox}"
                                 Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Defaults to server name"/>

                        <!-- Install path -->
                        <TextBlock Style="{StaticResource FieldLabel}" Text="INSTALL PATH"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource InputBox}"
                                     Text="{Binding NewInstallPath, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas, Courier New" FontSize="11"/>
                            <Button Grid.Column="1" Style="{StaticResource BtnAction}" Content="Browse"
                                    Command="{Binding BrowseInstallPathCommand}"
                                    Margin="4,0,0,0" Width="64"/>
                        </Grid>

                        <!-- Ports -->
                        <TextBlock Style="{StaticResource FieldLabel}" Text="GAME PORT"/>
                        <TextBox Style="{StaticResource InputBox}"
                                 Text="{Binding NewGamePort, UpdateSourceTrigger=PropertyChanged}"/>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="QUERY PORT"/>
                                <TextBox Style="{StaticResource InputBox}"
                                         Text="{Binding NewQueryPort, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="RCON PORT"/>
                                <TextBox Style="{StaticResource InputBox}"
                                         Text="{Binding NewRconPort, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Admin password -->
                        <TextBlock Style="{StaticResource FieldLabel}" Text="ADMIN PASSWORD  (optional)"/>
                        <TextBox Style="{StaticResource InputBox}"
                                 Text="{Binding NewAdminPassword, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Leave blank to configure later"/>

                        <!-- Actions -->
                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                            <Button Style="{StaticResource BtnPrimary}" Content="⬇ Create &amp; Install"
                                    Command="{Binding CreateAndInstallCommand}"
                                    Height="36" Padding="14,0" Margin="0,0,6,0"/>
                            <Button Style="{StaticResource BtnAction}" Content="Create Only"
                                    Command="{Binding CreateProfileCommand}"
                                    Height="36" Padding="14,0" Margin="0,0,6,0"/>
                            <Button Style="{StaticResource BtnAction}" Content="Cancel"
                                    Command="{Binding CancelNewCommand}"
                                    Height="36" Padding="14,0"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- ── Installing panel ────────────────────────────────────── -->
                <Grid Visibility="{Binding ShowInstalling, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Stage + animated bar -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="{Binding InstallStage}"
                                   Foreground="#E0EEF8" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding InstallStatus}"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11" Margin="0,3,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <ProgressBar Grid.Row="1" IsIndeterminate="True"
                                 Height="3" Margin="0,0,0,10"
                                 Background="#0A1624" Foreground="#2268E0"
                                 BorderThickness="0"/>

                    <!-- Rolling log output -->
                    <Border Grid.Row="2" Background="#050E1A"
                            BorderBrush="{StaticResource BorderMuted}"
                            BorderThickness="1" CornerRadius="6">
                        <ScrollViewer x:Name="InstallScroller"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      Padding="0,4,0,4">
                            <ItemsControl ItemsSource="{Binding InstallLog}"
                                          ItemTemplate="{StaticResource LogLineTemplate}"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- Cancel -->
                    <Button Grid.Row="3" Style="{StaticResource BtnDanger}" Content="Cancel"
                            Command="{Binding CancelInstallCommand}"
                            HorizontalAlignment="Left" Margin="0,8,0,0"
                            Height="32" Width="80"/>
                </Grid>

                <!-- ── Result panel ────────────────────────────────────────── -->
                <StackPanel Visibility="{Binding ShowResult, Converter={StaticResource BoolToVis}}"
                            VerticalAlignment="Top">

                    <!-- Result card -->
                    <Border CornerRadius="8" Padding="20,16" Margin="0,0,0,16">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"   Value="#0D3D20"/>
                                <Setter Property="BorderBrush"  Value="#1A6038"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ResultSuccess}" Value="False">
                                        <Setter Property="Background"  Value="#2C0A0A"/>
                                        <Setter Property="BorderBrush" Value="#6A1C1C"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock FontSize="20" Margin="0,0,0,6">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="✓  Success"/>
                                        <Setter Property="Foreground" Value="#38D983"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ResultSuccess}" Value="False">
                                                <Setter Property="Text"       Value="✕  Failed"/>
                                                <Setter Property="Foreground" Value="#FF7070"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding ResultMessage}"
                                       FontSize="12" TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#5DDA95"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ResultSuccess}" Value="False">
                                                <Setter Property="Foreground" Value="#FF9090"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Post-install actions -->
                    <WrapPanel>
                        <Button Style="{StaticResource BtnAction}" Content="← Back"
                                Command="{Binding BackToServerCommand}"
                                Height="32" Padding="12,0" Margin="0,0,6,6"/>
                        <Button Style="{StaticResource BtnAction}" Content="📄 View Log"
                                Command="{Binding OpenLogCommand}"
                                Height="32" Padding="12,0" Margin="0,0,6,6"/>
                        <Button Style="{StaticResource BtnAction}" Content="📁 Open Folder"
                                Command="{Binding OpenInstallFolderCommand}"
                                Height="32" Padding="12,0" Margin="0,0,6,6"/>
                        <Button Style="{StaticResource BtnSuccess}" Content="⬇ Install Again"
                                Command="{Binding InstallCommand}"
                                Height="32" Padding="12,0" Margin="0,0,0,6"/>
                    </WrapPanel>
                </StackPanel>

            </Grid><!-- end right panel -->
        </Grid><!-- end main grid -->

        <!-- ═══ Row 2 — Status bar ══════════════════════════════════════════ -->
        <Border Grid.Row="2" Margin="0,6,0,0" Padding="10,5" CornerRadius="4">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#0B1726"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding StatusIsError}" Value="True">
                            <Setter Property="Background" Value="#200A0A"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding StatusText}" FontSize="11">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#7090A8"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StatusIsError}" Value="True">
                                <Setter Property="Foreground" Value="#FF7070"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>

    </Grid>
</UserControl>
