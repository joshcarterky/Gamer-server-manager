<UserControl x:Class="GameServerManager.App.Views.BackupsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GameServerManager.App.ViewModels"
             Background="#070F1A">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#1C3349"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#0D1826"/>
                                <Setter Property="Foreground" Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource GhostBtn}">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource GhostBtn}">
            <Setter Property="BorderBrush" Value="#5C1A1A"/>
            <Setter Property="Foreground" Value="#FCA5A5"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#070F1A" BorderBrush="#1C3349" BorderThickness="0,0,0,1" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="Backups" Foreground="#F1F5F9" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Create, restore, and manage server backups" Foreground="#4B6280" FontSize="11.5" Margin="0,2,0,0"/>
                </StackPanel>

                <ComboBox Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" MinWidth="280"
                          Background="#0D1826" Foreground="#F1F5F9" BorderBrush="#1C3349"
                          ItemsSource="{Binding Servers}"
                          DisplayMemberPath="Label"
                          SelectedItem="{Binding SelectedServer, Mode=TwoWay}"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Create Backup" Style="{StaticResource PrimaryBtn}" Margin="0,0,8,0"
                            Command="{Binding CreateBackupCommand}"/>
                    <Button Content="Open Folder" Style="{StaticResource GhostBtn}" Margin="0,0,8,0"
                            Command="{Binding OpenFolderCommand}"/>
                    <Button Content="Refresh" Style="{StaticResource GhostBtn}"
                            Command="{Binding RefreshCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Backups list -->
        <Grid Grid.Row="1">
            <!-- Column headers -->
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="20,10,20,8" BorderBrush="#142234" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="BACKUP" Foreground="#3D5A74" FontSize="10" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="CREATED" Foreground="#3D5A74" FontSize="10" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="SIZE" Foreground="#3D5A74" FontSize="10" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="3" Text="ACTIONS" Foreground="#3D5A74" FontSize="10" FontWeight="SemiBold"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- Empty state -->
                <TextBlock DockPanel.Dock="Top" Text="No backups yet for this server. Click “Create Backup” to make one."
                           Foreground="#3D5A74" FontSize="13" HorizontalAlignment="Center" Margin="0,50,0,0"
                           Visibility="{Binding HasNoBackups, Converter={StaticResource BoolToVis}}"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,6,20,12">
                    <ItemsControl ItemsSource="{Binding Backups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:BackupItemViewModel}">
                                <Border Background="#0D1826" BorderBrush="#1A2F44" BorderThickness="1"
                                        CornerRadius="8" Padding="14,10" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="200"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="🗄 " FontSize="13" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding FileName}" Foreground="#E2E8F0" FontSize="12.5"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding CreatedText}" Foreground="#8AA8C0"
                                                   FontSize="12" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding SizeText}" Foreground="#8AA8C0"
                                                   FontSize="12" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right"
                                                    VerticalAlignment="Center">
                                            <Button Content="Restore" Style="{StaticResource GhostBtn}" Margin="0,0,6,0"
                                                    Padding="10,5"
                                                    Command="{Binding DataContext.RestoreCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Delete" Style="{StaticResource DangerBtn}" Padding="10,5"
                                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#070F1A" BorderBrush="#1C3349" BorderThickness="0,1,0,0" Padding="20,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="●" Foreground="#2563EB" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Text="{Binding Status}" Foreground="#8AA8C0" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
