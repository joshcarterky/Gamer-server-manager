<UserControl x:Class="GameServerManager.App.Views.ConsoleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GameServerManager.App.ViewModels"
             Background="Transparent">

    <UserControl.Resources>

        <!-- ═══ Converters ════════════════════════════════════════════════════ -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ═══ Color palette ════════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="BorderMuted"   Color="#192E42"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8BA3B8"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#4E6070"/>

        <!-- ═══ Flat button template ══════════════════════════════════════════ -->
        <ControlTemplate x:Key="FlatBtn" TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.32"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- ═══ Button styles ════════════════════════════════════════════════ -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Foreground"      Value="#D0E4F4"/>
            <Setter Property="Background"      Value="#0E1E2E"/>
            <Setter Property="BorderBrush"     Value="#1C3248"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Template"        Value="{StaticResource FlatBtn}"/>
        </Style>

        <Style x:Key="BtnNav" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Width"     Value="32"/>
            <Setter Property="Padding"   Value="0"/>
            <Setter Property="FontSize"  Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI Symbol"/>
        </Style>

        <Style x:Key="BtnAction" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Padding"   Value="11,0"/>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"   Value="#1E62E8"/>
            <Setter Property="BorderBrush"  Value="#2878FF"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"   Value="#2C0A0A"/>
            <Setter Property="BorderBrush"  Value="#6A1C1C"/>
            <Setter Property="Foreground"   Value="#FF7070"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
        </Style>

        <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"   Value="#0D3D20"/>
            <Setter Property="BorderBrush"  Value="#1A6038"/>
            <Setter Property="Foreground"   Value="#3DDA85"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
        </Style>

        <!-- ═══ Input styles ═════════════════════════════════════════════════ -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background"              Value="#0A1624"/>
            <Setter Property="Foreground"              Value="#D0E4F4"/>
            <Setter Property="BorderBrush"             Value="#1C3248"/>
            <Setter Property="BorderThickness"         Value="1"/>
            <Setter Property="Padding"                 Value="9,0"/>
            <Setter Property="Height"                  Value="32"/>
            <Setter Property="CaretBrush"              Value="#D0E4F4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily"              Value="Segoe UI"/>
            <Setter Property="FontSize"                Value="12"/>
        </Style>

        <!-- ═══ ComboBox ═════════════════════════════════════════════════════ -->
        <Style x:Key="ServerCombo" TargetType="ComboBox">
            <Setter Property="Background"      Value="#0A1624"/>
            <Setter Property="Foreground"      Value="#D0E4F4"/>
            <Setter Property="BorderBrush"     Value="#1C3248"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#0A1624"/>
                        <Setter Property="Foreground" Value="#D0E4F4"/>
                        <Setter Property="Padding"    Value="10,7"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="B" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter TextElement.Foreground="#D0E4F4"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="B" Property="Background" Value="#14304A"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="B" Property="Background" Value="#1E62E8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"/>
                            <DockPanel Margin="10,0,6,0">
                                <TextBlock x:Name="Arrow" DockPanel.Dock="Right"
                                           Text="⌄" Foreground="#7090A8"
                                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                                <ContentPresenter x:Name="CP"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  VerticalAlignment="Center"
                                                  TextElement.Foreground="#D0E4F4"/>
                            </DockPanel>
                            <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Placement="Bottom"
                                   MinWidth="{TemplateBinding ActualWidth}">
                                <Border Background="#0A1624" BorderBrush="#243A50" BorderThickness="1" CornerRadius="5"
                                        MaxHeight="280">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                            <ToggleButton IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="Transparent" BorderThickness="0" Opacity="0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Console line item template ═══════════════════════════════════ -->
        <DataTemplate x:Key="ConsoleLineTemplate" DataType="{x:Type vm:ConsoleLineItem}">
            <TextBlock Text="{Binding DisplayText}"
                       Foreground="{Binding ForegroundHex}"
                       FontFamily="Consolas, Courier New"
                       FontSize="12"
                       Padding="12,1,12,1"
                       TextWrapping="Wrap"/>
        </DataTemplate>

    </UserControl.Resources>

    <!-- ═══ Root layout ═══════════════════════════════════════════════════════ -->
    <Grid Margin="14,10,14,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Console output -->
            <RowDefinition Height="Auto"/>  <!-- Filter + toolbar row -->
            <RowDefinition Height="Auto"/>  <!-- Command input -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ Row 0 — Header bar ══════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="180"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Server selector -->
            <ComboBox Grid.Column="0"
                      Style="{StaticResource ServerCombo}"
                      ItemsSource="{Binding Servers}"
                      SelectedItem="{Binding SelectedServer, Mode=TwoWay}"
                      Margin="0,0,8,0">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding StatusDot}"
                                       Foreground="#4E6070"
                                       Margin="0,0,7,0" FontSize="9"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Connection status badge -->
            <Border Grid.Column="1" Margin="0,0,8,0"
                    Background="#0A1828" BorderBrush="{StaticResource BorderMuted}"
                    BorderThickness="1" CornerRadius="5" Padding="10,0" Height="32">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#4E6070"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Fill" Value="#38D983"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                        <Setter Property="Fill" Value="#4E6070"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectionLabel}"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Connect / Disconnect / Reconnect -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,8,0">
                <Button Style="{StaticResource BtnSuccess}" Content="Connect"
                        Command="{Binding ConnectCommand}" Margin="0,0,4,0" Width="74"/>
                <Button Style="{StaticResource BtnDanger}" Content="Disconnect"
                        Command="{Binding DisconnectCommand}" Margin="0,0,4,0" Width="84"/>
                <Button Style="{StaticResource BtnAction}" Content="Reconnect"
                        Command="{Binding ReconnectCommand}" Width="82"/>
            </StackPanel>

            <!-- Utility buttons -->
            <StackPanel Grid.Column="3" Orientation="Horizontal">
                <Button Style="{StaticResource BtnNav}" Content="⟳" ToolTip="Refresh server list"
                        Command="{Binding RefreshServersCommand}" Margin="0,0,4,0"/>
                <Button Style="{StaticResource BtnAction}" Content="{Binding PauseButtonText}" ToolTip="Pause/resume live output"
                        Command="{Binding PauseResumeCommand}" Margin="0,0,4,0" MinWidth="62"/>
                <Button Style="{StaticResource BtnAction}" Content="Clear" ToolTip="Clear visible output"
                        Command="{Binding ClearCommand}" Margin="0,0,4,0" Width="50"/>
                <Button Style="{StaticResource BtnAction}" Content="Export" ToolTip="Save visible lines to file"
                        Command="{Binding ExportCommand}" Margin="0,0,4,0" Width="56"/>
                <Button Style="{StaticResource BtnAction}" Content="📁 Logs" ToolTip="Open server log folder"
                        Command="{Binding OpenLogFolderCommand}" Width="64"/>
            </StackPanel>
        </Grid>

        <!-- ═══ Row 1 — Console output panel ════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="#050E1A"
                BorderBrush="{StaticResource BorderMuted}"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <!-- No-server placeholder -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasServer}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="⊡" FontSize="36" Foreground="#243A50"
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Select a server above to open its console."
                               Foreground="{StaticResource TextMuted}" FontSize="13"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Console lines -->
                <ScrollViewer x:Name="ConsoleScroller"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              CanContentScroll="True"
                              Padding="0,4,0,4">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasServer}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <ItemsControl x:Name="ConsoleItems"
                                  ItemsSource="{Binding FilteredLines}"
                                  ItemTemplate="{StaticResource ConsoleLineTemplate}"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Loading overlay -->
                <Border Background="#AA050E1A" CornerRadius="6" Panel.ZIndex="10"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Loading servers…"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ Row 2 — Filter + auto-scroll ════════════════════════════════ -->
        <Grid Grid.Row="2" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     x:Name="FilterBox"
                     Style="{StaticResource InputBox}"
                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                     Tag="Filter output…"/>

            <CheckBox Grid.Column="1"
                      Content="Auto-scroll"
                      IsChecked="{Binding AutoScroll}"
                      Foreground="{StaticResource TextSecondary}"
                      Margin="10,0,0,0"
                      VerticalAlignment="Center"
                      Cursor="Hand"/>
        </Grid>

        <!-- ═══ Row 3 — Command input ════════════════════════════════════════ -->
        <Grid Grid.Row="3" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#0A1624"
                    BorderBrush="#1C3248" BorderThickness="1" CornerRadius="5">
                <TextBox x:Name="CommandInput"
                         Background="Transparent"
                         Foreground="#D0E4F4"
                         BorderThickness="0"
                         Padding="9,0"
                         Height="34"
                         CaretBrush="#D0E4F4"
                         VerticalContentAlignment="Center"
                         FontFamily="Consolas, Courier New"
                         FontSize="12"
                         Text="{Binding CommandText, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding CanSendCommand}"
                         Tag="Enter command… (↑↓ history, Enter to send)"/>
            </Border>

            <Button Grid.Column="1" Style="{StaticResource BtnPrimary}"
                    Content="Send" Command="{Binding SendCommand}"
                    Margin="6,0,0,0" Width="72" Height="34"/>
        </Grid>

        <!-- ═══ Row 4 — Status bar ═══════════════════════════════════════════ -->
        <Border Grid.Row="4" Margin="0,6,0,0" Padding="10,5" CornerRadius="4">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#0B1726"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding StatusIsError}" Value="True">
                            <Setter Property="Background" Value="#200A0A"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding StatusText}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#7090A8"/>
                        <Setter Property="FontSize"   Value="11"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StatusIsError}" Value="True">
                                <Setter Property="Foreground" Value="#FF7070"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>

    </Grid>
</UserControl>
