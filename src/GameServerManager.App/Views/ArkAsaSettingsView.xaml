<UserControl x:Class="GameServerManager.App.Views.ArkAsaSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:GameServerManager.App.Views"
             Background="Transparent">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- ═══ DESIGN TOKEN STYLES ═══ -->

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7A94B0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="Background" Value="#06101A"/>
            <Setter Property="CaretBrush" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#1E3349"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>
        <Style x:Key="ComboInput" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="Background" Value="#06101A"/>
            <Setter Property="TextElement.Foreground" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#1E3349"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#06101A"/>
                        <Setter Property="Foreground" Value="#F1F5F9"/>
                        <Setter Property="Padding" Value="10,7"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter TextElement.Foreground="#F1F5F9"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#142A40"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#2563EB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Chrome" Background="#06101A" BorderBrush="#1E3349" BorderThickness="1" CornerRadius="8">
                                            <Grid>
                                                <ContentPresenter Margin="10,0,30,0"
                                                                  TextElement.Foreground="#F1F5F9"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                                <Path Data="M 0 0 L 4 4 L 8 0 Z" Fill="#7A94B0" Width="8" Height="4"
                                                      HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#2A4A62"/>
                                                <Setter TargetName="Chrome" Property="Background" Value="#0D1826"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" PopupAnimation="Fade">
                                <Border Background="#06101A" BorderBrush="#1E3349" BorderThickness="1" CornerRadius="4"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="260">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Alias ModernCombo to ComboInput for Overview page -->
        <Style x:Key="ModernCombo" TargetType="ComboBox" BasedOn="{StaticResource ComboInput}"/>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#1E3349"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#142A40"/>
                                <Setter Property="Foreground" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#432029"/>
            <Setter Property="BorderBrush" Value="#AA4658"/>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#AA0D1826"/>
            <Setter Property="BorderBrush" Value="#1A3249"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="#AA0D1826"/>
            <Setter Property="BorderBrush" Value="#1A3249"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="6"/>
        </Style>

        <!-- ═══ HEADER BUTTON STYLES ═══ -->

        <Style x:Key="HeaderPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Background" Value="#1A2D4A"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#1E3349"/>
                                <Setter Property="Foreground" Value="#4A6A80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderOutlineButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderBrush" Value="#1E3349"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#142A40"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#2A4A62"/>
                                <Setter Property="Foreground" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ NAV BUTTON ═══ -->

        <Style x:Key="NewNavButton" TargetType="Button">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#142A40"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#1D3D6E"/>
                    <Setter Property="BorderBrush" Value="#2A5A9E"/>
                    <Setter Property="Foreground" Value="#F1F5F9"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ═══ CONTENT BUTTON STYLES ═══ -->

        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderBrush" Value="#1E3349"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#142A40"/>
                                <Setter Property="Foreground" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource OutlineButton}">
            <Setter Property="Padding" Value="10,7"/>
        </Style>

        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#3B82F6"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#60A5FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- ═══ ROOT 3-ROW GRID ═══ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>   <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Unsaved changes banner -->
            <RowDefinition Height="*"/>    <!-- Sidebar + Content -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 0 — TOP HEADER BAR
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#AA0A1520" BorderBrush="#1A3249" BorderThickness="0,0,0,1">
            <Grid Margin="16,0,12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- Logo + title -->
                    <ColumnDefinition Width="1"/>     <!-- Separator -->
                    <ColumnDefinition Width="Auto"/>  <!-- Server chip -->
                    <ColumnDefinition Width="*"/>     <!-- Search (flex) -->
                    <ColumnDefinition Width="Auto"/>  <!-- Mode toggle -->
                    <ColumnDefinition Width="Auto"/>  <!-- Action buttons -->
                </Grid.ColumnDefinitions>

                <!-- Logo + Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Border Width="34" Height="34" CornerRadius="8" Background="#152A4A">
                        <Polygon Points="17,7 29,27 5,27" Fill="#4B9FFF" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="ARK ASA Settings" Foreground="#F1F5F9" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="Configure and manage your ARK: Survival Ascended server" Foreground="#7A94B0" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <!-- Separator -->
                <Border Grid.Column="1" Width="1" Background="#1A3249" Margin="0,12"/>

                <!-- Server profile chip -->
                <Border Grid.Column="2" Background="#08141E" BorderBrush="#1A3249" BorderThickness="1" CornerRadius="8"
                        Padding="10,0" Margin="16,10" Cursor="Hand">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="#22C55E" VerticalAlignment="Center"/>
                        <StackPanel Margin="8,0,0,0">
                            <TextBlock Text="ARK: Survival Ascended" Foreground="#F1F5F9" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ProfileDisplayName}" Foreground="#7A94B0" FontSize="11"/>
                        </StackPanel>
                        <Path Data="M 0 0 L 4 4 L 8 0 Z" Fill="#7A94B0" Width="8" Height="4" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Search bar -->
                <Border Grid.Column="3" Background="#06101A" BorderBrush="#1E3349" BorderThickness="1" CornerRadius="8" Margin="0,11,12,11">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" Foreground="#7A94B0"
                                   FontSize="14" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="#F1F5F9" CaretBrush="#F1F5F9"
                                 Padding="8,0" MinWidth="160"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Search setting names, INI keys, and descriptions"/>
                        <Border Grid.Column="2" Background="#0D1826" BorderBrush="#1A3249" BorderThickness="1"
                                CornerRadius="4" Padding="5,2" Margin="0,0,6,0" VerticalAlignment="Center">
                            <TextBlock Text="Ctrl+K" Foreground="#4A6A80" FontSize="10"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Header action buttons -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Save Changes" Command="{Binding SaveCommand}" Style="{StaticResource HeaderPrimaryButton}"/>
                    <Button Content="Validate" Command="{Binding ValidateCommand}" Style="{StaticResource HeaderOutlineButton}"/>
                    <Button Content="Export" Command="{Binding ExportConfigurationCommand}" Style="{StaticResource HeaderOutlineButton}"/>
                    <Button Content="Reset Category" Command="{Binding ResetCategoryCommand}" Style="{StaticResource HeaderOutlineButton}" Margin="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 1 — UNSAVED CHANGES BANNER
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#0F1F10" BorderBrush="#1A4A1A" BorderThickness="0,0,0,1" Padding="20,6"
                Visibility="{Binding HasUnsavedChanges, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#x26A0; " Foreground="#F59E0B" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding UnsavedChangesText}" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Review Changes" Command="{Binding ReviewChangesCommand}" Style="{StaticResource LinkButton}" Margin="0,0,12,0"/>
                    <Button Content="Revert" Command="{Binding RevertCommand}" Style="{StaticResource LinkButton}" Margin="0,0,12,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 2 — SIDEBAR + MAIN CONTENT
             ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>  <!-- Sidebar -->
                <ColumnDefinition Width="*"/>    <!-- Main content -->
            </Grid.ColumnDefinitions>

            <!-- ─────────────────────────────────────────────────────
                 LEFT SIDEBAR (220px)
                 ───────────────────────────────────────────────────── -->
            <Border Grid.Column="0" Background="#AA090F18" BorderBrush="#1A3249" BorderThickness="0,0,1,0">
                <DockPanel LastChildFill="True">

                    <!-- Server status footer card -->
                    <Border DockPanel.Dock="Bottom" Background="#0D1826" BorderBrush="#1A3249" BorderThickness="0,1,0,0" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Width="10" Height="10" Fill="#EF4444" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Server Offline" Foreground="#F1F5F9" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding ServerStatusText}" Foreground="#7A94B0" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Nav scroll area -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8,12,8,8">
                            <ItemsControl ItemsSource="{Binding NavigationGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,8">
                                            <!-- Group label -->
                                            <TextBlock Text="{Binding Name}" Foreground="#4A6A80" FontSize="10" FontWeight="SemiBold"
                                                       Margin="8,4,0,4"/>
                                            <!-- Group items -->
                                            <ItemsControl ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource NewNavButton}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="22"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <!-- Icon -->
                                                                <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                                           Foreground="#7A94B0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                                <!-- Name -->
                                                                <TextBlock Grid.Column="1" Text="{Binding Name}" TextWrapping="NoWrap"
                                                                           Margin="6,0,4,0" VerticalAlignment="Center"/>
                                                                <!-- Modified badge -->
                                                                <Border Grid.Column="2" Background="#B8831A" CornerRadius="4" Padding="5,1" Margin="2,0,0,0"
                                                                        Visibility="{Binding HasModified, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <TextBlock Text="{Binding ModifiedCount}" Foreground="#111820" FontSize="10" FontWeight="Bold"/>
                                                                </Border>
                                                                <!-- Error badge -->
                                                                <Border Grid.Column="3" Background="#C0294E" CornerRadius="4" Padding="5,1" Margin="2,0,0,0"
                                                                        Visibility="{Binding HasErrors, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <TextBlock Text="{Binding ErrorCount}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                                                </Border>
                                                            </Grid>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- ─────────────────────────────────────────────────────
                 MAIN CONTENT AREA
                 ───────────────────────────────────────────────────── -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,16,20,20">

                    <!-- ═══ OVERVIEW TAB ═══ -->
                    <StackPanel Visibility="{Binding IsOverviewTab, Converter={StaticResource BooleanToVisibilityConverter}}">

                        <!-- Page heading -->
                        <TextBlock Text="Overview" Foreground="#F1F5F9" FontSize="22" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Quick status, configuration health, and common settings for this ARK server."
                                   Foreground="#7A94B0" FontSize="13" Margin="0,0,0,16"/>

                        <!-- 3-column status cards -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Card 1: Quick Status -->
                            <Border Grid.Column="0" Background="#0D1826" BorderBrush="#1A3249" BorderThickness="1" CornerRadius="10" Padding="16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="#7A94B0" FontSize="14"
                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Quick Status" Foreground="#F1F5F9" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <!-- State -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="State" Foreground="#7A94B0" FontSize="12" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Background="#1F0A0A" BorderBrush="#5A1A1A" BorderThickness="1" CornerRadius="4" Padding="8,2">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="6" Height="6" Fill="#EF4444" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                <TextBlock Text="{Binding ServerStatusText}" Foreground="#F87171" FontSize="11"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <!-- Joinability -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Joinability" Foreground="#7A94B0" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="{Binding JoinabilityText}" Foreground="#94A3B8" FontSize="12"/>
                                    </Grid>
                                    <!-- Uptime -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Uptime" Foreground="#7A94B0" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="{Binding UptimeText}" Foreground="#94A3B8" FontSize="12"/>
                                    </Grid>
                                    <!-- Mods badge -->
                                    <Border Background="#0F1E35" BorderBrush="#1E3A5F" BorderThickness="1" CornerRadius="4"
                                            Padding="8,3" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding ModsStatusText}" Foreground="#60A5FA" FontSize="11"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Card 2: Configuration Health -->
                            <Border Grid.Column="2" Background="#0D1826" BorderBrush="#1A3249" BorderThickness="1" CornerRadius="10" Padding="16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="&#xE006;" FontFamily="Segoe MDL2 Assets" Foreground="#7A94B0" FontSize="14"
                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Configuration Health" Foreground="#F1F5F9" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <!-- Errors -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Errors" Foreground="#7A94B0" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ValidationErrorCount}" Foreground="#EF4444" FontSize="12" FontWeight="SemiBold"/>
                                    </Grid>
                                    <!-- Warnings -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#x26A0;" Foreground="#F59E0B" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="Warnings" Foreground="#7A94B0" FontSize="12"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding ValidationWarningCount}" Foreground="#F59E0B" FontSize="12" FontWeight="SemiBold"/>
                                    </Grid>
                                    <!-- INI Sync -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="INI Sync" Foreground="#7A94B0" FontSize="12"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="&#x2714;" Foreground="{Binding IniSyncStatusColor}" FontSize="11"
                                                       Margin="0,0,4,0" VerticalAlignment="Center"
                                                       Visibility="{Binding IniSyncIsGood, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            <TextBlock Text="{Binding IniSyncStatusText}" Foreground="{Binding IniSyncStatusColor}" FontSize="12"/>
                                        </StackPanel>
                                    </Grid>
                                    <!-- Launch Args -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Launch Args" Foreground="#7A94B0" FontSize="12"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="&#x2714;" Foreground="{Binding LaunchArgsStatusColor}" FontSize="11"
                                                       Margin="0,0,4,0" VerticalAlignment="Center"
                                                       Visibility="{Binding LaunchArgsIsGood, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            <TextBlock Text="{Binding LaunchArgsStatusText}" Foreground="{Binding LaunchArgsStatusColor}" FontSize="12"/>
                                        </StackPanel>
                                    </Grid>
                                    <!-- Footer -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding LastValidatedText, StringFormat='Last validated: {0}'}"
                                                   Foreground="#4A6A80" FontSize="11" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="View Details"
                                                Command="{Binding SelectCategoryCommand}" CommandParameter="Health and Validation"
                                                Style="{StaticResource LinkButton}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Card 3: Ports -->
                            <Border Grid.Column="4" Background="#0D1826" BorderBrush="#1A3249" BorderThickness="1" CornerRadius="10" Padding="16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets" Foreground="#7A94B0" FontSize="14"
                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Ports" Foreground="#F1F5F9" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <!-- Game port -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Game" Foreground="#7A94B0" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Foreground="#F1F5F9" FontSize="12">
                                            <Run Text="{Binding GamePort, Mode=OneWay}"/><Run Text="/UDP" Foreground="#7A94B0"/>
                                        </TextBlock>
                                    </Grid>
                                    <!-- Query port -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Query" Foreground="#7A94B0" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Foreground="#F1F5F9" FontSize="12">
                                            <Run Text="{Binding QueryPort, Mode=OneWay}"/><Run Text="/UDP" Foreground="#7A94B0"/>
                                        </TextBlock>
                                    </Grid>
                                    <!-- RCON port -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="RCON" Foreground="#7A94B0" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Foreground="#F1F5F9" FontSize="12">
                                            <Run Text="{Binding RconPort, Mode=OneWay}"/><Run Text="/TCP" Foreground="#7A94B0"/>
                                        </TextBlock>
                                    </Grid>
                                    <Button Content="Test Ports" Command="{Binding ValidateCommand}"
                                            Style="{StaticResource OutlineButton}" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Quick Configuration card -->
                        <Border Background="#0D1826" BorderBrush="#1A3249" BorderThickness="1" CornerRadius="10" Padding="20" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Quick Configuration" Foreground="#F1F5F9" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Core server settings and quick actions." Foreground="#7A94B0" FontSize="12" Margin="0,3,0,16"/>

                                <!-- Server Name + Map row -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Server Name -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Server Name" Foreground="#7A94B0" FontSize="12" Margin="0,0,0,6"/>
                                        <Border Background="#06101A" BorderBrush="#1E3349" BorderThickness="1" CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" Foreground="#4A6A80"
                                                           FontSize="13" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" Text="{Binding ServerName, UpdateSourceTrigger=PropertyChanged}"
                                                         Background="Transparent" BorderThickness="0" Foreground="#F1F5F9" CaretBrush="#F1F5F9"
                                                         Padding="8,9" VerticalContentAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                    <!-- Map -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Map" Foreground="#7A94B0" FontSize="12" Margin="0,0,0,6"/>
                                        <ComboBox ItemsSource="{Binding OfficialMaps}"
                                                  SelectedValue="{Binding MapName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="InternalName" DisplayMemberPath="DisplayName"
                                                  Style="{StaticResource ModernCombo}" Margin="0"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Install Path (full width) -->
                                <TextBlock Text="Install Path" Foreground="#7A94B0" FontSize="12" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#06101A" BorderBrush="#1E3349" BorderThickness="1" CornerRadius="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" Foreground="#4A6A80"
                                                       FontSize="13" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" Text="{Binding InstallPath, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="Transparent" BorderThickness="0" Foreground="#F1F5F9" CaretBrush="#F1F5F9"
                                                     Padding="8,9" VerticalContentAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseInstallPathCommand}"
                                            Style="{StaticResource SmallButton}" Margin="8,0,0,0"/>
                                </Grid>

                                <!-- Diagnostics row -->
                                <Border Background="#060E18" BorderBrush="#12243A" BorderThickness="1" CornerRadius="8"
                                        Padding="12,8" Margin="0,0,0,16">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Path Status -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                            <Ellipse Width="7" Height="7" Fill="{Binding PathExistsColor}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Foreground="#7A94B0" FontSize="11">
                                                <Run Text="Path Status: "/><Run Text="{Binding PathExistsText, Mode=OneWay}" Foreground="#94A3B8"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Border Width="1" Background="#1A3249" Margin="0,0,16,0"/>
                                        <!-- Permissions -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                            <Ellipse Width="7" Height="7" Fill="{Binding PathWritableColor}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Foreground="#7A94B0" FontSize="11">
                                                <Run Text="Permissions: "/><Run Text="{Binding PathWritableText, Mode=OneWay}" Foreground="#94A3B8"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Border Width="1" Background="#1A3249" Margin="0,0,16,0"/>
                                        <!-- Disk Space -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                            <Ellipse Width="7" Height="7" Fill="{Binding DiskSpaceColor}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Foreground="#7A94B0" FontSize="11">
                                                <Run Text="Disk Space: "/><Run Text="{Binding DiskSpaceText, Mode=OneWay}" Foreground="#94A3B8"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Border Width="1" Background="#1A3249" Margin="0,0,16,0"/>
                                        <!-- Executable Status -->
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="7" Height="7" Fill="{Binding ExecutableStatusColor}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Foreground="#7A94B0" FontSize="11">
                                                <Run Text="Executable Status: "/><Run Text="{Binding ExecutableStatus, Mode=OneWay}" Foreground="#94A3B8"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Quick actions -->
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Validate Configuration" Command="{Binding ValidateCommand}"
                                            Style="{StaticResource OutlineButton}" Margin="0,0,8,0"/>
                                    <Button Content="Manage Mods" Command="{Binding ManageModsCommand}"
                                            Style="{StaticResource OutlineButton}" Margin="0,0,8,0"/>
                                    <Button Content="Create Backup" Command="{Binding CreateBackupCommand}"
                                            Style="{StaticResource PrimaryActionButton}" Margin="0,0,8,0"/>
                                    <Button Content="Open Console" Command="{Binding SelectCategoryCommand}"
                                            CommandParameter="RCON / Console" Style="{StaticResource OutlineButton}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Configuration status strip (3 columns) -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Configuration column -->
                            <Border Grid.Column="0" Background="#0D1826" BorderBrush="#1A3249" BorderThickness="1" CornerRadius="10" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Configuration" Foreground="#F1F5F9" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock Text="Settings are loaded from" Foreground="#7A94B0" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding GameUserSettingsPath}" Foreground="#4A6A80" FontSize="10"
                                               TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>
                            <!-- INI Sync column -->
                            <Border Grid.Column="2" Background="#0D1826" BorderBrush="#1A3249" BorderThickness="1" CornerRadius="10" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="INI Sync" Foreground="#F1F5F9" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding LastValidatedText, StringFormat='Last synced: {0}'}"
                                               Foreground="#7A94B0" FontSize="11" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Status: " Foreground="#7A94B0" FontSize="11"/>
                                        <TextBlock Text="{Binding IniSyncStatusText}" Foreground="{Binding IniSyncStatusColor}"
                                                   FontSize="11" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <!-- Launch Arguments column -->
                            <Border Grid.Column="4" Background="#0D1826" BorderBrush="#1A3249" BorderThickness="1" CornerRadius="10" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Launch Arguments" Foreground="#F1F5F9" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock Text="Custom launch arguments are up to date" Foreground="#7A94B0" FontSize="11" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Status: " Foreground="#7A94B0" FontSize="11"/>
                                        <TextBlock Text="{Binding LaunchArgsStatusText}" Foreground="{Binding LaunchArgsStatusColor}"
                                                   FontSize="11" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                    </StackPanel>
                    <!-- END OVERVIEW TAB -->

                    <!-- ═══ CLUSTER TAB ═══ -->
                    <Border Style="{StaticResource Panel}"
                            Visibility="{Binding IsClusterTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Cluster" Foreground="White" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <Border Background="{Binding ClusterStatusColor}" BorderBrush="#4B6F8A" BorderThickness="1" CornerRadius="5" Padding="8,3" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding ClusterStatusText}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding ClusterStatusMessage}" Style="{StaticResource Label}" Margin="0,6,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="Validate" Command="{Binding ValidateCommand}" Style="{StaticResource ActionButton}"/>
                                    <Button Content="Open Cluster Folder" Command="{Binding OpenClusterFolderCommand}" Style="{StaticResource ActionButton}"/>
                                    <Button Content="Reset" Command="{Binding ResetClusterCommand}" Style="{StaticResource ActionButton}"/>
                                </StackPanel>
                            </Grid>

                            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="CrossARK Cluster" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                                    <CheckBox Content="Enable Cluster" IsChecked="{Binding ClusterEnabled}" Foreground="#DDE9F4" Margin="0,14,0,8"/>

                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Cluster ID" Style="{StaticResource Label}"/>
                                            <TextBox Text="{Binding ClusterId, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}" MinHeight="36"/>
                                            <TextBlock Text="Use the same ID on every server that should transfer together." Style="{StaticResource Label}" Margin="0,5,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Generate" Command="{Binding GenerateClusterIdCommand}" Style="{StaticResource ActionButton}" VerticalAlignment="Center"/>
                                    </Grid>

                                    <Grid Margin="0,18,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Cluster Directory Override" Style="{StaticResource Label}"/>
                                            <TextBox Text="{Binding ClusterDirectoryOverride, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}" MinHeight="36"/>
                                            <TextBlock Text="All clustered maps must read and write to this same folder." Style="{StaticResource Label}" Margin="0,5,0,0"/>
                                            <TextBlock Text="{Binding ClusterDirectoryStatusText}" Foreground="#F3B45D" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseClusterDirectoryCommand}" Style="{StaticResource ActionButton}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="2" Content="Create Folder" Command="{Binding CreateClusterDirectoryCommand}" Style="{StaticResource ActionButton}" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}" Visibility="{Binding ShowClusterLaunchPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Launch Preview" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding ClusterLaunchPreview, Mode=OneWay}" Style="{StaticResource Input}" FontFamily="Consolas" IsReadOnly="True" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══ MOD MANAGER (Mods tab only) ═══ -->
                    <Border Style="{StaticResource Panel}"
                            DataContext="{Binding Mods}"
                            Visibility="{Binding DataContext.IsModsTab, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>

                            <!-- Header + action buttons -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Mod Manager" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Message}" Style="{StaticResource Label}" Margin="0,3,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="Browse CurseForge" Command="{Binding OpenBrowserCommand}"
                                            Style="{StaticResource ActionButton}" Background="#1B4D72" BorderBrush="#2A7AB5"
                                            Visibility="{Binding IsBrowserClosed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <Button Content="&#8592; Back to Mod List" Command="{Binding CloseBrowserCommand}"
                                            Style="{StaticResource ActionButton}"
                                            Visibility="{Binding IsBrowserOpen, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <Button Content="Sort by Name" Command="{Binding SortByNameCommand}" Style="{StaticResource ActionButton}"
                                            Visibility="{Binding IsBrowserClosed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <Button Content="Sort by Date" Command="{Binding SortByDateCommand}" Style="{StaticResource ActionButton}"
                                            Visibility="{Binding IsBrowserClosed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <Button Content="Clear Disabled" Command="{Binding ClearDisabledCommand}" Style="{StaticResource ActionButton}"
                                            Visibility="{Binding IsBrowserClosed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <Button Content="Clear All" Command="{Binding ClearAllCommand}" Style="{StaticResource ActionButton}"
                                            Visibility="{Binding IsBrowserClosed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </StackPanel>
                            </Grid>

                            <!-- CurseForge Mod Browser (overlays mod list when open) -->
                            <Grid Visibility="{Binding IsBrowserOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <local:CurseForgeModBrowserView DataContext="{Binding Browser}" MinHeight="500"/>
                            </Grid>

                            <!-- Normal mod manager content (hidden when browser is open) -->
                            <StackPanel Visibility="{Binding IsBrowserClosed, Converter={StaticResource BooleanToVisibilityConverter}}">

                            <!-- Stats bar -->
                            <UniformGrid Columns="4" Margin="0,0,0,10">
                                <Border Background="#1A2E3E" BorderBrush="#2D4F68" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,6,0">
                                    <StackPanel>
                                        <TextBlock Text="Total Mods" Foreground="#7AA8C8" FontSize="11"/>
                                        <TextBlock Text="{Binding TotalMods}" Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#1A2E3E" BorderBrush="#2D4F68" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,6,0">
                                    <StackPanel>
                                        <TextBlock Text="Enabled" Foreground="#7AA8C8" FontSize="11"/>
                                        <TextBlock Text="{Binding EnabledCount}" Foreground="#4CAF50" FontSize="20" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#1A2E3E" BorderBrush="#2D4F68" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,6,0">
                                    <StackPanel>
                                        <TextBlock Text="Disabled" Foreground="#7AA8C8" FontSize="11"/>
                                        <TextBlock Text="{Binding DisabledCount}" Foreground="#A8B7C8" FontSize="20" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#1A2E3E" BorderBrush="#2D4F68" BorderThickness="1" CornerRadius="6" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock Text="Duplicates" Foreground="#7AA8C8" FontSize="11"/>
                                        <TextBlock Text="{Binding DuplicateCount}" FontSize="20" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#A8B7C8"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasDuplicates}" Value="True">
                                                            <Setter Property="Foreground" Value="#FF5555"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- Map Mod + Add Mod side by side -->
                            <UniformGrid Columns="2" Margin="0,0,0,10">

                                <!-- Active Map Mod -->
                                <Border Background="#0D1E2D" BorderBrush="#2D4F68" BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,5,0">
                                    <StackPanel>
                                        <TextBlock Text="ACTIVE MAP MOD" Foreground="#7AA8C8" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding ActiveMapModName}" Foreground="White" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"
                                                           Visibility="{Binding HasActiveMapMod, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <TextBlock Text="{Binding ActiveMapModId}" Foreground="#7AA8C8" FontSize="11" Margin="0,2,0,0"
                                                           Visibility="{Binding HasActiveMapMod, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <TextBlock Foreground="#4A6A80" FontSize="13" FontStyle="Italic">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="No map mod selected"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasActiveMapMod}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Clear" Command="{Binding ClearMapModCommand}"
                                                    Style="{StaticResource ActionButton}" VerticalAlignment="Center"
                                                    Visibility="{Binding HasActiveMapMod, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        </Grid>
                                        <TextBlock Text="Set a map mod via 'Map Mod' on any mod in the list below." Foreground="#4A6A80" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- Add Mod -->
                                <Border Background="#0D1E2D" BorderBrush="#2D4F68" BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="5,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="ADD MODS" Foreground="#7AA8C8" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding AddModInput, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource Input}"
                                                 ToolTip="Enter mod IDs (comma-separated) or paste a CurseForge URL"
                                                 MinHeight="60" AcceptsReturn="True" TextWrapping="Wrap"
                                                 Margin="0,0,0,8">
                                            <TextBox.InputBindings>
                                                <KeyBinding Key="Return" Modifiers="Ctrl" Command="{Binding AddModCommand}"/>
                                            </TextBox.InputBindings>
                                        </TextBox>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Content="Enable immediately" IsChecked="{Binding AddAsEnabled}" Foreground="#DDE9F4" VerticalAlignment="Center"/>
                                            <CheckBox Grid.Column="1" Content="Cluster-wide" IsChecked="{Binding AddAsClusterWide}" Foreground="#DDE9F4" VerticalAlignment="Center"/>
                                            <Button Grid.Column="2" Content="Add Mods" Command="{Binding AddModCommand}" Style="{StaticResource ActionButton}" Background="#1E5C8A"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- CurseForge URL Preview Panel -->
                            <Border Background="#081420" BorderBrush="#1B4D6E" BorderThickness="1" CornerRadius="6" Padding="14,12" Margin="0,0,0,10"
                                    Visibility="{Binding IsPreviewVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Looking up CurseForge mod..." Foreground="#6FA8C8" FontSize="12"
                                               Visibility="{Binding IsPreviewLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <StackPanel Visibility="{Binding IsPreviewNeedsId, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock Text="CURSEFORGE URL DETECTED" Foreground="#7AA8C8" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <Button Content="&#x2715;" Command="{Binding DismissPreviewCommand}" HorizontalAlignment="Right"
                                                    Background="Transparent" BorderThickness="0" Foreground="#6A8A9A" FontSize="12" Padding="6,0" Cursor="Hand"/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding PreviewName}" Foreground="#EAF2FA" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding PreviewUrl}" Foreground="#4A7A9A" FontSize="10" Margin="0,0,0,8"/>
                                        <TextBlock Text="Enter the numeric Project ID from the mod's CurseForge page:" Foreground="#A8B7C8" FontSize="11" Margin="0,0,0,5"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding PreviewManualId, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource Input}" Margin="0" ToolTip="e.g. 928597"/>
                                            <Button Grid.Column="1" Content="Add Mod" Command="{Binding AddFromPreviewCommand}" Style="{StaticResource ActionButton}" Background="#1E5C8A" Margin="8,5,0,0"/>
                                            <Button Grid.Column="2" Content="Dismiss" Command="{Binding DismissPreviewCommand}" Style="{StaticResource ActionButton}" Margin="4,5,0,0"/>
                                        </Grid>
                                        <TextBlock Text="Tip: Add a CurseForge API key in Settings to auto-fill mod IDs from URLs." Foreground="#3D6880" FontSize="10" Margin="0,7,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding IsPreviewFound, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock Text="CURSEFORGE MOD FOUND" Foreground="#62F19F" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <Button Content="&#x2715;" Command="{Binding DismissPreviewCommand}" HorizontalAlignment="Right"
                                                    Background="Transparent" BorderThickness="0" Foreground="#6A8A9A" FontSize="12" Padding="6,0" Cursor="Hand"/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding PreviewName}" Foreground="#EAF2FA" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding PreviewAuthorText}" Foreground="#7AA8C8" FontSize="11" Margin="0,0,0,3"/>
                                        <TextBlock Text="{Binding PreviewSummary}" Foreground="#A8B7C8" FontSize="11" TextWrapping="Wrap" MaxHeight="42" Margin="0,0,0,8"
                                                   Visibility="{Binding HasPreviewSummary, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <Button Content="Add Mod" Command="{Binding AddFromPreviewCommand}" Style="{StaticResource ActionButton}" Background="#1E6B47" Margin="0,0,4,0"/>
                                                <Button Content="Dismiss" Command="{Binding DismissPreviewCommand}" Style="{StaticResource ActionButton}"/>
                                            </StackPanel>
                                            <TextBlock VerticalAlignment="Center">
                                                <Run Text="Project ID: " Foreground="#7AA8C8" FontSize="11"/>
                                                <Run Text="{Binding PreviewProjectId, Mode=OneWay}" Foreground="#62F19F" FontSize="13" FontWeight="SemiBold"/>
                                            </TextBlock>
                                        </DockPanel>
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding IsPreviewFailed, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock Text="LOOKUP FAILED" Foreground="#FF6666" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <Button Content="&#x2715;" Command="{Binding DismissPreviewCommand}" HorizontalAlignment="Right"
                                                    Background="Transparent" BorderThickness="0" Foreground="#6A8A9A" FontSize="12" Padding="6,0" Cursor="Hand"/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding PreviewError}" Foreground="#A8B7C8" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                        <TextBlock Text="Enter the numeric Project ID manually:" Foreground="#A8B7C8" FontSize="11" Margin="0,0,0,5"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding PreviewManualId, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource Input}" Margin="0" ToolTip="e.g. 928597"/>
                                            <Button Grid.Column="1" Content="Add Mod" Command="{Binding AddFromPreviewCommand}" Style="{StaticResource ActionButton}" Background="#1E5C8A" Margin="8,5,0,0"/>
                                            <Button Grid.Column="2" Content="Dismiss" Command="{Binding DismissPreviewCommand}" Style="{StaticResource ActionButton}" Margin="4,5,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Mod list toolbar -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Input}" Margin="0,0,8,0"
                                         ToolTip="Search mods by ID, name or notes"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="Import from Clipboard" Command="{Binding ImportFromClipboardCommand}" Style="{StaticResource ActionButton}"/>
                                    <Button Content="Export to Clipboard" Command="{Binding ExportToClipboardCommand}" Style="{StaticResource ActionButton}"/>
                                    <Button Content="Export to File" Command="{Binding ExportToFileCommand}" Style="{StaticResource ActionButton}"/>
                                    <Button Content="Validate" Command="{Binding ValidateCommand}" Style="{StaticResource ActionButton}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Empty state -->
                            <Border Background="#0A1828" BorderBrush="#1E3A50" BorderThickness="1" CornerRadius="8" Padding="40"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="No mods added yet" Foreground="#5A8AAA" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Add your first ARK ASA mod by entering a mod ID above." Foreground="#4A6A80" FontSize="13" HorizontalAlignment="Center" Margin="0,6,0,20" TextWrapping="Wrap"/>
                                    <TextBlock Text="Tip: you can paste a comma-separated list from an existing ActiveMods line." Foreground="#374F62" FontSize="11" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Mod list header row -->
                            <Grid Margin="0,0,0,4" Visibility="{Binding IsNotEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="240"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="#" Foreground="#4A6A80" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="On" Foreground="#4A6A80" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="Mod ID / Name" Foreground="#4A6A80" FontSize="11" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                <TextBlock Grid.Column="3" Text="Status" Foreground="#4A6A80" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="Actions" Foreground="#4A6A80" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Grid>

                            <!-- Mod rows -->
                            <ItemsControl ItemsSource="{Binding FilteredMods}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,4" CornerRadius="6" Padding="6,5">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#0F2235"/>
                                                    <Setter Property="BorderBrush" Value="#1E3A50"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasWarning}" Value="True">
                                                            <Setter Property="BorderBrush" Value="#882222"/>
                                                            <Setter Property="Background" Value="#1A1010"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                            <Setter Property="Opacity" Value="0.6"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="36"/>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="240"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding LoadOrder}" Foreground="#4A6A80" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                <CheckBox Grid.Column="1" IsChecked="{Binding Enabled}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="6,0">
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding ModId}" Foreground="#5A7A95" FontSize="11"
                                                               Visibility="{Binding HasWarning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    <TextBlock Text="{Binding Notes}" Foreground="#6A8A9A" FontSize="11" TextWrapping="Wrap"
                                                               Visibility="{Binding HasWarning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                </StackPanel>
                                                <Border Grid.Column="3" CornerRadius="4" Padding="8,3" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Background="{Binding StatusBadgeColor}">
                                                    <TextBlock Text="{Binding StatusBadgeText}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                </Border>
                                                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                    <Button Content="&#x25B2;" Command="{Binding MoveUpCommand}" ToolTip="Move up"
                                                            Foreground="#A8B7C8" Background="Transparent" BorderThickness="0" Padding="6,3" FontSize="12"/>
                                                    <Button Content="&#x25BC;" Command="{Binding MoveDownCommand}" ToolTip="Move down"
                                                            Foreground="#A8B7C8" Background="Transparent" BorderThickness="0" Padding="6,3" FontSize="12"/>
                                                    <Button Content="Copy ID" Command="{Binding CopyIdCommand}" ToolTip="Copy mod ID to clipboard"
                                                            Foreground="#7AA8C8" Background="Transparent" BorderThickness="0" Padding="6,3" FontSize="11"/>
                                                    <Button Content="Map Mod" Command="{Binding SetAsMapModCommand}" ToolTip="Set as active map mod"
                                                            Foreground="#B89AE8" Background="Transparent" BorderThickness="0" Padding="6,3" FontSize="11"/>
                                                    <Button Content="&#x2715;" Command="{Binding RemoveCommand}" ToolTip="Remove mod"
                                                            Foreground="#CC4444" Background="Transparent" BorderThickness="0" Padding="8,3" FontSize="13"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Validation panel -->
                            <Border Background="#091525" BorderBrush="#1A3040" BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="0,10,0,0">
                                <StackPanel>
                                    <TextBlock Text="VALIDATION" Foreground="#5A7A95" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <ItemsControl ItemsSource="{Binding ValidationItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#0A1C2A" CornerRadius="4" Padding="10,6" Margin="0,0,0,4">
                                                    <TextBlock Foreground="{Binding Color}" FontSize="12" TextWrapping="Wrap">
                                                        <Run Text="{Binding Severity, Mode=OneWay}" FontWeight="SemiBold"/>
                                                        <Run Text=": "/>
                                                        <Run Text="{Binding Message, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            </StackPanel><!-- end IsBrowserClosed StackPanel -->

                        </StackPanel>
                    </Border>
                    <!-- END MODS TAB -->

                    <!-- ═══ HEALTH AND VALIDATION TAB ═══ -->
                    <Border Style="{StaticResource Card}"
                            Visibility="{Binding IsHealthValidationTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Health and Validation" Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding CategoryDescription}" Style="{StaticResource Label}" TextWrapping="Wrap" Margin="0,4,0,12"/>
                            <UniformGrid Columns="4">
                                <Border Style="{StaticResource Panel}">
                                    <StackPanel>
                                        <TextBlock Text="Errors" Style="{StaticResource Label}"/>
                                        <TextBlock Text="{Binding ValidationErrorCount}" Foreground="#FF8A92" FontSize="24" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Panel}">
                                    <StackPanel>
                                        <TextBlock Text="Warnings" Style="{StaticResource Label}"/>
                                        <TextBlock Text="{Binding ValidationWarningCount}" Foreground="#F3B45D" FontSize="24" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Panel}">
                                    <StackPanel>
                                        <TextBlock Text="Unsaved Changes" Style="{StaticResource Label}"/>
                                        <TextBlock Text="{Binding UnsavedChangesCount}" Foreground="#89D8FF" FontSize="24" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Panel}">
                                    <StackPanel>
                                        <TextBlock Text="Restart Required" Style="{StaticResource Label}"/>
                                        <TextBlock Text="{Binding RestartRequiredChangesCount}" Foreground="#D9CCFF" FontSize="24" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <Border Style="{StaticResource Panel}">
                                <StackPanel>
                                    <TextBlock Text="Current vs Pending Configuration" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding DiffPreview, Mode=OneWay}" Style="{StaticResource Input}" FontFamily="Consolas" MinHeight="110" IsReadOnly="True"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Button Content="Review Changes" Command="{Binding ReviewChangesCommand}" Style="{StaticResource ActionButton}" Margin="0"/>
                                        <Button Content="Validate All" Command="{Binding ValidateCommand}" Style="{StaticResource ActionButton}"/>
                                        <Button Content="Export Diagnostic Report" Command="{Binding ExportConfigurationCommand}" Style="{StaticResource ActionButton}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══ STARTUP TAB ═══ -->
                    <Border Style="{StaticResource Card}"
                            Visibility="{Binding IsStartupTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Startup" Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding CategoryDescription}" Style="{StaticResource Label}" TextWrapping="Wrap" Margin="0,4,0,12"/>
                            <TextBlock Text="Server Startup" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,12,12">
                                    <TextBlock Text="Session Name" Style="{StaticResource Label}"/>
                                    <TextBox Text="{Binding ServerName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,12,12">
                                    <TextBlock Text="Server Executable" Style="{StaticResource Label}"/>
                                    <TextBlock Text="{Binding ServerExecutablePath}" Style="{StaticResource ValueText}" Margin="0,8,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Working Directory" Style="{StaticResource Label}"/>
                                    <TextBlock Text="{Binding WorkingDirectory}" Style="{StaticResource ValueText}" Margin="0,8,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,12,12">
                                    <TextBlock Text="Startup Delay" Style="{StaticResource Label}"/>
                                    <TextBlock Text="{Binding StartupDelayText}" Style="{StaticResource ValueText}" Margin="0,8,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Startup Timeout" Style="{StaticResource Label}"/>
                                    <TextBlock Text="{Binding StartupTimeoutText}" Style="{StaticResource ValueText}" Margin="0,8,0,0"/>
                                </StackPanel>
                            </UniformGrid>
                            <TextBlock Text="Launch Options" Foreground="White" FontWeight="SemiBold" Margin="0,6,0,8"/>
                            <ItemsControl ItemsSource="{Binding FilteredSections}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Description}" Style="{StaticResource Label}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Expander Header="View Generated Command" Foreground="#EAF2FA" Background="#0E1B2A" BorderBrush="#223C54" BorderThickness="1" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="{Binding MaskedCommandPreview}" Style="{StaticResource ValueText}" FontFamily="Consolas" Margin="0,8,0,10"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Copy Generated Command" Command="{Binding CopyCommandCommand}" Style="{StaticResource ActionButton}" Margin="0"/>
                                        <Button Content="Validate Command" Command="{Binding ValidateCommand}" Style="{StaticResource ActionButton}"/>
                                        <Button Content="Explain Argument Sources" Command="{Binding ValidateCommand}" Style="{StaticResource ActionButton}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </Border>

                    <!-- ═══ SETTINGS TAB (all remaining tabs) ═══ -->
                    <Border Style="{StaticResource Card}"
                            Visibility="{Binding IsSettingsTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedTab}" Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding CategoryDescription}" Style="{StaticResource Label}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    <TextBlock Foreground="#6F8DA5" FontSize="12" Margin="0,6,0,0">
                                        <Run Text="{Binding VisibleSettingsCount, Mode=OneWay}"/><Run Text=" settings visible"/>
                                        <Run Text=" | "/><Run Text="{Binding UnsavedChangesCount, Mode=OneWay}"/><Run Text=" modified"/>
                                        <Run Text=" | "/><Run Text="{Binding ValidationErrorCount, Mode=OneWay}"/><Run Text=" errors"/>
                                    </TextBlock>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Reset Category" Command="{Binding ResetCategoryCommand}" Style="{StaticResource ActionButton}" VerticalAlignment="Top"/>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding FilteredSections}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#0E1B2A" BorderBrush="#223C54" BorderThickness="1" CornerRadius="7" Padding="14" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                                                <TextBlock Text="{Binding Description}" Style="{StaticResource Label}" TextWrapping="Wrap" Margin="0,4,0,10"/>
                                                <ItemsControl ItemsSource="{Binding Settings}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderBrush="#1F3549" BorderThickness="0,1,0,0" Padding="0,10,0,10">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="260"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="{Binding DisplayName}" Foreground="#F2F8FF" FontWeight="SemiBold"/>
                                                                            <TextBlock Text="  modified" Foreground="#F3B45D" FontSize="11" Visibility="{Binding IsModified, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                            <TextBlock Text="  restart" Foreground="#89D8FF" FontSize="11" Visibility="{Binding RestartRequired, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                        </StackPanel>
                                                                        <TextBlock Text="{Binding Description}" Style="{StaticResource Label}" TextWrapping="Wrap" Margin="0,3,12,0"/>
                                                                        <TextBlock Text="{Binding WarningText}" Foreground="#F3B45D" FontSize="11" TextWrapping="Wrap" Margin="0,3,12,0" Visibility="{Binding HasWarning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                        <TextBlock Text="{Binding ErrorText}" Foreground="#FF8A92" FontSize="11" TextWrapping="Wrap" Margin="0,3,12,0" Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                        <TextBlock Text="{Binding TechnicalDetails}" Foreground="#5F7B94" FontSize="10" TextWrapping="Wrap" Margin="0,5,12,0"/>
                                                                    </StackPanel>
                                                                    <Grid Grid.Column="1" VerticalAlignment="Center">
                                                                        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}">
                                                                            <TextBox.Style>
                                                                                <Style TargetType="TextBox" BasedOn="{StaticResource Input}">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsText}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBox.Style>
                                                                        </TextBox>
                                                                        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}">
                                                                            <TextBox.Style>
                                                                                <Style TargetType="TextBox" BasedOn="{StaticResource Input}">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsNumeric}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBox.Style>
                                                                        </TextBox>
                                                                        <CheckBox Content="Enabled" IsChecked="{Binding BooleanValue}" Foreground="#DDE9F4" VerticalAlignment="Center">
                                                                            <CheckBox.Style>
                                                                                <Style TargetType="CheckBox">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    <Setter Property="Margin" Value="0,4,0,0"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsBoolean}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </CheckBox.Style>
                                                                        </CheckBox>
                                                                        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" ToolTip="Sensitive value. Masked in command previews and diffs.">
                                                                            <TextBox.Style>
                                                                                <Style TargetType="TextBox" BasedOn="{StaticResource Input}">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsPassword}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBox.Style>
                                                                        </TextBox>
                                                                        <StackPanel>
                                                                            <StackPanel.Style>
                                                                                <Style TargetType="StackPanel">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsMapSetting}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </StackPanel.Style>
                                                                            <ComboBox ItemsSource="{Binding MapChoices}"
                                                                                      SelectedItem="{Binding SelectedMapChoice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                      DisplayMemberPath="DisplayName"
                                                                                      Style="{StaticResource ComboInput}"/>
                                                                            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                                                     Style="{StaticResource Input}"
                                                                                     Margin="0,4,0,0"
                                                                                     Visibility="{Binding ShowCustomMapInput, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                                                                        <Button Content="Reset" Command="{Binding ResetToSavedCommand}" Style="{StaticResource ActionButton}" Margin="0"/>
                                                                        <Button Content="Key" Command="{Binding CopyKeyCommand}" Style="{StaticResource ActionButton}"/>
                                                                        <Button Content="Value" Command="{Binding CopyValueCommand}" Style="{StaticResource ActionButton}"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- ═══ RAW INI EDITOR TAB ═══ -->
                    <Border Style="{StaticResource Card}"
                            Visibility="{Binding IsRawEditorTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Raw INI Editor" Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding CategoryDescription}" Style="{StaticResource Label}" TextWrapping="Wrap" Margin="0,4,0,10"/>
                            <CheckBox Content="Reveal Sensitive Values" IsChecked="{Binding RevealSensitiveRawValues}" Foreground="#F3B45D" Margin="0,0,0,10"/>
                            <TabControl Background="#0E1B2A" BorderBrush="#223C54">
                                <TabItem Header="GameUserSettings.ini">
                                    <Border Style="{StaticResource Panel}">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding GameUserSettingsPath}" Style="{StaticResource Label}" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Button Content="Import" Command="{Binding ImportGameUserSettingsCommand}" Style="{StaticResource ActionButton}" Margin="0"/>
                                                    <Button Content="Export" Command="{Binding ExportGameUserSettingsCommand}" Style="{StaticResource ActionButton}"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBox Text="{Binding RawGameUserSettingsEditorText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}" FontFamily="Consolas" MinHeight="360" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                                        </StackPanel>
                                    </Border>
                                </TabItem>
                                <TabItem Header="Game.ini">
                                    <Border Style="{StaticResource Panel}">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding GameIniPath}" Style="{StaticResource Label}" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Button Content="Import" Command="{Binding ImportGameIniCommand}" Style="{StaticResource ActionButton}" Margin="0"/>
                                                    <Button Content="Export" Command="{Binding ExportGameIniCommand}" Style="{StaticResource ActionButton}"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBox Text="{Binding RawGameIniEditorText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}" FontFamily="Consolas" MinHeight="360" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                                        </StackPanel>
                                    </Border>
                                </TabItem>
                                <TabItem Header="Launch Arguments">
                                    <Border Style="{StaticResource Panel}">
                                        <StackPanel>
                                            <TextBlock Text="Generated launch command values are masked by default." Style="{StaticResource Label}"/>
                                            <TextBox Text="{Binding MaskedCommandPreview, Mode=OneWay}" Style="{StaticResource Input}" FontFamily="Consolas" MinHeight="220" IsReadOnly="True" AcceptsReturn="True"/>
                                        </StackPanel>
                                    </Border>
                                </TabItem>
                                <TabItem Header="Generated Configuration">
                                    <Border Style="{StaticResource Panel}">
                                        <StackPanel>
                                            <TextBlock Text="Generated configuration is represented by the current pending settings state." Style="{StaticResource Label}"/>
                                            <TextBox Text="{Binding DiffPreview, Mode=OneWay}" Style="{StaticResource Input}" FontFamily="Consolas" MinHeight="220" IsReadOnly="True" AcceptsReturn="True"/>
                                        </StackPanel>
                                    </Border>
                                </TabItem>
                                <TabItem Header="File Comparison">
                                    <Border Style="{StaticResource Panel}">
                                        <StackPanel>
                                            <TextBlock Text="Compare with saved version" Foreground="White" FontWeight="SemiBold"/>
                                            <TextBox Text="{Binding DiffPreview, Mode=OneWay}" Style="{StaticResource Input}" FontFamily="Consolas" MinHeight="220" IsReadOnly="True" AcceptsReturn="True"/>
                                        </StackPanel>
                                    </Border>
                                </TabItem>
                            </TabControl>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Content="Reload from Disk" Command="{Binding RevertCommand}" Style="{StaticResource ActionButton}" Margin="0"/>
                                <Button Content="Save" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}"/>
                                <Button Content="Copy" Command="{Binding CopyCommandCommand}" Style="{StaticResource ActionButton}"/>
                                <Button Content="Revert" Command="{Binding RevertCommand}" Style="{StaticResource ActionButton}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
