<UserControl x:Class="GameServerManager.App.Views.ArkAsaSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:GameServerManager.App.Views"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="#AA132236"/>
            <Setter Property="BorderBrush" Value="#3E6680"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="6"/>
        </Style>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A8B7C8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Foreground" Value="#EAF2FA"/>
            <Setter Property="Background" Value="#15283A"/>
            <Setter Property="BorderBrush" Value="#45647D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>
        <Style x:Key="ComboInput" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#E8F0F8"/>
            <Setter Property="Background" Value="#0E1824"/>
            <Setter Property="TextElement.Foreground" Value="#E8F0F8"/>
            <Setter Property="BorderBrush" Value="#45647D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#0E1824"/>
                        <Setter Property="Foreground" Value="#E8F0F8"/>
                        <Setter Property="Padding" Value="10,7"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBorder"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter TextElement.Foreground="#E8F0F8"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#183A5B"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#1E62E8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Chrome"
                                                Background="#0E1824"
                                                BorderBrush="#45647D"
                                                BorderThickness="1"
                                                CornerRadius="2">
                                            <Grid>
                                                <ContentPresenter Margin="10,0,30,0"
                                                                  TextElement.Foreground="#E8F0F8"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                                <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="#A8B7C8"
                                                      Width="8"
                                                      Height="4"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#68C7FF"/>
                                                <Setter TargetName="Chrome" Property="Background" Value="#122236"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Background="#0E1824"
                                        BorderBrush="#45647D"
                                        BorderThickness="1"
                                        CornerRadius="2"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="260">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#243A50"/>
            <Setter Property="BorderBrush" Value="#4B6F8A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
        </Style>
    </UserControl.Resources>

    <DockPanel Margin="18">
        <Border DockPanel.Dock="Bottom" Style="{StaticResource Panel}" Margin="6,10,6,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Message}" Foreground="#B8CBE0" VerticalAlignment="Center" TextWrapping="Wrap"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Copy Command" Command="{Binding CopyCommandCommand}" Style="{StaticResource ActionButton}"/>
                    <Button Content="Revert" Command="{Binding RevertCommand}" Style="{StaticResource ActionButton}"/>
                    <Button Content="Save Changes" Command="{Binding SaveCommand}" Style="{StaticResource ActionButton}" Background="#246B4A"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Panel}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="ARK ASA" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <ListBox ItemsSource="{Binding Tabs}" SelectedItem="{Binding SelectedTab}" Background="Transparent" BorderThickness="0" Foreground="#DDE9F4"/>
                </DockPanel>
            </Border>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <UniformGrid Columns="3" Margin="0,0,0,6">
                        <Border Style="{StaticResource Panel}">
                            <StackPanel>
                                <TextBlock Text="Server Name" Style="{StaticResource Label}"/>
                                <TextBox Text="{Binding ServerName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Panel}">
                            <StackPanel>
                                <TextBlock Text="Map" Style="{StaticResource Label}"/>
                                <ComboBox ItemsSource="{Binding OfficialMaps}"
                                          SelectedValue="{Binding MapName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="InternalName"
                                          DisplayMemberPath="DisplayName"
                                          Style="{StaticResource ComboInput}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Panel}">
                            <StackPanel>
                                <TextBlock Text="Install Path" Style="{StaticResource Label}"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding InstallPath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                    <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseInstallPathCommand}" Style="{StaticResource ActionButton}" Margin="6,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border Style="{StaticResource Panel}"
                            DataContext="{Binding Cluster}"
                            Visibility="{Binding DataContext.IsClusterTab, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Cluster Dashboard" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Message}" Style="{StaticResource Label}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="Validate" Command="{Binding ValidateCommand}" Style="{StaticResource ActionButton}"/>
                                    <Button Content="Start Cluster" Command="{Binding StartClusterCommand}" Style="{StaticResource ActionButton}" Background="#246B4A"/>
                                    <Button Content="Stop Cluster" Command="{Binding StopClusterCommand}" Style="{StaticResource ActionButton}"/>
                                    <Button Content="Restart" Command="{Binding RestartClusterCommand}" Style="{StaticResource ActionButton}"/>
                                    <Button Content="Backup" Command="{Binding BackupClusterCommand}" Style="{StaticResource ActionButton}"/>
                                </StackPanel>
                            </Grid>

                            <UniformGrid Columns="4">
                                <Border Style="{StaticResource Panel}">
                                    <StackPanel>
                                        <TextBlock Text="Cluster ID" Style="{StaticResource Label}"/>
                                        <TextBox Text="{Binding ClusterId, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Panel}">
                                    <StackPanel>
                                        <TextBlock Text="ClusterDirOverride" Style="{StaticResource Label}"/>
                                        <TextBox Text="{Binding ClusterDirectoryOverride, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Panel}">
                                    <StackPanel>
                                        <TextBlock Text="Maps / Warnings / Errors" Style="{StaticResource Label}"/>
                                        <TextBlock Foreground="White" FontSize="22" FontWeight="SemiBold">
                                            <Run Text="{Binding MapCount, Mode=OneWay}"/><Run Text=" / "/><Run Text="{Binding WarningCount, Mode=OneWay}"/><Run Text=" / "/><Run Text="{Binding ErrorCount, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Panel}">
                                    <StackPanel>
                                        <TextBlock Text="Shared Backup" Style="{StaticResource Label}"/>
                                        <CheckBox Content="Enabled for every map" IsChecked="{Binding SharedBackupEnabled}" Foreground="#DDE9F4" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <Border Background="#6618293B" BorderBrush="#334F64" BorderThickness="1" CornerRadius="6" Padding="12" Margin="6">
                                <StackPanel>
                                    <TextBlock Text="Add Map" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.2*"/>
                                            <ColumnDefinition Width="1.2*"/>
                                            <ColumnDefinition Width="0.8*"/>
                                            <ColumnDefinition Width="0.8*"/>
                                            <ColumnDefinition Width="0.8*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox ItemsSource="{Binding KnownMaps}" SelectedValue="{Binding SelectedMapName}" SelectedValuePath="InternalName" DisplayMemberPath="DisplayName" Background="#15283A" Foreground="#EAF2FA" BorderBrush="#45647D" Padding="8" Margin="0,0,8,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding CustomMapName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}" Margin="0,0,8,0" ToolTip="Only used when Custom is selected."/>
                                        <TextBox Grid.Column="2" Text="{Binding NextGamePort, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}" Margin="0,0,8,0"/>
                                        <TextBox Grid.Column="3" Text="{Binding NextQueryPort, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}" Margin="0,0,8,0"/>
                                        <TextBox Grid.Column="4" Text="{Binding NextRconPort, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}" Margin="0,0,8,0"/>
                                        <Button Grid.Column="5" Content="Add Map" Command="{Binding AddMapCommand}" Style="{StaticResource ActionButton}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <UniformGrid Columns="4" Margin="0,0,0,8">
                                <CheckBox Content="No transfer source filtering" IsChecked="{Binding NoTransferFromFiltering}" Foreground="#DDE9F4" Margin="6"/>
                                <CheckBox Content="Allow tribute downloads" IsChecked="{Binding AllowTributeDownloads}" Foreground="#DDE9F4" Margin="6"/>
                                <CheckBox Content="Block survivor downloads" IsChecked="{Binding PreventDownloadSurvivors}" Foreground="#DDE9F4" Margin="6"/>
                                <CheckBox Content="Block item downloads" IsChecked="{Binding PreventDownloadItems}" Foreground="#DDE9F4" Margin="6"/>
                                <CheckBox Content="Block dino downloads" IsChecked="{Binding PreventDownloadDinos}" Foreground="#DDE9F4" Margin="6"/>
                                <CheckBox Content="Block survivor uploads" IsChecked="{Binding PreventUploadSurvivors}" Foreground="#DDE9F4" Margin="6"/>
                                <CheckBox Content="Block item uploads" IsChecked="{Binding PreventUploadItems}" Foreground="#DDE9F4" Margin="6"/>
                                <CheckBox Content="Block dino uploads" IsChecked="{Binding PreventUploadDinos}" Foreground="#DDE9F4" Margin="6"/>
                            </UniformGrid>

                            <ItemsControl ItemsSource="{Binding ValidationIssues}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#4418293B" BorderBrush="{Binding Color}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="6,0,6,8">
                                            <TextBlock Foreground="{Binding Color}" TextWrapping="Wrap">
                                                <Run Text="{Binding Severity, Mode=OneWay}"/><Run Text=": "/><Run Text="{Binding Message, Mode=OneWay}"/>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding ClusterMaps}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource Panel}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="White" FontWeight="SemiBold" FontSize="15"/>
                                                    <Border DockPanel.Dock="Right" Background="#263A50" CornerRadius="5" Padding="8,3">
                                                        <TextBlock Text="{Binding StatusText}" Foreground="#DDE9F4" FontSize="11"/>
                                                    </Border>
                                                </DockPanel>
                                                <TextBlock Grid.Row="1" Foreground="#A8B7C8" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap">
                                                    <Run Text="Map "/><Run Text="{Binding MapName, Mode=OneWay}"/>
                                                    <Run Text=" | Save "/><Run Text="{Binding AltSaveDirectoryName, Mode=OneWay}"/>
                                                    <Run Text=" | Ports "/><Run Text="{Binding GamePort, Mode=OneWay}"/><Run Text="/"/><Run Text="{Binding QueryPort, Mode=OneWay}"/><Run Text="/"/><Run Text="{Binding RconPort, Mode=OneWay}"/>
                                                </TextBlock>
                                                <TextBlock Grid.Row="2" Foreground="#A8B7C8" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap">
                                                    <Run Text="Cluster "/><Run Text="{Binding ClusterId, Mode=OneWay}"/>
                                                    <Run Text=" | Backup "/><Run Text="{Binding LastBackup, Mode=OneWay}"/>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- ═══ MOD MANAGER (Mods tab only) ═══ -->
                    <Border Style="{StaticResource Panel}"
                            DataContext="{Binding Mods}"
                            Visibility="{Binding DataContext.IsModsTab, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>

                            <!-- Header + action buttons -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Mod Manager" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Message}" Style="{StaticResource Label}" Margin="0,3,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="Browse CurseForge" Command="{Binding OpenBrowserCommand}"
                                            Style="{StaticResource ActionButton}" Background="#1B4D72" BorderBrush="#2A7AB5"
                                            Visibility="{Binding IsBrowserClosed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <Button Content="← Back to Mod List" Command="{Binding CloseBrowserCommand}"
                                            Style="{StaticResource ActionButton}"
                                            Visibility="{Binding IsBrowserOpen, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <Button Content="Sort by Name" Command="{Binding SortByNameCommand}" Style="{StaticResource ActionButton}"
                                            Visibility="{Binding IsBrowserClosed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <Button Content="Sort by Date" Command="{Binding SortByDateCommand}" Style="{StaticResource ActionButton}"
                                            Visibility="{Binding IsBrowserClosed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <Button Content="Clear Disabled" Command="{Binding ClearDisabledCommand}" Style="{StaticResource ActionButton}"
                                            Visibility="{Binding IsBrowserClosed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <Button Content="Clear All" Command="{Binding ClearAllCommand}" Style="{StaticResource ActionButton}"
                                            Visibility="{Binding IsBrowserClosed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </StackPanel>
                            </Grid>

                            <!-- CurseForge Mod Browser (overlays mod list when open) -->
                            <Grid Visibility="{Binding IsBrowserOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <local:CurseForgeModBrowserView DataContext="{Binding Browser}" MinHeight="500"/>
                            </Grid>

                            <!-- Normal mod manager content (hidden when browser is open) -->
                            <StackPanel Visibility="{Binding IsBrowserClosed, Converter={StaticResource BooleanToVisibilityConverter}}">

                            <!-- Stats bar -->
                            <UniformGrid Columns="4" Margin="0,0,0,10">
                                <Border Background="#1A2E3E" BorderBrush="#2D4F68" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,6,0">
                                    <StackPanel>
                                        <TextBlock Text="Total Mods" Foreground="#7AA8C8" FontSize="11"/>
                                        <TextBlock Text="{Binding TotalMods}" Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#1A2E3E" BorderBrush="#2D4F68" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,6,0">
                                    <StackPanel>
                                        <TextBlock Text="Enabled" Foreground="#7AA8C8" FontSize="11"/>
                                        <TextBlock Text="{Binding EnabledCount}" Foreground="#4CAF50" FontSize="20" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#1A2E3E" BorderBrush="#2D4F68" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,6,0">
                                    <StackPanel>
                                        <TextBlock Text="Disabled" Foreground="#7AA8C8" FontSize="11"/>
                                        <TextBlock Text="{Binding DisabledCount}" Foreground="#A8B7C8" FontSize="20" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#1A2E3E" BorderBrush="#2D4F68" BorderThickness="1" CornerRadius="6" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock Text="Duplicates" Foreground="#7AA8C8" FontSize="11"/>
                                        <TextBlock Text="{Binding DuplicateCount}" FontSize="20" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#A8B7C8"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasDuplicates}" Value="True">
                                                            <Setter Property="Foreground" Value="#FF5555"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- Map Mod + Add Mod side by side -->
                            <UniformGrid Columns="2" Margin="0,0,0,10">

                                <!-- Active Map Mod -->
                                <Border Background="#0D1E2D" BorderBrush="#2D4F68" BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,5,0">
                                    <StackPanel>
                                        <TextBlock Text="ACTIVE MAP MOD" Foreground="#7AA8C8" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding ActiveMapModName}" Foreground="White" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"
                                                           Visibility="{Binding HasActiveMapMod, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <TextBlock Text="{Binding ActiveMapModId}" Foreground="#7AA8C8" FontSize="11" Margin="0,2,0,0"
                                                           Visibility="{Binding HasActiveMapMod, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <TextBlock Foreground="#4A6A80" FontSize="13" FontStyle="Italic">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="No map mod selected"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasActiveMapMod}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Clear" Command="{Binding ClearMapModCommand}"
                                                    Style="{StaticResource ActionButton}" VerticalAlignment="Center"
                                                    Visibility="{Binding HasActiveMapMod, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        </Grid>
                                        <TextBlock Text="Set a map mod via 'Map Mod' on any mod in the list below." Foreground="#4A6A80" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- Add Mod -->
                                <Border Background="#0D1E2D" BorderBrush="#2D4F68" BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="5,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="ADD MODS" Foreground="#7AA8C8" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding AddModInput, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource Input}"
                                                 ToolTip="Enter mod IDs (comma-separated) or paste a CurseForge URL — e.g. 928597 or https://www.curseforge.com/ark-survival-ascended/mods/..."
                                                 MinHeight="60" AcceptsReturn="True" TextWrapping="Wrap"
                                                 Margin="0,0,0,8">
                                            <TextBox.InputBindings>
                                                <KeyBinding Key="Return" Modifiers="Ctrl" Command="{Binding AddModCommand}"/>
                                            </TextBox.InputBindings>
                                        </TextBox>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Content="Enable immediately" IsChecked="{Binding AddAsEnabled}" Foreground="#DDE9F4" VerticalAlignment="Center"/>
                                            <CheckBox Grid.Column="1" Content="Cluster-wide" IsChecked="{Binding AddAsClusterWide}" Foreground="#DDE9F4" VerticalAlignment="Center"/>
                                            <Button Grid.Column="2" Content="Add Mods" Command="{Binding AddModCommand}" Style="{StaticResource ActionButton}" Background="#1E5C8A"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- CurseForge URL Preview Panel -->
                            <Border Background="#081420" BorderBrush="#1B4D6E" BorderThickness="1" CornerRadius="6" Padding="14,12" Margin="0,0,0,10"
                                    Visibility="{Binding IsPreviewVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>

                                    <!-- Loading -->
                                    <TextBlock Text="Looking up CurseForge mod..." Foreground="#6FA8C8" FontSize="12"
                                               Visibility="{Binding IsPreviewLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- NeedsId: URL detected but no API key configured -->
                                    <StackPanel Visibility="{Binding IsPreviewNeedsId, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock Text="CURSEFORGE URL DETECTED" Foreground="#7AA8C8" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <Button Content="✕" Command="{Binding DismissPreviewCommand}" HorizontalAlignment="Right"
                                                    Background="Transparent" BorderThickness="0" Foreground="#6A8A9A" FontSize="12" Padding="6,0" Cursor="Hand"/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding PreviewName}" Foreground="#EAF2FA" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding PreviewUrl}" Foreground="#4A7A9A" FontSize="10" Margin="0,0,0,8"/>
                                        <TextBlock Text="Enter the numeric Project ID from the mod's CurseForge page:" Foreground="#A8B7C8" FontSize="11" Margin="0,0,0,5"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding PreviewManualId, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource Input}" Margin="0" ToolTip="e.g. 928597"/>
                                            <Button Grid.Column="1" Content="Add Mod" Command="{Binding AddFromPreviewCommand}" Style="{StaticResource ActionButton}" Background="#1E5C8A" Margin="8,5,0,0"/>
                                            <Button Grid.Column="2" Content="Dismiss" Command="{Binding DismissPreviewCommand}" Style="{StaticResource ActionButton}" Margin="4,5,0,0"/>
                                        </Grid>
                                        <TextBlock Text="Tip: Add a CurseForge API key in Settings → Integrations to auto-fill mod IDs from URLs." Foreground="#3D6880" FontSize="10" Margin="0,7,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- Found: API returned full mod info -->
                                    <StackPanel Visibility="{Binding IsPreviewFound, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock Text="CURSEFORGE MOD FOUND" Foreground="#62F19F" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <Button Content="✕" Command="{Binding DismissPreviewCommand}" HorizontalAlignment="Right"
                                                    Background="Transparent" BorderThickness="0" Foreground="#6A8A9A" FontSize="12" Padding="6,0" Cursor="Hand"/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding PreviewName}" Foreground="#EAF2FA" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding PreviewAuthorText}" Foreground="#7AA8C8" FontSize="11" Margin="0,0,0,3"/>
                                        <TextBlock Text="{Binding PreviewSummary}" Foreground="#A8B7C8" FontSize="11" TextWrapping="Wrap" MaxHeight="42" Margin="0,0,0,8"
                                                   Visibility="{Binding HasPreviewSummary, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <Button Content="Add Mod" Command="{Binding AddFromPreviewCommand}" Style="{StaticResource ActionButton}" Background="#1E6B47" Margin="0,0,4,0"/>
                                                <Button Content="Dismiss" Command="{Binding DismissPreviewCommand}" Style="{StaticResource ActionButton}"/>
                                            </StackPanel>
                                            <TextBlock VerticalAlignment="Center">
                                                <Run Text="Project ID: " Foreground="#7AA8C8" FontSize="11"/>
                                                <Run Text="{Binding PreviewProjectId, Mode=OneWay}" Foreground="#62F19F" FontSize="13" FontWeight="SemiBold"/>
                                            </TextBlock>
                                        </DockPanel>
                                    </StackPanel>

                                    <!-- Failed: lookup error -->
                                    <StackPanel Visibility="{Binding IsPreviewFailed, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock Text="LOOKUP FAILED" Foreground="#FF6666" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <Button Content="✕" Command="{Binding DismissPreviewCommand}" HorizontalAlignment="Right"
                                                    Background="Transparent" BorderThickness="0" Foreground="#6A8A9A" FontSize="12" Padding="6,0" Cursor="Hand"/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding PreviewError}" Foreground="#A8B7C8" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                        <TextBlock Text="Enter the numeric Project ID manually:" Foreground="#A8B7C8" FontSize="11" Margin="0,0,0,5"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding PreviewManualId, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource Input}" Margin="0" ToolTip="e.g. 928597"/>
                                            <Button Grid.Column="1" Content="Add Mod" Command="{Binding AddFromPreviewCommand}" Style="{StaticResource ActionButton}" Background="#1E5C8A" Margin="8,5,0,0"/>
                                            <Button Grid.Column="2" Content="Dismiss" Command="{Binding DismissPreviewCommand}" Style="{StaticResource ActionButton}" Margin="4,5,0,0"/>
                                        </Grid>
                                    </StackPanel>

                                </StackPanel>
                            </Border>

                            <!-- Mod list toolbar -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Input}" Margin="0,0,8,0"
                                         ToolTip="Search mods by ID, name or notes"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="Import from Clipboard" Command="{Binding ImportFromClipboardCommand}" Style="{StaticResource ActionButton}"/>
                                    <Button Content="Export to Clipboard" Command="{Binding ExportToClipboardCommand}" Style="{StaticResource ActionButton}"/>
                                    <Button Content="Export to File" Command="{Binding ExportToFileCommand}" Style="{StaticResource ActionButton}"/>
                                    <Button Content="Validate" Command="{Binding ValidateCommand}" Style="{StaticResource ActionButton}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Empty state -->
                            <Border Background="#0A1828" BorderBrush="#1E3A50" BorderThickness="1" CornerRadius="8" Padding="40"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="No mods added yet" Foreground="#5A8AAA" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Add your first ARK ASA mod by entering a mod ID above." Foreground="#4A6A80" FontSize="13" HorizontalAlignment="Center" Margin="0,6,0,20" TextWrapping="Wrap"/>
                                    <TextBlock Text="Tip: you can paste a comma-separated list from an existing ActiveMods line." Foreground="#374F62" FontSize="11" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Mod list header row -->
                            <Grid Margin="0,0,0,4" Visibility="{Binding IsNotEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="240"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="#" Foreground="#4A6A80" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="On" Foreground="#4A6A80" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="Mod ID / Name" Foreground="#4A6A80" FontSize="11" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                <TextBlock Grid.Column="3" Text="Status" Foreground="#4A6A80" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="Actions" Foreground="#4A6A80" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Grid>

                            <!-- Mod rows -->
                            <ItemsControl ItemsSource="{Binding FilteredMods}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,4" CornerRadius="6" Padding="6,5">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#0F2235"/>
                                                    <Setter Property="BorderBrush" Value="#1E3A50"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasWarning}" Value="True">
                                                            <Setter Property="BorderBrush" Value="#882222"/>
                                                            <Setter Property="Background" Value="#1A1010"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                            <Setter Property="Opacity" Value="0.6"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="36"/>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="240"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Load order number -->
                                                <TextBlock Text="{Binding LoadOrder}" Foreground="#4A6A80" FontSize="12"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                                <!-- Enable toggle -->
                                                <CheckBox Grid.Column="1" IsChecked="{Binding Enabled}"
                                                          VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                                <!-- Mod info -->
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="6,0">
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding ModId}" Foreground="#5A7A95" FontSize="11"
                                                               Visibility="{Binding HasWarning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    <TextBlock Text="{Binding Notes}" Foreground="#6A8A9A" FontSize="11" TextWrapping="Wrap"
                                                               Visibility="{Binding HasWarning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                </StackPanel>

                                                <!-- Status badge -->
                                                <Border Grid.Column="3" CornerRadius="4" Padding="8,3" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Background="{Binding StatusBadgeColor}">
                                                    <TextBlock Text="{Binding StatusBadgeText}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                </Border>

                                                <!-- Actions -->
                                                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                    <Button Content="▲" Command="{Binding MoveUpCommand}" ToolTip="Move up"
                                                            Foreground="#A8B7C8" Background="Transparent" BorderThickness="0" Padding="6,3" FontSize="12"/>
                                                    <Button Content="▼" Command="{Binding MoveDownCommand}" ToolTip="Move down"
                                                            Foreground="#A8B7C8" Background="Transparent" BorderThickness="0" Padding="6,3" FontSize="12"/>
                                                    <Button Content="Copy ID" Command="{Binding CopyIdCommand}" ToolTip="Copy mod ID to clipboard"
                                                            Foreground="#7AA8C8" Background="Transparent" BorderThickness="0" Padding="6,3" FontSize="11"/>
                                                    <Button Content="Map Mod" Command="{Binding SetAsMapModCommand}" ToolTip="Set as active map mod"
                                                            Foreground="#B89AE8" Background="Transparent" BorderThickness="0" Padding="6,3" FontSize="11"/>
                                                    <Button Content="✕" Command="{Binding RemoveCommand}" ToolTip="Remove mod"
                                                            Foreground="#CC4444" Background="Transparent" BorderThickness="0" Padding="8,3" FontSize="13"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Validation panel -->
                            <Border Background="#091525" BorderBrush="#1A3040" BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="0,10,0,0">
                                <StackPanel>
                                    <TextBlock Text="VALIDATION" Foreground="#5A7A95" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <ItemsControl ItemsSource="{Binding ValidationItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{Binding Color}" BorderThickness="0,0,0,0"
                                                        Background="#0A1C2A" CornerRadius="4" Padding="10,6" Margin="0,0,0,4">
                                                    <TextBlock Foreground="{Binding Color}" FontSize="12" TextWrapping="Wrap">
                                                        <Run Text="{Binding Severity, Mode=OneWay}" FontWeight="SemiBold"/>
                                                        <Run Text=": "/>
                                                        <Run Text="{Binding Message, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            </StackPanel><!-- end IsBrowserClosed StackPanel -->

                        </StackPanel>
                    </Border>

                    <!-- ═══ SETTINGS LIST (all tabs except Cluster and Mods) ═══ -->
                    <Border Style="{StaticResource Panel}"
                            Visibility="{Binding IsSettingsTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}" Margin="0" ToolTip="Search ARK settings"/>
                                <CheckBox Grid.Column="1" Content="Advanced" IsChecked="{Binding ShowAdvanced}" Foreground="#DDE9F4" VerticalAlignment="Center" Margin="12,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding SelectedTab}" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding FilteredSettings}" Margin="0,12,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#6618293B" BorderBrush="#334F64" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="White" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Description}" Style="{StaticResource Label}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                    <TextBlock Text="{Binding WarningText}" Foreground="#F7B267" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                </StackPanel>
                                                <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input}" ToolTip="{Binding WikiReference}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <UniformGrid Columns="2">
                        <Border Style="{StaticResource Panel}">
                            <StackPanel>
                                <TextBlock Text="SteamCMD Install / Update" Foreground="White" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SteamCmdArguments}" Style="{StaticResource ValueText}" FontFamily="Consolas" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Panel}">
                            <StackPanel>
                                <TextBlock Text="Launch Command Preview" Foreground="White" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding CommandPreview}" Style="{StaticResource ValueText}" FontFamily="Consolas" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border Style="{StaticResource Panel}">
                        <StackPanel>
                            <TextBlock Text="Current vs Pending Config" Foreground="White" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding DiffPreview, Mode=OneWay}" Style="{StaticResource Input}" FontFamily="Consolas" MinHeight="90" IsReadOnly="True"/>
                        </StackPanel>
                    </Border>

                    <UniformGrid Columns="2">
                        <Border Style="{StaticResource Panel}">
                            <StackPanel>
                                <TextBlock Text="{Binding GameUserSettingsPath}" Style="{StaticResource Label}"/>
                                <TextBox Text="{Binding RawGameUserSettings}" Style="{StaticResource Input}" FontFamily="Consolas" MinHeight="180" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Panel}">
                            <StackPanel>
                                <TextBlock Text="{Binding GameIniPath}" Style="{StaticResource Label}"/>
                                <TextBox Text="{Binding RawGameIni}" Style="{StaticResource Input}" FontFamily="Consolas" MinHeight="180" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</UserControl>
