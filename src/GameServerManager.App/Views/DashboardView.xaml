<UserControl x:Class="GameServerManager.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="DashboardViewRoot"
             Background="Transparent">
    <UserControl.Resources>
        <LinearGradientBrush x:Key="CardBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#B6203147" Offset="0"/>
            <GradientStop Color="#7B162235" Offset="0.55"/>
            <GradientStop Color="#83321F3E" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CyanLineBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#4AA8FF" Offset="0"/>
            <GradientStop Color="#49F3EE" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="GreenLineBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#36D1DC" Offset="0"/>
            <GradientStop Color="#5CFF9A" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="SectionTitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="#48647D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A8B7C8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#243A50"/>
            <Setter Property="BorderBrush" Value="#4B6F8A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D89B7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Foreground" Value="#47EBD9"/>
            <Setter Property="Background" Value="#354457"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="18">

            <!-- ═══ EMPTY STATE WELCOME CARD ═══ -->
            <Border Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Background="#B6203147" BorderBrush="#48647D" BorderThickness="1"
                    CornerRadius="8" Padding="28,24" Margin="5,0,5,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Welcome to Nexus Server Manager"
                                   Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="No server profiles found. Deploy a game server to get started, or import an existing installation."
                                   Foreground="#A8B7C8" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,18" MaxWidth="500"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Deploy Server" Style="{StaticResource ActionButton}"
                                    Background="#1B5D9A" BorderBrush="#2F84D8"
                                    Margin="0" Padding="16,8" Click="OnDeployClick"/>
                            <Button Content="Import Server" Style="{StaticResource ActionButton}"
                                    Margin="8,0,0,0" Padding="16,8" Click="OnImportClick"/>
                        </StackPanel>
                    </StackPanel>
                    <Border Grid.Column="1" Width="72" Height="72" CornerRadius="36"
                            Background="#1A2A3E" BorderBrush="#2E4860" BorderThickness="2"
                            Margin="24,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="GS" Foreground="#4AA8FF" FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="System Overview" Style="{StaticResource SectionTitleText}"/>
                <Border Grid.Column="1" Background="#332C3D54" BorderBrush="#54667D"
                        BorderThickness="1" CornerRadius="6" Padding="10,5" Margin="0,0,5,0">
                    <TextBlock Text="System Overview" Foreground="#DCE7F3" FontSize="11"/>
                </Border>
            </Grid>

            <UniformGrid Columns="4" Margin="-5,0,-5,14">
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Total Servers" Style="{StaticResource MutedText}"/>
                        <TextBlock Text="{Binding ProfileCount}" Style="{StaticResource MetricValue}"/>
                        <ProgressBar Value="{Binding ProfileProgressValue, Mode=OneWay}" Maximum="{Binding ProfileProgressMaximum, Mode=OneWay}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Online Servers" Style="{StaticResource MutedText}"/>
                        <TextBlock Text="{Binding OnlineCount}" Style="{StaticResource MetricValue}" Foreground="#65F3A7"/>
                        <ProgressBar Value="{Binding OnlineCount, Mode=OneWay}" Maximum="{Binding ProfileProgressMaximum, Mode=OneWay}" Foreground="#5DFFAD"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Active Players" Style="{StaticResource MutedText}"/>
                        <TextBlock Text="{Binding PlayerCapacityText}" Style="{StaticResource MetricValue}"/>
                        <Canvas Height="24">
                            <Path Stroke="#49F3EE" StrokeThickness="1.5"
                                  Data="{Binding PlayerSparklinePath}"/>
                        </Canvas>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="CPU Usage" Style="{StaticResource MutedText}"/>
                        <TextBlock Text="{Binding CpuUsagePercent, StringFormat={}{0}%}" Style="{StaticResource MetricValue}"/>
                        <ProgressBar Value="{Binding CpuUsagePercent, Mode=OneWay}" Foreground="#8A75FF"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Memory Usage" Style="{StaticResource MutedText}"/>
                        <TextBlock Text="{Binding MemoryUsageText}" Style="{StaticResource MetricValue}"/>
                        <ProgressBar Value="{Binding MemoryUsagePercent, Mode=OneWay}" Foreground="#49E6F1"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Disk Usage" Style="{StaticResource MutedText}"/>
                        <TextBlock Text="{Binding StorageUsageText}" Style="{StaticResource MetricValue}"/>
                        <ProgressBar Value="{Binding StorageUsagePercent, Mode=OneWay}" Foreground="#F6B56E"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Network Throughput" Style="{StaticResource MutedText}"/>
                        <TextBlock Text="{Binding NetworkThroughputMbps, StringFormat={}{0} Mbps}" Style="{StaticResource MetricValue}"/>
                        <Canvas Height="24">
                            <Path Stroke="#58A7FF" StrokeThickness="1.4"
                                  Data="{Binding NetworkSparklinePath}"/>
                        </Canvas>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="System Health Score" Style="{StaticResource MutedText}"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding HealthScore}" Style="{StaticResource MetricValue}"/>
                            <Border Background="#2BC977" CornerRadius="5" Padding="6,2" Margin="10,9,0,8">
                                <TextBlock Text="+35" Foreground="#DFFFF0" FontSize="11"/>
                            </Border>
                        </StackPanel>
                        <ProgressBar Value="{Binding HealthScore, Mode=OneWay}" Foreground="#55F099"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TextBlock Text="Beautiful Analytics" Style="{StaticResource SectionTitleText}"/>
            <UniformGrid Columns="4" Margin="-5,0,-5,8">
                <Border Style="{StaticResource CardStyle}" MinHeight="142">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="CPU Performance" Foreground="White" FontWeight="SemiBold"/>
                            <TextBlock Text="..." Foreground="#A8B7C8" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <Grid Height="92" Margin="0,10,0,0">
                            <Rectangle Fill="#142437" RadiusX="4" RadiusY="4"/>
                            <Path Stroke="#2A3B4F" StrokeThickness="1" Data="M0,23 L260,23 M0,46 L260,46 M0,69 L260,69"/>
                            <Path Stroke="{StaticResource CyanLineBrush}" StrokeThickness="2"
                                  Data="{Binding CpuChartPath}"/>
                        </Grid>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" MinHeight="142">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="Memory Usage" Foreground="White" FontWeight="SemiBold"/>
                            <TextBlock Text="..." Foreground="#A8B7C8" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <Grid Height="92" Margin="0,10,0,0">
                            <Rectangle Fill="#142437" RadiusX="4" RadiusY="4"/>
                            <Path Stroke="#2A3B4F" StrokeThickness="1" Data="M0,23 L260,23 M0,46 L260,46 M0,69 L260,69"/>
                            <Path Stroke="#8F72FF" StrokeThickness="3" Data="{Binding MemoryChartPath}"/>
                            <Path Stroke="#4AE6F4" StrokeThickness="2" Data="{Binding MemoryChartPath}"/>
                        </Grid>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" MinHeight="142">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="Network Traffic" Foreground="White" FontWeight="SemiBold"/>
                            <TextBlock Text="..." Foreground="#A8B7C8" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <Grid Height="92" Margin="0,10,0,0">
                            <Rectangle Fill="#142437" RadiusX="4" RadiusY="4"/>
                            <Path Stroke="#2A3B4F" StrokeThickness="1" Data="M0,23 L260,23 M0,46 L260,46 M0,69 L260,69"/>
                            <Path Stroke="#43B7FF" StrokeThickness="2"
                                  Data="{Binding NetworkChartPath}"/>
                        </Grid>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" MinHeight="142">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="Storage Utilization" Foreground="White" FontWeight="SemiBold"/>
                            <TextBlock Text="..." Foreground="#A8B7C8" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <Grid Height="92" Margin="0,10,0,0">
                            <Rectangle Fill="#142437" RadiusX="4" RadiusY="4"/>
                            <Path Stroke="#2A3B4F" StrokeThickness="1" Data="M0,23 L260,23 M0,46 L260,46 M0,69 L260,69"/>
                            <Path Stroke="#69D9FF" StrokeThickness="2" Data="{Binding StorageChartPath}"/>
                            <Path Stroke="#F6B56E" StrokeThickness="2" Data="{Binding StorageChartPath}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.55*"/>
                    <ColumnDefinition Width="1.25*"/>
                    <ColumnDefinition Width="1.25*"/>
                </Grid.ColumnDefinitions>

                <UniformGrid Grid.Column="0" Columns="2" Margin="-5,0,5,0">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Active Processes" Foreground="White" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ActiveProcesses}" Style="{StaticResource MetricValue}"/>
                            <ProgressBar Value="{Binding OnlineCount, Mode=OneWay}" Maximum="{Binding ProfileProgressMaximum, Mode=OneWay}" Foreground="#4AA8FF"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Running Tasks" Foreground="White" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding RunningTasksText}" Style="{StaticResource MetricValue}" Foreground="#5BDDF0"/>
                            <ProgressBar Value="{Binding RunningTasksPercent, Mode=OneWay}" Foreground="#49E6F1"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Backup Status" Foreground="White" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding BackupStatusText}" FontSize="22" FontWeight="SemiBold" Foreground="#5CFF9A" Margin="0,10,0,9"/>
                            <ProgressBar Value="{Binding BackupCoveragePercent, Mode=OneWay}" Foreground="#5CFF9A"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Node Status" Foreground="White" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding FavoriteCount}" Style="{StaticResource MetricValue}" Foreground="#59F1A5"/>
                            <ProgressBar Value="{Binding FavoriteCount, Mode=OneWay}" Maximum="{Binding ProfileProgressMaximum, Mode=OneWay}" Foreground="#59F1A5"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="5,5,5,5">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="Recent Activity" Foreground="White" FontWeight="SemiBold"/>
                            <TextBlock Text="..." Foreground="#A8B7C8" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding RecentActivity}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="18" Height="18" Fill="{Binding Color}"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text="{Binding Detail}" Style="{StaticResource MutedText}" FontSize="10"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding TimeText}" Style="{StaticResource MutedText}" FontSize="10"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="5,5,5,5">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="System Health" Foreground="White" FontWeight="SemiBold"/>
                            <TextBlock Text="..." Foreground="#A8B7C8" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <TextBlock Text="{Binding ResourceAllocationPercent, StringFormat=Resource Allocation                      {0}%}" Foreground="#DDE9F4" FontSize="12"/>
                        <ProgressBar Value="{Binding ResourceAllocationPercent, Mode=OneWay}" Foreground="#49E6F1" Margin="0,6,0,12"/>
                        <TextBlock Text="{Binding ServiceAvailabilityPercent, StringFormat=Service Availability                     {0}%}" Foreground="#DDE9F4" FontSize="12"/>
                        <ProgressBar Value="{Binding ServiceAvailabilityPercent, Mode=OneWay}" Foreground="#5CFF9A" Margin="0,6,0,12"/>
                        <TextBlock Text="{Binding NetworkConnectivityPercent, StringFormat=Network Connectivity                     {0}%}" Foreground="#DDE9F4" FontSize="12"/>
                        <ProgressBar Value="{Binding NetworkConnectivityPercent, Mode=OneWay}" Foreground="#4AA8FF" Margin="0,6,0,12"/>
                        <TextBlock Text="{Binding StorageHealthPercent, StringFormat=Storage Health                           {0}%}" Foreground="#DDE9F4" FontSize="12"/>
                        <ProgressBar Value="{Binding StorageHealthPercent, Mode=OneWay}" Foreground="#4AE6F4" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource CardStyle}" Margin="5,5,5,0">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Server Profiles" Foreground="White" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <TextBlock Text="{Binding OfflineCount, StringFormat=Offline: {0}}"
                                       Foreground="#FA6D72" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Button Content="Start All" Style="{StaticResource ActionButton}"
                                    Command="{Binding StartAllCommand}" Padding="10,5" Margin="0,0,4,0"/>
                            <Button Content="Stop All" Style="{StaticResource ActionButton}"
                                    Command="{Binding StopAllCommand}" Padding="10,5"/>
                        </StackPanel>
                    </DockPanel>

                    <ItemsControl ItemsSource="{Binding Servers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#3A162438" BorderBrush="#425B72" BorderThickness="1"
                                        CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Start" Click="OnContextStartClick"/>
                                            <MenuItem Header="Stop" Click="OnContextStopClick"/>
                                            <MenuItem Header="Restart" Click="OnContextRestartClick"/>
                                            <Separator/>
                                            <MenuItem Header="Toggle Auto-Restart on Crash" Click="OnContextToggleAutoRestartClick"/>
                                            <Separator/>
                                            <MenuItem Header="Open Settings" Click="OnContextOpenSettingsClick"/>
                                            <MenuItem Header="Open Console" Click="OnContextOpenConsoleClick"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding ProfileName, Mode=OneWay}" Foreground="White"
                                                       FontSize="14" FontWeight="SemiBold"/>
                                            <TextBlock Foreground="#A8B7C8" FontSize="11">
                                                <Run Text="{Binding GameName, Mode=OneWay}"/>
                                                <Run Text=" | "/>
                                                <Run Text="{Binding InstallPath, Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock Foreground="#A8B7C8" FontSize="11" Margin="0,4,0,0">
                                                <Run Text="{Binding StatusText, Mode=OneWay}"/>
                                                <Run Text=" | Players "/>
                                                <Run Text="{Binding PlayersText, Mode=OneWay}"/>
                                                <Run Text=" | CPU "/>
                                                <Run Text="{Binding CpuPercent, Mode=OneWay}"/>
                                                <Run Text="% | RAM "/>
                                                <Run Text="{Binding RamText, Mode=OneWay}"/>
                                                <Run Text=" | Uptime "/>
                                                <Run Text="{Binding Uptime, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="Start" Style="{StaticResource ActionButton}" Click="OnStartClick"/>
                                            <Button Content="Stop" Style="{StaticResource ActionButton}" Click="OnStopClick"/>
                                            <Button Content="Restart" Style="{StaticResource ActionButton}" Click="OnRestartClick"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="No server profiles found. Add a server to get started."
                               Foreground="#7F92A6" FontSize="13"
                               Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
