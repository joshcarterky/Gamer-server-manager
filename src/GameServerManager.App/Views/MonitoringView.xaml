<UserControl x:Class="GameServerManager.App.Views.MonitoringView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7A95AA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CellText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD9E8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#96203147"/>
            <Setter Property="BorderBrush" Value="#48647D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
        </Style>
        <Style x:Key="MonBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#243A50"/>
            <Setter Property="BorderBrush" Value="#4B6F8A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D89B7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding LastUpdated, StringFormat=Updated: {0}}"
                           Foreground="#556070" FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Content="↻  Refresh" Style="{StaticResource MonBtn}"
                        Command="{Binding RefreshCommand}"/>
            </StackPanel>
            <TextBlock Text="Server Monitoring" Foreground="White" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </DockPanel>

        <!-- ═══ AGGREGATE CARDS ═══ -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">
            <Border Style="{StaticResource StatCard}" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="Servers Online" Foreground="#7A95AA" FontSize="11"/>
                    <TextBlock Text="{Binding TotalRunning}" Foreground="#3DDA85" FontSize="28" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="6,0,6,0">
                <StackPanel>
                    <TextBlock Text="Total Players" Foreground="#7A95AA" FontSize="11"/>
                    <TextBlock Text="{Binding TotalPlayers}" Foreground="White" FontSize="28" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="6,0,6,0">
                <StackPanel>
                    <TextBlock Text="Average CPU" Foreground="#7A95AA" FontSize="11"/>
                    <TextBlock Text="{Binding AverageCpu}" Foreground="#8F72FF" FontSize="28" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="6,0,0,0">
                <StackPanel>
                    <TextBlock Text="Total RAM" Foreground="#7A95AA" FontSize="11"/>
                    <TextBlock Text="{Binding TotalRamText}" Foreground="#49E6F1" FontSize="28" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ═══ TABLE HEADER ═══ -->
        <Border Grid.Row="2"
                Background="#40162030" BorderBrush="#2A3F52" BorderThickness="1,1,1,0"
                CornerRadius="6,6,0,0" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource ColHeader}" Text=""/>
                <TextBlock Grid.Column="1" Style="{StaticResource ColHeader}" Text="SERVER"/>
                <TextBlock Grid.Column="2" Style="{StaticResource ColHeader}" Text="GAME"/>
                <TextBlock Grid.Column="3" Style="{StaticResource ColHeader}" Text="STATUS"/>
                <TextBlock Grid.Column="4" Style="{StaticResource ColHeader}" Text="CPU"/>
                <TextBlock Grid.Column="5" Style="{StaticResource ColHeader}" Text="RAM"/>
                <TextBlock Grid.Column="6" Style="{StaticResource ColHeader}" Text="PLAYERS"/>
                <TextBlock Grid.Column="7" Style="{StaticResource ColHeader}" Text="UPTIME"/>
                <TextBlock Grid.Column="8" Style="{StaticResource ColHeader}" Text="LAST STARTED"/>
            </Grid>
        </Border>

        <!-- ═══ TABLE ROWS ═══ -->
        <Border Grid.Row="3"
                Background="#30101824" BorderBrush="#2A3F52" BorderThickness="1"
                CornerRadius="0,0,6,6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Empty state -->
                    <Border Padding="24" Visibility="{Binding HasNoServers, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="No servers found. Add a server profile to begin monitoring."
                                   Foreground="#556070" FontSize="13" HorizontalAlignment="Center"/>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Entries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#1E3040" BorderThickness="0,0,0,1" Padding="12,10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#14243444"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding StatusDot}"
                                                   Foreground="{Binding StatusColor}" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding GameName}" Style="{StaticResource CellText}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding StatusText}"
                                                   Foreground="{Binding StatusColor}" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="{Binding CpuText}" Style="{StaticResource CellText}"/>
                                        <TextBlock Grid.Column="5" Text="{Binding RamText}" Style="{StaticResource CellText}"/>
                                        <TextBlock Grid.Column="6" Text="{Binding PlayersText}" Style="{StaticResource CellText}"/>
                                        <TextBlock Grid.Column="7" Text="{Binding UptimeText}" Style="{StaticResource CellText}"/>
                                        <TextBlock Grid.Column="8" Text="{Binding LastStarted}" Style="{StaticResource CellText}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
