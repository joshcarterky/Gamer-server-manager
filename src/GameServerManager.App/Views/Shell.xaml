<Window x:Class="GameServerManager.App.Views.Shell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Game Server Manager"
        Width="1360" Height="860"
        MinWidth="1040" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Icon="/Assets/AppIcon.ico"
        Background="Transparent"
        AllowsTransparency="False">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#07111C" Offset="0"/>
            <GradientStop Color="#102C3D" Offset="0.38"/>
            <GradientStop Color="#20172E" Offset="0.78"/>
            <GradientStop Color="#070A12" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#CED9E8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="12,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#223A4B"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="#DCE7F3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#223A4B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="ShellFrame"
            Margin="0"
            CornerRadius="12"
            BorderBrush="#50657A"
            BorderThickness="1"
            Background="{StaticResource AppBackgroundBrush}">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="218"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="SidebarPanel"
                    Grid.Column="0"
                    Background="#80111B2B"
                    BorderBrush="#1F4B62"
                    BorderThickness="0,0,1,0"
                    CornerRadius="0">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="18,18,14,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="LogoAccent"
                                Width="24" Height="24" CornerRadius="6" Background="#1ECAFF">
                            <TextBlock Text="GS" Foreground="#06101B" FontSize="9" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="BrandNameText"
                                   Grid.Column="1" Text="Game Server" Foreground="White"
                                   FontSize="14" FontWeight="SemiBold" Margin="10,0,0,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Menu" Foreground="#8393A5" FontSize="11"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <StackPanel>
                        <Button x:Name="DashboardButton"
                                Content="Dashboard" Style="{StaticResource SidebarButtonStyle}"
                                Tag="Dashboard"
                                Background="#354A5E" Foreground="White"
                                Click="OnNavigationClick"/>
                        <Button x:Name="ServersButton"
                                Content="Servers" Style="{StaticResource SidebarButtonStyle}"
                                Tag="Servers"
                                Click="OnNavigationClick"/>
                        <Button x:Name="DeployButton"
                                Content="Deploy" Style="{StaticResource SidebarButtonStyle}"
                                Tag="Deploy"
                                Click="OnNavigationClick"/>
                        <Button x:Name="FileManagerButton"
                                Content="File Manager" Style="{StaticResource SidebarButtonStyle}"
                                Tag="File Manager"
                                Click="OnNavigationClick"/>
                        <Button x:Name="ConsoleButton"
                                Content="Console" Style="{StaticResource SidebarButtonStyle}"
                                Tag="Console"
                                Click="OnNavigationClick"/>
                        <Button x:Name="BackupsButton"
                                Content="Backups" Style="{StaticResource SidebarButtonStyle}"
                                Tag="Backups"
                                Click="OnNavigationClick"/>
                        <Button x:Name="SchedulerButton"
                                Content="Scheduler" Style="{StaticResource SidebarButtonStyle}"
                                Tag="Scheduler"
                                Click="OnNavigationClick"/>
                        <Button x:Name="MonitoringButton"
                                Content="Monitoring" Style="{StaticResource SidebarButtonStyle}"
                                Tag="Monitoring"
                                Click="OnNavigationClick"/>
                        <Button x:Name="UserManagementButton"
                                Content="User Management" Style="{StaticResource SidebarButtonStyle}"
                                Tag="User Management"
                                Click="OnNavigationClick"/>
                        <Button x:Name="SettingsButton"
                                Content="Settings" Style="{StaticResource SidebarButtonStyle}"
                                Tag="Settings"
                                Click="OnNavigationClick"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="HeaderRow" Height="58"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border x:Name="HeaderPanel"
                        Grid.Row="0"
                        Background="#66102536"
                        BorderBrush="#24556D"
                        BorderThickness="0,0,0,1"
                        CornerRadius="0"
                        MouseLeftButtonDown="OnHeaderMouseLeftButtonDown">
                    <Grid Margin="22,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PageTitleText"
                                   Text="Dashboard" Foreground="White" FontSize="16"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Alerts" Foreground="#90A4B8" FontSize="12" Margin="0,0,18,0"/>
                            <Border Width="28" Height="28" CornerRadius="14" Background="#2A3B4E">
                                <TextBlock Text="J" Foreground="White" FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Button Content="-" Style="{StaticResource WindowControlButtonStyle}" Margin="18,0,0,0" Click="OnMinimizeClick"/>
                            <Button x:Name="MaximizeButton" Content="[ ]" Style="{StaticResource WindowControlButtonStyle}" Click="OnMaximizeClick"/>
                            <Button Content="X" Style="{StaticResource WindowControlButtonStyle}" Click="OnCloseClick"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border x:Name="UpdateBanner"
                        Grid.Row="1"
                        Visibility="Collapsed"
                        Background="#173F72"
                        BorderBrush="#287DFF"
                        BorderThickness="0,0,0,1"
                        Padding="16,8">
                    <DockPanel>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button Content="View Updates" Style="{StaticResource SidebarButtonStyle}" Click="OnViewUpdatesClick" Margin="8,0,0,0"/>
                            <Button Content="Later" Style="{StaticResource WindowControlButtonStyle}" Click="OnDismissUpdateBannerClick"/>
                        </StackPanel>
                        <TextBlock x:Name="UpdateBannerText"
                                   Text="Update available"
                                   Foreground="#EAF2FA"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <ContentControl Grid.Row="2" x:Name="MainContentArea"/>
            </Grid>
        </Grid>
    </Border>
</Window>
